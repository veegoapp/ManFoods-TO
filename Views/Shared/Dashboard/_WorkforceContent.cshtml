
<style>
.wf-select-wrap { position:relative; }
.wf-select {
    appearance:none; -webkit-appearance:none;
    background:var(--card-bg); border:1px solid var(--card-border); color:var(--text);
    border-radius:var(--radius-sm); font-size:13.5px; font-weight:600;
    height:42px; padding:0 34px 0 14px; min-width:110px;
    box-shadow:var(--shadow-sm); cursor:pointer;
}
.wf-select:focus { outline:none; border-color:var(--red); box-shadow:0 0 0 3px var(--red-light); }
.wf-select-wrap i { position:absolute; top:50%; right:12px; transform:translateY(-50%); font-size:11px; color:var(--text-3); pointer-events:none; }
[dir="rtl"] .wf-select { padding:0 14px 0 34px; }
[dir="rtl"] .wf-select-wrap i { right:auto; left:12px; }

.wf-multiselect { position:relative; }
.wf-multiselect-trigger {
    display:flex; align-items:center; gap:10px; justify-content:space-between;
    background:var(--card-bg); border:1px solid var(--card-border); color:var(--text);
    border-radius:var(--radius-sm); font-size:13.5px; font-weight:600;
    height:42px; padding:0 12px 0 14px; min-width:190px;
    box-shadow:var(--shadow-sm); cursor:pointer;
}
.wf-multiselect-trigger:hover { border-color:var(--card-border-h); }
.wf-multiselect-trigger i { font-size:11px; color:var(--text-3); flex-shrink:0; }
.wf-multiselect-chips { white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.wf-multiselect-panel {
    display:none; position:absolute; top:calc(100% + 6px); left:0; z-index:50;
    background:var(--card-bg); border:1px solid var(--card-border); border-radius:var(--radius-sm);
    box-shadow:var(--shadow-lg); min-width:230px; padding:8px; max-height:280px; overflow-y:auto;
}
.wf-multiselect-panel.open { display:block; }
[dir="rtl"] .wf-multiselect-panel { left:auto; right:0; }
.wf-multiselect-actions { display:flex; gap:6px; padding:2px 4px 8px; border-bottom:1px solid var(--card-border); margin-bottom:6px; }
.wf-ms-action {
    flex:1; background:var(--card-bg-2); border:1px solid var(--card-border); color:var(--red);
    border-radius:6px; font-size:11.5px; font-weight:700; padding:6px 8px; cursor:pointer;
}
.wf-ms-action:hover { background:var(--red-light); }
.wf-ms-option { display:flex; align-items:center; gap:9px; padding:7px 8px; border-radius:6px; cursor:pointer; font-size:13px; color:var(--text-2); }
.wf-ms-option:hover { background:var(--card-bg-2); }
.wf-ms-option input { accent-color:var(--red); width:15px; height:15px; cursor:pointer; }

.wf-combobox { position:relative; }
.wf-combobox-input {
    background:var(--card-bg); border:1px solid var(--card-border); color:var(--text);
    border-radius:var(--radius-sm); font-size:13.5px; font-weight:500;
    height:42px; padding:0 14px; min-width:190px; width:100%;
    box-shadow:var(--shadow-sm);
}
.wf-combobox-input:focus { outline:none; border-color:var(--red); box-shadow:0 0 0 3px var(--red-light); }
.wf-combobox-panel {
    display:none; position:absolute; top:calc(100% + 6px); left:0; right:0; z-index:50;
    background:var(--card-bg); border:1px solid var(--card-border); border-radius:var(--radius-sm);
    box-shadow:var(--shadow-lg); max-height:260px; overflow-y:auto; padding:6px;
}
.wf-combobox-panel.open { display:block; }
.wf-combo-option { padding:8px 10px; border-radius:6px; font-size:13px; color:var(--text-2); cursor:pointer; }
.wf-combo-option:hover { background:var(--card-bg-2); }
.wf-combo-option.active { color:var(--red); font-weight:700; background:var(--red-light); }

.wf-gender-body { display:flex; align-items:center; gap:18px; height:220px; }
.wf-gender-canvas-wrap { flex:0 0 44%; height:100%; position:relative; }
.wf-gender-list { flex:1; display:flex; flex-direction:column; gap:10px; }
.wf-gender-row { display:flex; align-items:center; gap:9px; font-size:13px; color:var(--text-2); }
.wf-gender-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
.wf-gender-label { flex:1; }
.wf-gender-value { font-weight:700; color:var(--text); }
.wf-gender-pct { font-weight:500; color:var(--text-3); }

.wf-store-gender-mini { display:inline-flex; gap:4px; align-items:center; font-size:11px; color:var(--text-3); }
.wf-store-gender-mini span { display:inline-flex; align-items:center; gap:2px; }
.wf-store-gender-dot { width:7px; height:7px; border-radius:50%; display:inline-block; }

/* Chart.js draws its tick/legend text on <canvas>, which otherwise inherits
   the page's dir="rtl" and reorders labels like "1–2 years" into "years 2–1". */
.chart-body canvas { direction:ltr; }
</style>

