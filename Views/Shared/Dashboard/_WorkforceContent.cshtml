<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="~/js/dashboard.js" asp-append-version="true"></script>
<script>
/* ── Workforce page — Year + discrete Months multi-select, same filter
   components as Turnover/Comparisons/90-Day pages. Reuses dashboard.js's
   loadKpis() (via the overridden buildQuery below) for the top KPI cards,
   but does NOT use its loadCharts() (that one is resignation-based) —
   this page renders its own active-headcount composition charts instead. */
let wfYear = null;
let wfMonths = [];
let wfYearMonthsMap = {};

function wfMonthShortName(m) { return new Date(2000, m - 1, 1).toLocaleString('default', { month: 'short' }); }
function wfAnchorMonth() { return wfMonths.length ? Math.max(...wfMonths) : null; }

function buildQuery() {
    const p = new URLSearchParams();
    if (wfYear) p.set('year', wfYear);
    if (wfMonths.length) { p.set('months', wfMonths.join(',')); p.set('month', wfAnchorMonth()); }
    if (storeFilter) p.set('store', storeFilter);
    if (omFilter)    p.set('om', omFilter);
    if (ocFilter)    p.set('oc', ocFilter);
    return p.toString();
}

/* Generic searchable single-select combobox ---------------------------- */
function wfCreateCombobox({ inputId, panelId, onSelect }) {
    const input = document.getElementById(inputId);
    const panel = document.getElementById(panelId);
    const allLabel = input.placeholder;
    let options = [];
    let value = '';

    function render(filterText) {
        const ft = (filterText || '').toLowerCase();
        const filtered = options.filter(o => o.toLowerCase().includes(ft));
        let html = `<div class="wf-combo-option${value === '' ? ' active' : ''}" data-value="">${allLabel}</div>`;
        html += filtered.map(o => `<div class="wf-combo-option${o === value ? ' active' : ''}" data-value="${o.replace(/"/g, '&quot;')}">${o}</div>`).join('');
        panel.innerHTML = html;
    }
    function open() { panel.classList.add('open'); render(''); input.select(); }
    function close() { panel.classList.remove('open'); input.value = value; }

    panel.addEventListener('mousedown', (e) => {
        const opt = e.target.closest('.wf-combo-option');
        if (!opt) return;
        e.preventDefault();
        value = opt.dataset.value;
        input.value = value;
        panel.classList.remove('open');
        onSelect(value);
    });
    input.addEventListener('focus', open);
    input.addEventListener('input', () => render(input.value));
    input.addEventListener('blur', () => setTimeout(close, 150));

    return { setOptions(list) { options = list || []; }, setValue(v) { value = v || ''; input.value = value; } };
}

const wfStoreCombo = wfCreateCombobox({ inputId: 'wfStoreInput', panelId: 'wfStorePanel', onSelect: v => { storeFilter = v; loadAll(); } });
const wfOmCombo    = wfCreateCombobox({ inputId: 'wfOmInput',    panelId: 'wfOmPanel',    onSelect: v => { omFilter    = v; loadAll(); } });
const wfOcCombo    = wfCreateCombobox({ inputId: 'wfOcInput',    panelId: 'wfOcPanel',    onSelect: v => { ocFilter    = v; loadAll(); } });

/* Months multi-select ---------------------------------------------------- */
function wfBuildMonthsOptions() {
    const container = document.getElementById('wfMonthsOptions');
    const available = (wfYearMonthsMap[wfYear] || []).slice().sort((a, b) => a - b);
    container.innerHTML = available.map(m => `
        <label class="wf-ms-option">
            <input type="checkbox" value="${m}" ${wfMonths.includes(m) ? 'checked' : ''}>
            <span>${monthName(m, wfYear)}</span>
        </label>`).join('');
    container.querySelectorAll('input[type=checkbox]').forEach(cb => {
        cb.addEventListener('change', () => {
            const m = parseInt(cb.value);
            if (cb.checked) { if (!wfMonths.includes(m)) wfMonths.push(m); }
            else { wfMonths = wfMonths.filter(x => x !== m); }
            wfMonths.sort((a, b) => a - b);
            wfRenderMonthsChips();
            wfOnMonthsChanged();
        });
    });
}

function wfRenderMonthsChips() {
    const chipsEl = document.getElementById('wfMonthsChips');
    const labels = document.getElementById('wfMonthsMultiselect').dataset;
    const available = wfYearMonthsMap[wfYear] || [];
    if (!wfMonths.length) { chipsEl.textContent = labels.labelSelect; return; }
    if (wfMonths.length === available.length) { chipsEl.textContent = labels.labelAll; return; }
    const names = wfMonths.map(wfMonthShortName);
    chipsEl.textContent = names.length <= 2 ? names.join('، ') : `${names[0]}، ${names[1]} +${names.length - 2}`;
}

let wfMonthsDebounce;
function wfOnMonthsChanged() {
    clearTimeout(wfMonthsDebounce);
    wfMonthsDebounce = setTimeout(async () => {
        if (!wfMonths.length) return;
        await wfLoadDependentLists();
        await loadAll();
    }, 250);
}

document.getElementById('wfMonthsSelectAll').addEventListener('click', () => {
    wfMonths = (wfYearMonthsMap[wfYear] || []).slice().sort((a, b) => a - b);
    wfBuildMonthsOptions(); wfRenderMonthsChips(); wfOnMonthsChanged();
});
document.getElementById('wfMonthsClearAll').addEventListener('click', () => {
    wfMonths = [];
    wfBuildMonthsOptions(); wfRenderMonthsChips(); wfOnMonthsChanged();
});
document.getElementById('wfMonthsTrigger').addEventListener('click', (e) => {
    e.stopPropagation();
    document.getElementById('wfMonthsPanel').classList.toggle('open');
});
document.addEventListener('click', (e) => {
    if (!document.getElementById('wfMonthsMultiselect').contains(e.target))
        document.getElementById('wfMonthsPanel').classList.remove('open');
});

document.getElementById('wfYearSelect').addEventListener('change', async function () {
    wfYear = parseInt(this.value);
    wfMonths = (wfYearMonthsMap[wfYear] || []).slice().sort((a, b) => a - b);
    storeFilter = ''; omFilter = ''; ocFilter = '';
    wfStoreCombo.setValue(''); wfOmCombo.setValue(''); wfOcCombo.setValue('');
    wfBuildMonthsOptions(); wfRenderMonthsChips();
    await wfLoadDependentLists();
    await loadAll();
});

async function wfLoadDependentLists() {
    const anchor = wfAnchorMonth();
    if (!anchor || !wfYear) return;
    const [stores, oms, ocs] = await Promise.all([
        fetchJson(`/api/dashboard/stores?month=${anchor}&year=${wfYear}`),
        fetchJson(`/api/dashboard/operation-managers?month=${anchor}&year=${wfYear}`),
        fetchJson(`/api/dashboard/operation-consultants?month=${anchor}&year=${wfYear}`)
    ]);
    wfStoreCombo.setOptions(stores.map(s => s.storeName));
    wfOmCombo.setOptions(oms);
    wfOcCombo.setOptions(ocs);
}

async function wfInit() {
    const periods = await fetchJson('/api/dashboard/available-periods');
    if (!periods.length) return;

    wfYearMonthsMap = {};
    periods.forEach(p => { (wfYearMonthsMap[p.year] = wfYearMonthsMap[p.year] || []).push(p.month); });
    const years = Object.keys(wfYearMonthsMap).map(Number).sort((a, b) => b - a);
    const yearSel = document.getElementById('wfYearSelect');
    yearSel.innerHTML = years.map(y => `<option value="${y}">${y}</option>`).join('');
    wfYear = years[0];
    yearSel.value = wfYear;

    wfMonths = (wfYearMonthsMap[wfYear] || []).slice().sort((a, b) => a - b);
    wfBuildMonthsOptions();
    wfRenderMonthsChips();

    await wfLoadDependentLists();
    await loadAll();
}

/* ── Composition charts ──────────────────────────────────────────── */
let wfJobTitleChart, wfPayrollChart, wfTenureChart, wfGenderChart;

async function wfLoadJobTitleChart() {
    const data = await fetchJson(`/api/dashboard/headcount-by-job-title?${buildQuery()}`);
    wfJobTitleChart = mkChart(wfJobTitleChart, 'wfJobTitleChart', {
        type: 'bar',
        data: { labels: data.map(d => d.label), datasets: [{ data: data.map(d => d.value), backgroundColor: '#6D5DFB', borderRadius: 4 }] },
        options: { indexAxis: 'y', plugins: { legend: { display: false } },
            scales: { x: { grid: { color: '#E4E2F5' }, ticks: { color: '#5B5875' } }, y: { grid: { display: false }, ticks: { color: '#5B5875' } } } }
    });
}

async function wfLoadPayrollChart() {
    const data = await fetchJson(`/api/dashboard/headcount-by-payroll-group?${buildQuery()}`);
    wfPayrollChart = mkChart(wfPayrollChart, 'wfPayrollChart', {
        type: 'bar',
        data: { labels: data.map(d => d.label), datasets: [{ data: data.map(d => d.value), backgroundColor: '#5B3FE0', borderRadius: 4 }] },
        options: { indexAxis: 'y', plugins: { legend: { display: false } },
            scales: { x: { grid: { color: '#E4E2F5' }, ticks: { color: '#5B5875' } }, y: { grid: { display: false }, ticks: { color: '#5B5875' } } } }
    });
}

async function wfLoadTenureChart() {
    const data = await fetchJson(`/api/dashboard/headcount-by-tenure?${buildQuery()}`);
    wfTenureChart = mkChart(wfTenureChart, 'wfTenureChart', {
        type: 'bar',
        data: { labels: data.map(d => d.label), datasets: [{ data: data.map(d => d.value), backgroundColor: '#A78BFA', borderRadius: 4 }] },
        options: { plugins: { legend: { display: false } },
            scales: { x: { grid: { display: false }, ticks: { color: '#5B5875' } }, y: { grid: { color: '#E4E2F5' }, ticks: { color: '#5B5875' } } } }
    });
}

async function wfLoadGenderChart() {
    const data = await fetchJson(`/api/dashboard/gender-breakdown?${buildQuery()}`);
    wfGenderChart = mkChart(wfGenderChart, 'wfGenderChart', {
        type: 'doughnut',
        data: { labels: data.map(d => d.label), datasets: [{ data: data.map(d => d.value), backgroundColor: COLORS, borderWidth: 0 }] },
        options: { plugins: { legend: { display: false } } }
    });

    const el = document.getElementById('wfGenderStatsList');
    if (!data.length) { el.innerHTML = ''; return; }
    const total = data.reduce((s, d) => s + d.value, 0);
    el.innerHTML = data.map((d, i) => {
        const pct = total > 0 ? Math.round(d.value / total * 100) : 0;
        return `<div class="wf-gender-row">
            <span class="wf-gender-dot" style="background:${COLORS[i % COLORS.length]}"></span>
            <span class="wf-gender-label">${d.label}</span>
            <span class="wf-gender-value">${d.value} <span class="wf-gender-pct">(${pct}%)</span></span>
        </div>`;
    }).join('');
}

/* Headcount trend — always full history from the selected year onward,
   unaffected by the Months multi-select (same rule as the Turnover page's
   Monthly Trend chart). */
let wfHeadcountTrendChart;
async function wfLoadHeadcountTrend() {
    const q = new URLSearchParams();
    if (storeFilter) q.set('store', storeFilter);
    if (omFilter)    q.set('om', omFilter);
    if (ocFilter)    q.set('oc', ocFilter);
    if (wfYear)      q.set('sinceYear', wfYear);
    const data = await fetchJson(`/api/dashboard/headcount-trend?${q.toString()}`);
    const fmt = pk => { const [y, m] = pk.split('-'); return new Date(+y, +m - 1, 1).toLocaleString('default', { month: 'short', year: '2-digit' }); };
    wfHeadcountTrendChart = mkChart(wfHeadcountTrendChart, 'wfHeadcountTrendChart', {
        type: 'line',
        data: {
            labels: data.map(d => fmt(d.label)),
            datasets: [{ data: data.map(d => d.value), borderColor: 'oklch(0.5 0.18 25)', backgroundColor: 'oklch(0.5 0.18 25 / .12)', tension: 0.35, fill: true, pointRadius: 3 }]
        },
        options: { plugins: { legend: { display: false } },
            scales: { x: { grid: { display: false }, ticks: { color: '#5B5875' } }, y: { grid: { color: '#E4E2F5' }, ticks: { color: '#5B5875' } } } }
    });
}

/* Headcount by store, with a simple gender mix per store -------------- */
function wfRenderStoreTable(rows) {
    const tbody = document.getElementById('wfStoreTableBody');
    if (!rows || !rows.length) { tbody.innerHTML = '<tr><td colspan="3" class="text-center py-4 text-muted">No data for this period.</td></tr>'; return; }
    tbody.innerHTML = rows.map(r => {
        const total = Object.values(r.genderBreakdown).reduce((s, v) => s + v, 0) || 1;
        const genderHtml = Object.entries(r.genderBreakdown).map(([label, value], i) => {
            const pct = Math.round(value / total * 100);
            return `<span><span class="wf-store-gender-dot" style="background:${COLORS[i % COLORS.length]}"></span>${label} ${pct}%</span>`;
        }).join(' ');
        return `<tr>
            <td class="px-3 py-2 fw-semibold">${r.storeName}</td>
            <td class="px-3 py-2 text-center">${r.headcount}</td>
            <td class="px-3 py-2"><div class="wf-store-gender-mini">${genderHtml}</div></td>
        </tr>`;
    }).join('');
}

async function wfLoadStoreTable() {
    const anchor = wfAnchorMonth();
    if (!anchor || !wfYear) return;
    const q = new URLSearchParams({ month: anchor, year: wfYear });
    if (omFilter) q.set('om', omFilter);
    if (ocFilter) q.set('oc', ocFilter);
    const data = await fetchJson(`/api/dashboard/store-headcount-breakdown?${q.toString()}`);
    wfRenderStoreTable(data);
}

/* OC / OM tables (reusing the same rendering approach as Turnover) ------- */
function wfRenderOcOmTable(tbodyId, rows) {
    const tbody = document.getElementById(tbodyId);
    if (!rows || !rows.length) { tbody.innerHTML = '<tr><td colspan="4" class="text-center py-3 text-muted">No data for this period.</td></tr>'; return; }
    tbody.innerHTML = rows.map(r => {
        const bg = r.avgTurnoverRate >= 15 ? 'oklch(0.6 0.22 22)' : r.avgTurnoverRate >= 8 ? 'oklch(0.68 0.18 55)' : r.avgTurnoverRate >= 4 ? 'oklch(0.75 0.16 75)' : 'oklch(0.62 0.15 155)';
        const badge = `<span style="background:${bg};color:#fff;padding:3px 10px;border-radius:12px;font-size:11.5px;font-weight:700">${r.avgTurnoverRate.toFixed(1)}%</span>`;
        return `<tr>
            <td class="px-3 py-2 fw-semibold">${r.name}</td>
            <td class="px-3 py-2 text-center">${r.storeCount}</td>
            <td class="px-3 py-2 text-center">${r.totalHeadcount}</td>
            <td class="px-3 py-2 text-center">${badge}</td>
        </tr>`;
    }).join('');
}

async function wfLoadOcOm() {
    if (!wfYear || !wfMonths.length) return;
    const data = await fetchJson(`/api/dashboard/oc-om-analysis?${buildQuery()}`);
    wfRenderOcOmTable('ocTableBody', data.ocRows);
    wfRenderOcOmTable('omTableBody', data.omRows);
}

/* dashboard.js's own #periodSelect/#storeSelect wiring safely no-ops here
   (those elements don't exist), and its loadCharts() is never called —
   only loadKpis() is reused, via loadAll below. */
loadAll = async function () {
    await Promise.all([
        loadKpis(),
        wfLoadJobTitleChart(),
        wfLoadPayrollChart(),
        wfLoadTenureChart(),
        wfLoadGenderChart(),
        wfLoadHeadcountTrend(),
        wfLoadStoreTable(),
        wfLoadOcOm()
    ]);
};

wfInit();
</script>
