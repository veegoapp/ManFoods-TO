async function ntdLoadSmartInsights() {
    const container = document.getElementById('ntdInsightsContainer');
    if (!ntdMonths.length) { container.innerHTML = ''; return; }
    const items = await ntdFetch('smart-insights') || [];

    if (!items.length) {
        container.innerHTML = '<div class="col-12"><div class="alert alert-secondary py-2">No insights available yet — upload more cohort data to enable trend analysis.</div></div>';
        return;
    }

    const colorMap = {
        danger:    { bg: '#fff5f5', border: 'oklch(0.6 0.22 22)', text: 'oklch(0.6 0.22 22)' },
        success:   { bg: '#f0fff4', border: '#198754', text: '#198754' },
        warning:   { bg: '#fffbf0', border: 'oklch(0.75 0.16 75)', text: '#9a6c00' },
        secondary: { bg: '#f8f9fa', border: '#6c757d', text: '#6c757d' }
    };

    container.innerHTML = items.map(item => {
        const c = colorMap[item.color] || colorMap.secondary;
        return `<div class="col-md-6 col-xl-4">
            <div style="background:${c.bg};border-left:4px solid ${c.border};border-radius:8px;padding:14px 16px;height:100%">
                <div class="d-flex align-items-start gap-2">
                    <i class="bi ${item.icon} mt-1 flex-shrink-0" style="color:${c.text};font-size:17px"></i>
                    <div>
                        <div style="font-size:13px;font-weight:700;color:${c.text};margin-bottom:3px">${item.title}</div>
                        <div style="font-size:12.5px;color:oklch(0.5 0.03 258);line-height:1.55">${item.description}</div>
                    </div>
                </div>
            </div>
        </div>`;
    }).join('');
}

async function ntdLoadAll() {
    await Promise.all([
        ntdLoadKpi(), ntdLoadByCohort(), ntdLoadByStore(), ntdLoadReasons(), ntdLoadLeavers(),
        ntdLoadJobTitleChart(), ntdLoadPayrollGroupChart(), ntdLoadGenderChart(),
        ntdLoadStoreComparison(), ntdLoadOcOmAnalysis(), ntdLoadSmartInsights(),
    ]);
}

/* ── Full Data Table (90-Day Trend Matrix) — same pattern as the Turnover
   page's Full Data Table, but backed by /api/ninety-day-turnover/trend-matrix.
   Only OM/OC scope the matrix (like the Turnover page); the single Store
   combobox above is ignored here since the matrix already lists every store
   as its own row, and the search box narrows that client-side. */
let ndMxData = null;
let ndMxSortCol = 'avg';
let ndMxSortAsc = false;

function ndMxFmtPeriod(pk) {
    const [y, m] = pk.split('-');
    return new Date(+y, +m - 1, 1).toLocaleString('default', { month: 'short', year: '2-digit' });
}

function ndMxRateCell(rate) {
    if (rate === null || rate === undefined)
        return `<td class="px-2 py-2 text-center text-muted" style="color:#ccc">—</td>`;
    const bg = rate >= 15 ? 'oklch(0.6 0.22 22)'
             : rate >= 8  ? 'oklch(0.68 0.18 55)'
             : rate >= 4  ? 'oklch(0.75 0.16 75)'
             : 'oklch(0.62 0.15 155)';
    const fg = rate >= 4 ? (rate >= 8 ? '#fff' : '#1C1C27') : '#fff';
    return `<td class="px-2 py-2 text-center">
        <span style="background:${bg};color:${fg};padding:2px 8px;border-radius:10px;font-size:11px;font-weight:700;white-space:nowrap">${rate.toFixed(1)}%</span>
    </td>`;
}

function ndMxBuildHeader(periods) {
    const tr = document.querySelector('#ntdMatrixHead tr');
    const avgTh = tr.querySelector('[data-ndcol="avg"]');
    tr.querySelectorAll('[data-ndcol^="p-"]').forEach(el => el.remove());

    periods.forEach(pk => {
        const th = document.createElement('th');
        th.className = 'px-2 py-2 text-center';
        th.style.cssText = 'min-width:72px;cursor:pointer;white-space:nowrap';
        th.dataset.ndcol = `p-${pk}`;
        th.innerHTML = `${ndMxFmtPeriod(pk)} <i id="ndMxi-${pk}" class="bi bi-arrow-down-up text-muted" style="font-size:10px"></i>`;
        th.onclick = () => ndMxSort(`p-${pk}`);
        tr.insertBefore(th, avgTh);
    });
}

function ndMxRender() {
    if (!ndMxData) return;
    const search = (document.getElementById('ntdMatrixSearch').value || '').toLowerCase();

    let rows = ndMxData.rows.filter(r =>
        r.storeName.toLowerCase().includes(search) ||
        (r.operationConsultant || '').toLowerCase().includes(search)
    );

    rows.sort((a, b) => {
        let va, vb;
        if (ndMxSortCol === 'store') { va = a.storeName; vb = b.storeName; }
        else if (ndMxSortCol === 'oc') { va = a.operationConsultant || ''; vb = b.operationConsultant || ''; }
        else if (ndMxSortCol === 'avg') { va = a.avgRate ?? -1; vb = b.avgRate ?? -1; }
        else {
            va = a.periodRates[ndMxSortCol.replace('p-', '')] ?? -1;
            vb = b.periodRates[ndMxSortCol.replace('p-', '')] ?? -1;
        }
        if (typeof va === 'string') return ndMxSortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
        return ndMxSortAsc ? va - vb : vb - va;
    });

    const colSpan = 2 + ndMxData.periods.length + 1;
    if (!rows.length) {
        document.getElementById('ntdMatrixBody').innerHTML =
            `<tr><td colspan="${colSpan}" class="text-center py-4 text-muted">No matching stores.</td></tr>`;
        return;
    }

    document.getElementById('ntdMatrixBody').innerHTML = rows.map(r => {
        const periodCells = ndMxData.periods.map(pk => ndMxRateCell(r.periodRates[pk])).join('');
        const avgCell = r.avgRate !== null && r.avgRate !== undefined
            ? ndMxRateCell(r.avgRate).replace('<td', '<td style="background:oklch(0.5 0.18 25 / .06)"')
            : `<td class="px-2 py-2 text-center text-muted" style="background:oklch(0.5 0.18 25 / .06)">—</td>`;
        return `<tr>
            <td class="px-3 py-2" style="color:oklch(0.5 0.03 258);white-space:nowrap">${r.operationConsultant || '<span class="text-muted">—</span>'}</td>
            <td class="px-3 py-2 fw-semibold" style="white-space:nowrap">${r.storeName}</td>
            ${periodCells}
            ${avgCell}
        </tr>`;
    }).join('');
}

function ndMxSort(col) {
    if (ndMxSortCol === col) { ndMxSortAsc = !ndMxSortAsc; }
    else { ndMxSortCol = col; ndMxSortAsc = (col === 'store' || col === 'oc'); }
    document.querySelectorAll('#ntdMatrixHead [data-ndcol] i').forEach(i =>
        i.className = 'bi bi-arrow-down-up text-muted');
    const icon = document.querySelector(`#ntdMatrixHead [data-ndcol="${col}"] i`);
    if (icon) icon.className = ndMxSortAsc ? 'bi bi-sort-up text-danger' : 'bi bi-sort-down text-danger';
    ndMxRender();
}

async function ntdLoadTrendMatrix() {
    const body = document.getElementById('ntdMatrixBody');
    body.innerHTML = '<tr><td colspan="4" class="text-center py-4 text-muted"><div class="spinner-border spinner-border-sm me-2" style="color:oklch(0.6 0.22 22)"></div>Loading…</td></tr>';
    const q = new URLSearchParams();
    if (ntdOmFilter) q.set('om', ntdOmFilter);
    if (ntdOcFilter) q.set('oc', ntdOcFilter);
    const r = await fetch(`/api/ninety-day-turnover/trend-matrix?${q.toString()}`);
    ndMxData = r.ok ? await r.json() : null;
    if (!ndMxData || !ndMxData.rows || !ndMxData.rows.length) {
        body.innerHTML = '<tr><td colspan="4" class="text-center py-4 text-muted">No data available.</td></tr>';
        return;
    }
    ndMxBuildHeader(ndMxData.periods);
    ndMxRender();
}

document.getElementById('ntdMatrixSearch').addEventListener('input', ndMxRender);

/* Store Comparison table — sort headers + search ------------------------ */
document.querySelectorAll('#ntdStoreTable .ntd-sort').forEach(th => {
    th.addEventListener('click', () => {
        const col = th.dataset.col;
        if (ntdStoreSortCol === col) { ntdStoreSortAsc = !ntdStoreSortAsc; }
        else { ntdStoreSortCol = col; ntdStoreSortAsc = (col === 'storeName' || col === 'operationConsultant' || col === 'operationManager'); }
        document.querySelectorAll('#ntdStoreTable .ntd-sort i').forEach(i => i.className = 'bi bi-arrow-down-up text-muted');
        const icon = th.querySelector('i');
        if (icon) icon.className = ntdStoreSortAsc ? 'bi bi-sort-up text-danger' : 'bi bi-sort-down text-danger';
        ntdRenderStoreTable();
    });
});
document.getElementById('ntdStoreTableSearch').addEventListener('input', ntdRenderStoreTable);

(async function init() {
    const hasData = await ntdLoadFilters();
    if (hasData) await Promise.all([ntdLoadTrend(), ntdLoadAll(), ntdLoadTrendMatrix()]);
})();
</script>
