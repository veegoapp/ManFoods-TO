</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
<script>Chart.register(ChartDataLabels);</script>
<script>
/* ── 90-Day Turnover — Year + discrete cohort-Months multi-select, plus
   searchable single-select combos for Store/OM/OC (same components as the
   Turnover and Comparisons pages). Store/OM/OC lists on this page are
   global (not period-scoped) since the underlying API already returns
   them unscoped. */
let ntdYear = null, ntdMonths = [], ntdYearMonthsMap = {};
let ntdStoreFilter = '', ntdOmFilter = '', ntdOcFilter = '';

function ntdMonthShortName(m) { return new Date(2000, m - 1, 1).toLocaleString('default', { month: 'short' }); }
function ntdMonthLongName(m, y) { return new Date(y, m - 1).toLocaleString('default', { month: 'long', year: 'numeric' }); }
function ntdAnchor() { return ntdMonths.length ? Math.max(...ntdMonths) : null; }

function ntdBuildQuery(extra) {
    const q = new URLSearchParams(extra || {});
    if (ntdYear) q.set('year', ntdYear);
    if (ntdMonths.length) { q.set('months', ntdMonths.join(',')); q.set('month', ntdAnchor()); }
    if (ntdStoreFilter) q.set('store', ntdStoreFilter);
    if (ntdOmFilter)    q.set('om', ntdOmFilter);
    if (ntdOcFilter)    q.set('oc', ntdOcFilter);
    return q;
}

async function ntdFetch(path, extraQuery) {
    const r = await fetch(`/api/ninety-day-turnover/${path}?${ntdBuildQuery(extraQuery).toString()}`);
    return r.ok ? r.json() : null;
}

/* Generic searchable single-select combobox ---------------------------- */
function ntdCreateCombobox({ inputId, panelId, onSelect }) {
    const input = document.getElementById(inputId);
    const panel = document.getElementById(panelId);
    const allLabel = input.placeholder;
    let options = [];
    let value = '';

    function render(filterText) {
        const ft = (filterText || '').toLowerCase();
        const filtered = options.filter(o => o.toLowerCase().includes(ft));
        let html = `<div class="ntd-combo-option${value === '' ? ' active' : ''}" data-value="">${allLabel}</div>`;
        html += filtered.map(o => `<div class="ntd-combo-option${o === value ? ' active' : ''}" data-value="${o.replace(/"/g, '&quot;')}">${o}</div>`).join('');
        panel.innerHTML = html;
    }
    function open() { panel.classList.add('open'); render(''); input.select(); }
    function close() { panel.classList.remove('open'); input.value = value; }

    panel.addEventListener('mousedown', (e) => {
        const opt = e.target.closest('.ntd-combo-option');
        if (!opt) return;
        e.preventDefault();
        value = opt.dataset.value;
        input.value = value;
        panel.classList.remove('open');
        onSelect(value);
    });
    input.addEventListener('focus', open);
    input.addEventListener('input', () => render(input.value));
    input.addEventListener('blur', () => setTimeout(close, 150));

    return { setOptions(list) { options = list || []; }, setValue(v) { value = v || ''; input.value = value; } };
}

