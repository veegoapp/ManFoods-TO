/* Store Comparison (90-day) -------------------------------------------- */
let ntdStoreData = [], ntdStoreSortCol = 'rate', ntdStoreSortAsc = false;

function ntdRateColor(rate) {
    if (rate >= 50) return { bg: 'oklch(0.6 0.22 22)', fg: '#fff' };
    if (rate >= 25) return { bg: 'oklch(0.68 0.18 55)', fg: '#fff' };
    if (rate >= 10) return { bg: 'oklch(0.75 0.16 75)', fg: '#1C1C27' };
    return { bg: 'oklch(0.62 0.15 155)', fg: '#fff' };
}

function ntdRenderStoreTable() {
    const search = (document.getElementById('ntdStoreTableSearch').value || '').toLowerCase();
    let rows = ntdStoreData.filter(r =>
        r.storeName.toLowerCase().includes(search) ||
        (r.operationConsultant || '').toLowerCase().includes(search) ||
        (r.operationManager    || '').toLowerCase().includes(search)
    );
    rows.sort((a, b) => {
        const va = a[ntdStoreSortCol], vb = b[ntdStoreSortCol];
        if (typeof va === 'string') return ntdStoreSortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
        return ntdStoreSortAsc ? va - vb : vb - va;
    });

    const badge = document.getElementById('ntdStoreCountBadge');
    if (badge) badge.textContent = rows.length + ' stores';

    const tbody = document.getElementById('ntdStoreTableBody');
    if (!rows.length) {
        tbody.innerHTML = '<tr><td colspan="6" class="text-center py-4 text-muted">No matching stores.</td></tr>';
        return;
    }
    tbody.innerHTML = rows.map(r => {
        const c = ntdRateColor(r.rate);
        const rateBadge = `<span style="background:${c.bg};color:${c.fg};padding:3px 10px;border-radius:12px;font-size:11.5px;font-weight:700">${r.rate.toFixed(1)}%</span>`;
        return `<tr>
            <td class="px-3 py-2 fw-semibold">${r.storeName}</td>
            <td class="px-3 py-2" style="color:oklch(0.5 0.03 258)">${r.operationConsultant || '<span class="text-muted">—</span>'}</td>
            <td class="px-3 py-2" style="color:oklch(0.5 0.03 258)">${r.operationManager    || '<span class="text-muted">—</span>'}</td>
            <td class="px-3 py-2 text-center">${r.totalHires}</td>
            <td class="px-3 py-2 text-center" style="color:oklch(0.6 0.22 22);font-weight:600">${r.earlyLeavers}</td>
            <td class="px-3 py-2 text-center">${rateBadge}</td>
        </tr>`;
    }).join('');
}

async function ntdLoadStoreComparison() {
    if (!ntdMonths.length) { ntdStoreData = []; ntdRenderStoreTable(); return; }
    ntdStoreData = await ntdFetch('store-comparison') || [];
    ntdRenderStoreTable();
}

