@using MvcApp.Models.ViewModels
@model List<PeriodItem>
@{
    ViewData["Title"] = L["Page_Reports"].Value;
    var hasPeriods  = Model != null && Model.Count > 0;
    var __area = ViewContext.RouteData.Values["area"]?.ToString();
    var __areaPrefix = string.Equals(__area, "Home", StringComparison.OrdinalIgnoreCase) ? "/home" : "/admin";
    var sectionGroups = ReportCatalog.All.GroupBy(r => r.Section);
}

<style>
.rep-section-bar  { width: 4px; height: 20px; border-radius: 2px; flex-shrink: 0; }
.rep-card { display:block; text-decoration:none; color:inherit; cursor:pointer; transition:transform .12s, box-shadow .12s; }
.rep-card:hover { transform:translateY(-2px); box-shadow:var(--shadow-lg); color:inherit; }
.rep-card-arrow { font-size:1rem; color:var(--text-3); transition:transform .12s; }
.rep-card:hover .rep-card-arrow { transform:translateX(3px); color:var(--red); }
[dir="rtl"] .rep-card-arrow { transform:scaleX(-1); }
[dir="rtl"] .rep-card:hover .rep-card-arrow { transform:scaleX(-1) translateX(3px); }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title">@L["Page_Reports"]</h1>
        <p class="page-subtitle">@L["Page_ReportsSub"]</p>
    </div>
</div>

@if (!hasPeriods)
{
    <div class="card-dark text-center py-5">
        <i class="bi bi-file-earmark-bar-graph-fill d-block mb-3" style="font-size:3rem;color:oklch(0.5 0.18 25)"></i>
        <h5 class="mb-1">@L["Rep_UploadFirst"]</h5>
        <p class="text-muted-custom mb-0 small">Upload payroll data to unlock all reports.</p>
    </div>
}
else
{
    foreach (var grp in sectionGroups)
    {
        <div class="d-flex align-items-center gap-2 mb-3 mt-1">
            <div class="rep-section-bar" style="background:@(grp.First().IconColor)"></div>
            <h5 class="fw-bold mb-0">@grp.Key</h5>
        </div>
        <div class="row g-4 mb-4">
            @foreach (var rep in grp)
            {
                <div class="@(rep.Id == "full" || rep.Id == "exit-interviews" ? "col-md-8 col-lg-6" : "col-md-6 col-lg-4")">
                    <a class="rep-card" href="@(__areaPrefix)/dashboard/reports/@rep.Id">
                        <div class="card-dark h-100 d-flex flex-column">
                            <div class="d-flex gap-3 align-items-start">
                                <div class="card-icon flex-shrink-0" style="background:@rep.IconBg">
                                    <i class="bi @rep.Icon" style="color:@rep.IconColor"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center justify-content-between gap-2">
                                        <h6 class="mb-0">@rep.Title</h6>
                                        <i class="bi bi-arrow-right rep-card-arrow"></i>
                                    </div>
                                    <p class="text-muted-custom mb-0 small mt-1">@rep.Description</p>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
}
