            <div class="chart-body"><canvas id="ewReasonChart"></canvas></div>
        </div>
        <div class="chart-card">
            <div class="chart-header"><h6>@L["Chart_EwStoreBreakdown"]</h6><p>@L["Chart_EwStoreBreakdownSub"]</p></div>
            <div class="chart-body"><canvas id="ewStoreChart"></canvas></div>
