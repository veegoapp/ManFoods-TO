        </div>
    </div>

    <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
        <div class="d-flex align-items-center gap-2">
            <div class="section-accent"></div>
            <h5 class="mb-0 fw-bold">@L["EW_WatchList"]</h5>
            <span id="ewCountBadge" class="badge ms-1" style="background:var(--bg-2);color:var(--text-2);font-size:11px"></span>
        </div>
        <input type="text" id="ewSearch" class="form-control form-control-sm" placeholder="@L["Common_Search"]" style="width:220px;border-radius:20px">
    </div>
    <div class="chart-card p-0" style="overflow:hidden" data-employee-suffix="@L["EW_EmployeeCountSuffix"]" data-no-data="@L["EW_NoWatchlistData"]">
        <div class="table-responsive" style="max-height:520px;overflow-y:auto">
            <table class="table table-hover mb-0 ew-sortable-table" style="font-size:13px">
                <thead style="background:var(--bg-2);position:sticky;top:0;z-index:1">
                    <tr>
                        <th class="px-3 py-2 ew-sort-header" data-sort-key="name">@L["EW_HireName"]<i class="bi ew-sort-icon"></i></th>
                        <th class="px-3 py-2 ew-sort-header" data-sort-key="store">@L["EW_Store"]<i class="bi ew-sort-icon"></i></th>
                        <th class="px-3 py-2 ew-sort-header" data-sort-key="operationConsultant">@L["Common_OperationConsultant"]<i class="bi ew-sort-icon"></i></th>
                        <th class="px-3 py-2 ew-sort-header" data-sort-key="jobTitle">@L["EW_JobTitle"]<i class="bi ew-sort-icon"></i></th>
                        <th class="px-3 py-2 ew-sort-header" data-sort-key="hireDate">@L["EW_HireDate"]<i class="bi ew-sort-icon"></i></th>
                        <th class="px-3 py-2 ew-sort-header" data-sort-key="tenureDays">@L["EW_TenureDays"]<i class="bi ew-sort-icon"></i></th>
                        <th class="px-3 py-2 text-center ew-sort-header" data-sort-key="stars">@L["EW_RiskScore"]<i class="bi ew-sort-icon"></i></th>
                        <th class="px-3 py-2">@L["EW_Reasons"]</th>
                    </tr>
                </thead>
                <tbody id="ewBody">
                    <tr><td colspan="8" class="text-center py-4 text-muted">
                        <div class="spinner-border spinner-border-sm me-2" style="color:oklch(0.5 0.18 25)"></div>@L["Common_Loading"]
                    </td></tr>
                </tbody>
            </table>
        </div>
