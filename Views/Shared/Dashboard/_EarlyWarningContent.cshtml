<div id="ewEmptyState" class="card-dark text-center py-5" style="display:none">
    <i class="bi bi-shield-check" style="font-size:3rem;color:oklch(0.5 0.18 25);display:block;margin-bottom:1rem"></i>
    <h5 class="mb-2">No Active Employee Data Yet</h5>
    <p class="text-muted-custom">Upload workforce data with hire dates to see the early-warning watchlist here.</p>
</div>

<div id="ewContent">
    <div id="ewSummaryCards" class="kpi-grid mb-4">
        <div class="kpi-spinner text-center py-3 w-100">
            <div class="spinner-border spinner-border-sm" style="color:oklch(0.5 0.18 25)"></div>
        </div>
    </div>

    <div class="charts-grid mb-4">
        <div class="chart-card">
