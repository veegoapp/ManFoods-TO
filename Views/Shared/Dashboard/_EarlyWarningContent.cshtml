     data-kpi-in-watchlist="@L["EW_InWatchList"]"
     data-kpi-high-risk="@L["EW_HighRisk"]"
     data-kpi-new-hire-window="@L["EW_NewHireWindow"]"
     data-kpi-company-baseline="@L["EW_CompanyBaseline"]"
     data-reason-new-hire-window="@L["EW_ReasonNewHireWindow"]"
     data-reason-store-history="@L["EW_ReasonStoreHistory"]"
     data-reason-role-history="@L["EW_ReasonRoleHistory"]"
     data-reason-peak-window="@L["EW_ReasonPeakWindow"]"
     data-reason-gender-history="@L["EW_ReasonGenderHistory"]"
     data-reason-exit-interview-score="@L["EW_ReasonExitInterviewScore"]"
     data-reason-store-leader-history="@L["EW_ReasonStoreLeaderHistory"]"
     data-reason-type-new-hire-window="@L["EW_ReasonType_NewHireWindow"]"
     data-reason-type-store-history="@L["EW_ReasonType_StoreHistory"]"
     data-reason-type-role-history="@L["EW_ReasonType_RoleHistory"]"
     data-reason-type-peak-window="@L["EW_ReasonType_PeakWindow"]"
     data-reason-type-gender-history="@L["EW_ReasonType_GenderHistory"]"
