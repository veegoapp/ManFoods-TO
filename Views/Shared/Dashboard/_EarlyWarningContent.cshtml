                </thead>
                <tbody id="ewHighRiskBody">
                    <tr><td colspan="8" class="text-center py-4 text-muted">
                        <div class="spinner-border spinner-border-sm me-2" style="color:oklch(0.5 0.18 25)"></div>@L["Common_Loading"]
                    </td></tr>
                </tbody>
