
<style>
.ew-select-wrap { position:relative; }
.ew-select {
    appearance:none; -webkit-appearance:none;
    background:var(--card-bg); border:1px solid var(--card-border); color:var(--text);
    border-radius:var(--radius-sm); font-size:13.5px; font-weight:600;
    height:42px; padding:0 34px 0 14px; min-width:110px;
    box-shadow:var(--shadow-sm); cursor:pointer;
}
.ew-select:focus { outline:none; border-color:var(--red); box-shadow:0 0 0 3px var(--red-light); }
.ew-select-wrap i { position:absolute; top:50%; right:12px; transform:translateY(-50%); font-size:11px; color:var(--text-3); pointer-events:none; }
[dir="rtl"] .ew-select { padding:0 14px 0 34px; }
[dir="rtl"] .ew-select-wrap i { right:auto; left:12px; }

.ew-multiselect { position:relative; }
.ew-multiselect-trigger {
    display:flex; align-items:center; gap:10px; justify-content:space-between;
    background:var(--card-bg); border:1px solid var(--card-border); color:var(--text);
    border-radius:var(--radius-sm); font-size:13.5px; font-weight:600;
    height:42px; padding:0 12px 0 14px; min-width:190px;
    box-shadow:var(--shadow-sm); cursor:pointer;
}
.ew-multiselect-trigger:hover { border-color:var(--card-border-h); }
.ew-multiselect-trigger i { font-size:11px; color:var(--text-3); flex-shrink:0; }
.ew-multiselect-chips { white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.ew-multiselect-panel {
    display:none; position:absolute; top:calc(100% + 6px); left:0; z-index:50;
    background:var(--card-bg); border:1px solid var(--card-border); border-radius:var(--radius-sm);
    box-shadow:var(--shadow-lg); min-width:230px; padding:8px; max-height:280px; overflow-y:auto;
}
.ew-multiselect-panel.open { display:block; }
[dir="rtl"] .ew-multiselect-panel { left:auto; right:0; }
.ew-multiselect-actions { display:flex; gap:6px; padding:2px 4px 8px; border-bottom:1px solid var(--card-border); margin-bottom:6px; }
.ew-ms-action {
    flex:1; background:var(--card-bg-2); border:1px solid var(--card-border); color:var(--red);
    border-radius:6px; font-size:11.5px; font-weight:700; padding:6px 8px; cursor:pointer;
}
.ew-ms-action:hover { background:var(--red-light); }
.ew-ms-option { display:flex; align-items:center; gap:9px; padding:7px 8px; border-radius:6px; cursor:pointer; font-size:13px; color:var(--text-2); }
.ew-ms-option:hover { background:var(--card-bg-2); }
.ew-ms-option input { accent-color:var(--red); width:15px; height:15px; cursor:pointer; }

.ew-combobox { position:relative; }
.ew-combobox-input {
    background:var(--card-bg); border:1px solid var(--card-border); color:var(--text);
    border-radius:var(--radius-sm); font-size:13.5px; font-weight:500;
    height:42px; padding:0 14px; min-width:190px; width:100%;
    box-shadow:var(--shadow-sm);
}
.ew-combobox-input:focus { outline:none; border-color:var(--red); box-shadow:0 0 0 3px var(--red-light); }
.ew-combobox-panel {
    display:none; position:absolute; top:calc(100% + 6px); left:0; right:0; z-index:50;
    background:var(--card-bg); border:1px solid var(--card-border); border-radius:var(--radius-sm);
    box-shadow:var(--shadow-lg); max-height:260px; overflow-y:auto; padding:6px;
}
.ew-combobox-panel.open { display:block; }
.ew-combo-option { padding:8px 10px; border-radius:6px; font-size:13px; color:var(--text-2); cursor:pointer; }
.ew-combo-option:hover { background:var(--card-bg-2); }
.ew-combo-option.active { color:var(--red); font-weight:700; background:var(--red-light); }

/* Chart.js draws its tick/legend text on <canvas>, which otherwise inherits
   the page's dir="rtl" and reorders numeric-leading labels. */
.chart-body canvas { direction:ltr; }

.ew-sort-header { cursor:pointer; user-select:none; white-space:nowrap; }
.ew-sort-header:hover { color:var(--red); }
.ew-sort-icon { font-size:10px; margin-left:4px; opacity:0.35; }
[dir="rtl"] .ew-sort-icon { margin-left:0; margin-right:4px; }
.ew-sort-header.ew-sort-asc .ew-sort-icon,
.ew-sort-header.ew-sort-desc .ew-sort-icon { opacity:1; color:var(--red); }
.ew-sort-header.ew-sort-asc .ew-sort-icon::before { content:"\f235"; }   /* bi-caret-up-fill */
.ew-sort-header.ew-sort-desc .ew-sort-icon::before { content:"\f229"; } /* bi-caret-down-fill */
.ew-sort-header:not(.ew-sort-asc):not(.ew-sort-desc) .ew-sort-icon::before { content:"\f229"; }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title">@L["Page_EarlyWarning"]</h1>
        <p class="page-subtitle">@L["Page_EarlyWarningSub"]</p>
    </div>
    <div class="d-flex gap-2 flex-wrap align-items-end">
        <div class="ew-select-wrap"><select id="ewYearSelect" class="ew-select"></select><i class="bi bi-chevron-down"></i></div>

        <div class="ew-multiselect" id="ewMonthsMultiselect" data-label-select="@L["Common_SelectMonths"]" data-label-all="@L["Common_AllMonths"]">
            <button type="button" class="ew-multiselect-trigger" id="ewMonthsTrigger">
                <span class="ew-multiselect-chips" id="ewMonthsChips">@L["Common_AllMonths"]</span>
                <i class="bi bi-chevron-down"></i>
            </button>
            <div class="ew-multiselect-panel" id="ewMonthsPanel">
                <div class="ew-multiselect-actions">
                    <button type="button" class="ew-ms-action" id="ewMonthsSelectAll">@L["Common_SelectAll"]</button>
                    <button type="button" class="ew-ms-action" id="ewMonthsClearAll">@L["Common_ClearAll"]</button>
                </div>
                <div id="ewMonthsOptions"></div>
            </div>
        </div>

        <div class="ew-combobox" id="ewStoreCombo">
            <input type="text" class="ew-combobox-input" id="ewStoreInput" placeholder="@L["Common_AllStores"]" autocomplete="off">
            <div class="ew-combobox-panel" id="ewStorePanel"></div>
        </div>
    </div>
</div>

