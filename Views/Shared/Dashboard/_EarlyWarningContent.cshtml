</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
<script>Chart.register(ChartDataLabels);</script>
<script>
/* ── Early Warning page — Year + discrete Months multi-select (picks which
   Active Employees snapshot counts as "currently active"), same filter
   components as other redesigned pages. Historical risk-factor baselines
   always use all-time data regardless of this filter. */
let ewYear = null, ewMonths = [], ewYearMonthsMap = {};
let ewStoreFilter = '';
let ewWatchlistData = [];

const EW_REASON_TYPES = ['new_hire_window', 'store_history', 'role_history', 'peak_window', 'gender_history', 'exit_interview_score', 'store_leader_history'];
const EW_REASON_COLORS = {
    new_hire_window:      'oklch(0.55 0.19 25)',
    store_history:        'oklch(0.65 0.15 190)',
    role_history:         'oklch(0.7 0.16 145)',
    peak_window:          'oklch(0.72 0.17 60)',
    gender_history:       'oklch(0.68 0.15 310)',
    exit_interview_score: 'oklch(0.62 0.18 15)',
    store_leader_history: 'oklch(0.66 0.14 230)',
};
const EW_L = document.getElementById('ewLocalization').dataset;

function ewMonthShortName(m) { return new Date(2000, m - 1, 1).toLocaleString('default', { month: 'short' }); }
function ewMonthLongName(m, y) { return new Date(y, m - 1).toLocaleString('default', { month: 'long', year: 'numeric' }); }

function ewBuildQuery(extra) {
    const q = new URLSearchParams(extra || {});
    if (ewYear) q.set('year', ewYear);
    if (ewMonths.length) q.set('months', ewMonths.join(','));
    if (ewStoreFilter) q.set('store', ewStoreFilter);
    return q;
}

async function ewFetch(path) {
    const r = await fetch(`/api/early-warning/${path}?${ewBuildQuery().toString()}`);
    return r.ok ? r.json() : null;
}

/* Generic searchable single-select combobox ------------------------------ */
function ewCreateCombobox({ inputId, panelId, onSelect }) {
    const input = document.getElementById(inputId);
    const panel = document.getElementById(panelId);
    const allLabel = input.placeholder;
    let options = [];
    let value = '';

    function render(filterText) {
        const ft = (filterText || '').toLowerCase();
        const filtered = options.filter(o => o.toLowerCase().includes(ft));
        let html = `<div class="ew-combo-option${value === '' ? ' active' : ''}" data-value="">${allLabel}</div>`;
        html += filtered.map(o => `<div class="ew-combo-option${o === value ? ' active' : ''}" data-value="${o.replace(/"/g, '&quot;')}">${o}</div>`).join('');
        panel.innerHTML = html;
    }
    function open() { panel.classList.add('open'); render(''); input.select(); }
    function close() { panel.classList.remove('open'); input.value = value; }

    panel.addEventListener('mousedown', (e) => {
        const opt = e.target.closest('.ew-combo-option');
        if (!opt) return;
        e.preventDefault();
        value = opt.dataset.value;
        input.value = value;
        panel.classList.remove('open');
        onSelect(value);
    });
    input.addEventListener('focus', open);
    input.addEventListener('input', () => render(input.value));
    input.addEventListener('blur', () => setTimeout(close, 150));

    return { setOptions(list) { options = list || []; }, setValue(v) { value = v || ''; input.value = value; } };
}

const ewStoreCombo = ewCreateCombobox({ inputId: 'ewStoreInput', panelId: 'ewStorePanel', onSelect: v => { ewStoreFilter = v; ewLoadAll(); } });

/* Months multi-select ---------------------------------------------------- */
function ewBuildMonthsOptions() {
    const container = document.getElementById('ewMonthsOptions');
    const available = (ewYearMonthsMap[ewYear] || []).slice().sort((a, b) => a - b);
    container.innerHTML = available.map(m => `
        <label class="ew-ms-option">
            <input type="checkbox" value="${m}" ${ewMonths.includes(m) ? 'checked' : ''}>
            <span>${ewMonthLongName(m, ewYear)}</span>
        </label>`).join('');
    container.querySelectorAll('input[type=checkbox]').forEach(cb => {
        cb.addEventListener('change', () => {
            const m = parseInt(cb.value);
            if (cb.checked) { if (!ewMonths.includes(m)) ewMonths.push(m); }
            else { ewMonths = ewMonths.filter(x => x !== m); }
            ewMonths.sort((a, b) => a - b);
            ewRenderMonthsChips();
            ewOnMonthsChanged();
        });
    });
}

function ewRenderMonthsChips() {
    const chipsEl = document.getElementById('ewMonthsChips');
    const labels = document.getElementById('ewMonthsMultiselect').dataset;
    const available = ewYearMonthsMap[ewYear] || [];
    if (!ewMonths.length) { chipsEl.textContent = labels.labelSelect; return; }
    if (ewMonths.length === available.length) { chipsEl.textContent = labels.labelAll; return; }
    const names = ewMonths.map(ewMonthShortName);
    chipsEl.textContent = names.length <= 2 ? names.join('، ') : `${names[0]}، ${names[1]} +${names.length - 2}`;
}

let ewMonthsDebounce;
function ewOnMonthsChanged() {
    clearTimeout(ewMonthsDebounce);
    ewMonthsDebounce = setTimeout(() => { if (ewMonths.length) ewLoadAll(); }, 250);
}

document.getElementById('ewMonthsSelectAll').addEventListener('click', () => {
    ewMonths = (ewYearMonthsMap[ewYear] || []).slice().sort((a, b) => a - b);
    ewBuildMonthsOptions(); ewRenderMonthsChips(); ewOnMonthsChanged();
});
document.getElementById('ewMonthsClearAll').addEventListener('click', () => {
    ewMonths = [];
    ewBuildMonthsOptions(); ewRenderMonthsChips(); ewOnMonthsChanged();
});
document.getElementById('ewMonthsTrigger').addEventListener('click', (e) => {
    e.stopPropagation();
    document.getElementById('ewMonthsPanel').classList.toggle('open');
});
document.addEventListener('click', (e) => {
    if (!document.getElementById('ewMonthsMultiselect').contains(e.target))
        document.getElementById('ewMonthsPanel').classList.remove('open');
});

document.getElementById('ewYearSelect').addEventListener('change', async function () {
    ewYear = parseInt(this.value);
    ewMonths = (ewYearMonthsMap[ewYear] || []).slice().sort((a, b) => a - b);
    ewBuildMonthsOptions(); ewRenderMonthsChips();
    await ewLoadAll();
});

/* Initial filter load ------------------------------------------------------ */
async function ewLoadFilters() {
    const [periods, stores] = await Promise.all([
        fetch('/api/dashboard/available-periods').then(r => r.ok ? r.json() : []),
        fetch('/api/early-warning/stores').then(r => r.ok ? r.json() : []),
    ]);

    const hasData = (periods || []).length > 0;
    document.getElementById('ewEmptyState').style.display = hasData ? 'none' : '';
    document.getElementById('ewContent').style.display = hasData ? '' : 'none';
    if (!hasData) return false;

    ewYearMonthsMap = {};
    (periods || []).forEach(p => { (ewYearMonthsMap[p.year] = ewYearMonthsMap[p.year] || []).push(p.month); });
    const years = Object.keys(ewYearMonthsMap).map(Number).sort((a, b) => b - a);
    const yearSel = document.getElementById('ewYearSelect');
    yearSel.innerHTML = years.map(y => `<option value="${y}">${y}</option>`).join('');
    ewYear = years[0];
    yearSel.value = ewYear;
    ewMonths = (ewYearMonthsMap[ewYear] || []).slice().sort((a, b) => a - b);
    ewBuildMonthsOptions();
    ewRenderMonthsChips();

    ewStoreCombo.setOptions(stores || []);
    return true;
}

function ewRenderSummary(s) {
    const el = document.getElementById('ewSummaryCards');
    if (!s) { el.innerHTML = ''; return; }
    el.innerHTML = `
        <div class="kpi-card"><div class="kpi-icon"><i class="bi bi-eye-fill"></i></div><div class="kpi-value">${s.totalWatchlist}</div><div class="kpi-label">${EW_L.kpiInWatchlist}</div></div>
        <div class="kpi-card"><div class="kpi-icon text-danger"><i class="bi bi-exclamation-triangle-fill"></i></div><div class="kpi-value text-danger">${s.highRiskCount}</div><div class="kpi-label">${EW_L.kpiHighRisk}</div></div>
        <div class="kpi-card"><div class="kpi-icon"><i class="bi bi-hourglass-split"></i></div><div class="kpi-value">${s.newHireWindowCount}</div><div class="kpi-label">${EW_L.kpiNewHireWindow}</div></div>
        <div class="kpi-card"><div class="kpi-icon"><i class="bi bi-graph-up"></i></div><div class="kpi-value">${s.companyBaselineRate.toFixed(1)}%</div><div class="kpi-label">${EW_L.kpiCompanyBaseline}</div></div>
    `;
}

async function ewLoadSummary() {
    ewRenderSummary(await ewFetch('summary'));
}

function ewReasonText(reason) {
    const templates = {
        new_hire_window:      EW_L.reasonNewHireWindow,
        store_history:        EW_L.reasonStoreHistory,
        role_history:         EW_L.reasonRoleHistory,
        peak_window:          EW_L.reasonPeakWindow,
        gender_history:       EW_L.reasonGenderHistory,
        exit_interview_score: EW_L.reasonExitInterviewScore,
        store_leader_history: EW_L.reasonStoreLeaderHistory,
    };
    const t = templates[reason.type] || '';
    return t.replace(/\{(\w+)\}/g, (_, k) => reason.params?.[k] ?? '');
}

function ewRiskBadge(stars) {
    const color = stars >= 4 ? 'oklch(0.6 0.22 22)'
                : stars >= 3 ? 'oklch(0.72 0.19 50)'
                : stars >= 2 ? 'oklch(0.75 0.16 75)'
                :              'oklch(0.55 0.15 25)';
    const filled = '★'.repeat(stars);
    const empty  = '☆'.repeat(5 - stars);
    return `<span style="color:${color};font-size:15px;letter-spacing:1px;line-height:1" title="${stars}/5">${filled}${empty}</span>`;
}

function ewRowHtml(r) {
    return `
        <tr>
            <td class="px-3 py-2 fw-semibold">${r.name}</td>
            <td class="px-3 py-2">${r.store}</td>
            <td class="px-3 py-2" style="color:var(--text-2)">${r.operationConsultant || ''}</td>
            <td class="px-3 py-2" style="color:var(--text-2)">${r.jobTitle}</td>
            <td class="px-3 py-2" style="color:var(--text-2)">${r.hireDate}</td>
            <td class="px-3 py-2">${r.tenureDays}</td>
            <td class="px-3 py-2 text-center">${ewRiskBadge(r.stars)}</td>
            <td class="px-3 py-2" style="font-size:12px;color:var(--text-2)">${r.reasons.map(x => `• ${ewReasonText(x)}`).join('<br>')}</td>
        </tr>`;
}

/* Generic sortable-header wiring ------------------------------------------
   Each table tracks its own sort key/direction so the two tables (High Risk
   and Watch List) can be sorted independently. */
const ewSortState = {}; // tableId -> { key, dir }

function ewSortValue(row, key) {
    const v = row[key];
    if (key === 'hireDate') return new Date(v).getTime() || 0;
    if (typeof v === 'number') return v;
    return (v || '').toString().toLowerCase();
}

function ewApplySort(tableId, rows) {
    const state = ewSortState[tableId];
    if (!state || !state.key) return rows;
    const sorted = rows.slice().sort((a, b) => {
        const va = ewSortValue(a, state.key), vb = ewSortValue(b, state.key);
        if (va < vb) return state.dir === 'asc' ? -1 : 1;
        if (va > vb) return state.dir === 'asc' ? 1 : -1;
        return 0;
    });
    return sorted;
}

function ewWireSortHeaders(tableId, renderFn) {
    const table = document.querySelector(`#${tableId}`).closest('table');
    table.querySelectorAll('.ew-sort-header').forEach(th => {
        th.addEventListener('click', () => {
            const key = th.dataset.sortKey;
            const state = ewSortState[tableId] || { key: null, dir: 'asc' };
            state.dir = (state.key === key && state.dir === 'asc') ? 'desc' : 'asc';
            state.key = key;
            ewSortState[tableId] = state;
            table.querySelectorAll('.ew-sort-header').forEach(h => h.classList.remove('ew-sort-asc', 'ew-sort-desc'));
            th.classList.add(state.dir === 'asc' ? 'ew-sort-asc' : 'ew-sort-desc');
            renderFn();
        });
    });
}

function ewRenderTable(rows) {
    const tbody = document.getElementById('ewBody');
    const labels = document.querySelector('#ewBody').closest('.chart-card').dataset;
    const search = (document.getElementById('ewSearch').value || '').toLowerCase();
    const filtered = rows.filter(r =>
        r.name.toLowerCase().includes(search) ||
        (r.store || '').toLowerCase().includes(search) ||
        (r.operationConsultant || '').toLowerCase().includes(search) ||
        (r.jobTitle || '').toLowerCase().includes(search)
    );
    const sorted = ewApplySort('ewBody', filtered);

    const badge = document.getElementById('ewCountBadge');
    badge.textContent = `${sorted.length} ${labels.employeeSuffix}`;
    if (!sorted.length) { tbody.innerHTML = `<tr><td colspan="8" class="text-center py-4 text-muted">${labels.noData}</td></tr>`; return; }
    tbody.innerHTML = sorted.map(ewRowHtml).join('');
}

function ewRenderHighRiskTable(rows) {
    const tbody = document.getElementById('ewHighRiskBody');
    const labels = document.querySelector('#ewHighRiskBody').closest('.chart-card').dataset;
    const highRisk = rows.filter(r => r.stars >= 4);
    const sorted = ewApplySort('ewHighRiskBody', highRisk);

    const badge = document.getElementById('ewHighRiskCountBadge');
    badge.textContent = `${sorted.length} ${labels.employeeSuffix}`;
    if (!sorted.length) { tbody.innerHTML = `<tr><td colspan="8" class="text-center py-4 text-muted">${labels.noData}</td></tr>`; return; }
    tbody.innerHTML = sorted.map(ewRowHtml).join('');
}

ewWireSortHeaders('ewBody', () => ewRenderTable(ewWatchlistData));
ewWireSortHeaders('ewHighRiskBody', () => ewRenderHighRiskTable(ewWatchlistData));

/* Charts — derived client-side from the watchlist response ---------------- */
let ewReasonChartInstance, ewStoreChartInstance;

function ewLoadReasonChart(rows) {
    const counts = {};
    EW_REASON_TYPES.forEach(t => counts[t] = 0);
    rows.forEach(r => r.reasons.forEach(x => { if (counts[x.type] != null) counts[x.type]++; }));

    const labelMap = {
        new_hire_window:      EW_L.reasonTypeNewHireWindow,
        store_history:        EW_L.reasonTypeStoreHistory,
        role_history:         EW_L.reasonTypeRoleHistory,
        peak_window:          EW_L.reasonTypePeakWindow,
        gender_history:       EW_L.reasonTypeGenderHistory,
        exit_interview_score: EW_L.reasonTypeExitInterviewScore,
        store_leader_history: EW_L.reasonTypeStoreLeaderHistory,
    };

    const ctx = document.getElementById('ewReasonChart');
    if (!ctx) return;
    if (ewReasonChartInstance) ewReasonChartInstance.destroy();
    ewReasonChartInstance = new Chart(ctx.getContext('2d'), {
        type: 'bar',
        data: {
            labels: EW_REASON_TYPES.map(t => labelMap[t]),
            datasets: [{ data: EW_REASON_TYPES.map(t => counts[t]), backgroundColor: EW_REASON_TYPES.map(t => EW_REASON_COLORS[t]), borderRadius: 4, maxBarThickness: 34 }],
        },
        options: {
            indexAxis: 'y', maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                datalabels: { anchor: 'end', align: 'right', color: 'oklch(0.5 0.03 258)', font: { size: 11, weight: '600' }, formatter: v => v > 0 ? v : '' },
            },
            scales: {
                x: { ticks: { color: 'oklch(0.5 0.03 258)' }, grid: { color: 'oklch(0.92 0.008 255)' } },
                y: { ticks: { color: 'oklch(0.5 0.03 258)' }, grid: { display: false } },
            },
        },
    });
}

function ewLoadStoreChart(rows) {
    const counts = {};
    rows.forEach(r => { if (r.store) counts[r.store] = (counts[r.store] || 0) + 1; });
    const entries = Object.entries(counts).sort((a, b) => b[1] - a[1]);

    const ctx = document.getElementById('ewStoreChart');
    if (!ctx) return;
    if (ewStoreChartInstance) ewStoreChartInstance.destroy();
    ewStoreChartInstance = new Chart(ctx.getContext('2d'), {
        type: 'bar',
        data: {
            labels: entries.map(e => e[0]),
            datasets: [{ data: entries.map(e => e[1]), backgroundColor: 'oklch(0.55 0.19 25)', borderRadius: 4, maxBarThickness: 34 }],
        },
        options: {
            indexAxis: 'y', maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                datalabels: { anchor: 'end', align: 'right', color: 'oklch(0.5 0.03 258)', font: { size: 11, weight: '600' }, formatter: v => v > 0 ? v : '' },
            },
            scales: {
                x: { ticks: { color: 'oklch(0.5 0.03 258)', precision: 0 }, grid: { color: 'oklch(0.92 0.008 255)' } },
                y: { ticks: { color: 'oklch(0.5 0.03 258)' }, grid: { display: false } },
            },
        },
    });
}

async function ewLoadWatchlist() {
    ewWatchlistData = await ewFetch('watchlist') || [];
    ewRenderHighRiskTable(ewWatchlistData);
    ewRenderTable(ewWatchlistData);
    ewLoadReasonChart(ewWatchlistData);
    ewLoadStoreChart(ewWatchlistData);
}

async function ewLoadAll() {
    if (!ewYear || !ewMonths.length) return;
    await Promise.all([ewLoadSummary(), ewLoadWatchlist()]);
}

document.getElementById('ewSearch').addEventListener('input', () => ewRenderTable(ewWatchlistData));

(async function init() {
    const hasData = await ewLoadFilters();
    if (hasData) await ewLoadAll();
})();
</script>
