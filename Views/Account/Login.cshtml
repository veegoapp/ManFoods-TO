@model LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — Manfoods</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body class="login-body">
    <div class="login-container">
        <div class="login-card">
            <div class="login-brand">
                <div class="brand-icon-lg">M</div>
                <h1 class="login-title">Manfoods</h1>
                <p class="login-subtitle">Workforce Analytics Platform</p>
            </div>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-banner alert-error-banner mb-3">
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div><i class="bi bi-exclamation-triangle-fill me-1"></i>@err.ErrorMessage</div>
                        }
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="Email" class="form-label-dark">Email</label>
                    <input asp-for="Email" type="email" class="form-control form-control-dark" placeholder="admin@manfoods.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Password" class="form-label-dark">Password</label>
                    <input asp-for="Password" type="password" class="form-control form-control-dark" placeholder="••••••••" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 btn-lg">Sign In</button>
            </form>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
