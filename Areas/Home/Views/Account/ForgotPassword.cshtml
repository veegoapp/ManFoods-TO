@model MvcApp.Models.ViewModels.ForgotPasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Forgot Password — Manfoods McDonald's</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <script>document.documentElement.setAttribute('data-theme', localStorage.getItem('mf-theme') || 'light');</script>
    <style>
        .login-body { background: var(--bg); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        [data-theme="light"] .login-body { background: linear-gradient(135deg, #F5F3FF 0%, #FAF9FF 50%, #F3F1FF 100%); }
        .login-container { width: 100%; max-width: 440px; padding: 16px; }
        .login-card { background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 14px; padding: 40px 36px 32px; box-shadow: var(--shadow-lg); position: relative; overflow: hidden; }
        .login-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--red), var(--gold)); }
        .login-title { font-size: 22px; font-weight: 800; color: var(--text); margin: 0 0 4px; }
        .login-subtitle { font-size: 13px; color: var(--text-3); margin: 0 0 22px; }
        .fp-step { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
        .fp-step-num { width: 22px; height: 22px; border-radius: 50%; background: var(--gold); color: #1C1C27; font-size: 11px; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        [data-theme="light"] .fp-step-num { background: var(--red); color: #fff; }
        .fp-step-label { font-size: 11px; font-weight: 700; color: var(--text-2); text-transform: uppercase; letter-spacing: .6px; }
        .fp-field { margin: 8px 0 20px 30px; }
        .fp-field input { height: 46px; font-size: 15px; border-radius: 8px; border: 1.5px solid var(--card-border); background: var(--card-bg-2); color: var(--text); width: 100%; padding: 0 14px; outline: none; }
        .fp-field input:focus { background: var(--card-bg); border-color: var(--gold); }
        [data-theme="light"] .fp-field input:focus { border-color: var(--red); }
        .btn-signin { width: 100%; min-height: 48px; background: linear-gradient(135deg, var(--red) 0%, var(--red-dark) 100%); border: 1px solid var(--red-dark); border-radius: 48px; color: #fff; font-size: 15px; font-weight: 700; cursor: pointer; }
        .back-link { display: block; text-align: center; margin-top: 16px; font-size: 12px; color: var(--text-3); text-decoration: none; }
        .back-link:hover { color: var(--gold); }
        [data-theme="light"] .back-link:hover { color: var(--red); }
        .alert-error-banner { background: var(--danger-bg); border-left: 4px solid var(--red); color: #fca5a5; padding: 11px 16px; border-radius: 8px; font-size: 14px; margin-bottom: 16px; }
        [data-theme="light"] .alert-error-banner { color: var(--red); }
    </style>
</head>
<body class="login-body">
    <div class="login-container">
        <div class="login-card">
            <h1 class="login-title">Reset Your Password</h1>
            <p class="login-subtitle">Use the OTP your admin sent you to set a new password.</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-error-banner">
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div><i class="bi bi-exclamation-triangle-fill me-1"></i>@err.ErrorMessage</div>
                    }
                </div>
            }

            <form asp-area="Home" asp-controller="Account" asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()

                <div class="fp-step"><span class="fp-step-num">1</span><span class="fp-step-label">Phone or Email</span></div>
                <div class="fp-field">
                    <input asp-for="Identifier" placeholder="+20 1xx xxx xxxx or you@company.com"/>
                    <span asp-validation-for="Identifier" class="text-danger small"></span>
                </div>

                <div class="fp-step"><span class="fp-step-num">2</span><span class="fp-step-label">OTP Code</span></div>
                <div class="fp-field">
                    <input asp-for="OtpCode" placeholder="6-digit code" maxlength="6" style="letter-spacing:4px;text-align:center;font-weight:700"/>
                    <span asp-validation-for="OtpCode" class="text-danger small"></span>
                </div>

                <div class="fp-step"><span class="fp-step-num">3</span><span class="fp-step-label">New Password</span></div>
                <div class="fp-field">
                    <input asp-for="NewPassword" type="password" placeholder="New password" class="mb-2"/>
                    <span asp-validation-for="NewPassword" class="text-danger small d-block mb-2"></span>
                    <input asp-for="ConfirmPassword" type="password" placeholder="Confirm new password"/>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn-signin"><i class="bi bi-check-circle me-2"></i>Set New Password</button>
            </form>

            <a href="/home/account/login" class="back-link"><i class="bi bi-arrow-left me-1"></i>Back to Sign In</a>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
