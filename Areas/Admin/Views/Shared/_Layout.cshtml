@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpCtx
@{
    var session      = HttpCtx.HttpContext?.Session;
    var userEmail    = session?.GetString("Email") ?? "";
    var userRole     = session?.GetString("Role")  ?? "";
    var currentPath  = HttpCtx.HttpContext?.Request.Path.Value ?? "";
    bool IsActive(string seg) => currentPath.Contains(seg, StringComparison.OrdinalIgnoreCase);
    var initials     = string.IsNullOrEmpty(userEmail) ? "A" : userEmail.Substring(0,1).ToUpper();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — Admin | Manfoods" : "Admin | Manfoods McDonald's")</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/admin-theme.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <script>document.documentElement.setAttribute('data-theme', localStorage.getItem('mf-theme') || 'light');</script>
</head>
<body class="admin-theme" data-theme="light">
<script>document.body.setAttribute('data-theme', localStorage.getItem('mf-theme') || 'light');</script>

<div class="admin-shell">
    <!-- ══ SIDEBAR ════════════════════════════════════════ -->
    <aside class="admin-sidebar" id="adminSidebar">
        <a class="admin-sidebar-brand" href="/admin/dashboard/turnover" style="text-decoration:none">
            <div class="admin-sidebar-logo"><img src="/images/mclogo.png" alt="Manfoods"/></div>
            <div>
                <div class="admin-sidebar-brand-main">Manfoods</div>
                <div class="admin-sidebar-brand-sub">Admin Portal</div>
            </div>
        </a>

        <nav class="admin-sidebar-nav">
            <a href="/admin/dashboard/turnover" class="admin-nav-link @(IsActive("Turnover") ? "active" : "")">
                <i class="bi bi-pie-chart-fill"></i><span>Turnover</span>
            </a>
            <a href="/admin/dashboard/workforce" class="admin-nav-link @(IsActive("Workforce") ? "active" : "")">
                <i class="bi bi-people-fill"></i><span>Workforce</span>
            </a>
            <a href="/admin/dashboard/retention" class="admin-nav-link @(IsActive("Retention") ? "active" : "")">
                <i class="bi bi-graph-up-arrow"></i><span>Retention</span>
            </a>
            <a href="/admin/dashboard/exitinterviews" class="admin-nav-link @(IsActive("ExitInterviews") ? "active" : "")">
                <i class="bi bi-chat-square-text-fill"></i><span>Exit Interviews</span>
            </a>
            <a href="/admin/dashboard/ninetydayturnover" class="admin-nav-link @(IsActive("NinetyDayTurnover") ? "active" : "")">
                <i class="bi bi-hourglass-split"></i><span>90-Day Turnover</span>
            </a>
            <a href="/admin/dashboard/stores" class="admin-nav-link @(IsActive("Stores") || IsActive("StoreProfile") ? "active" : "")">
                <i class="bi bi-shop"></i><span>Stores</span>
            </a>
            <a href="/admin/dashboard/uploads" class="admin-nav-link @(IsActive("Uploads") ? "active" : "")">
                <i class="bi bi-cloud-upload-fill"></i><span>Data Management</span>
            </a>
            <a href="/admin/dashboard/reports" class="admin-nav-link @(IsActive("Reports") ? "active" : "")">
                <i class="bi bi-file-earmark-bar-graph-fill"></i><span>Reports</span>
            </a>
            <a href="/admin/dashboard/users" class="admin-nav-link @(IsActive("Users") ? "active" : "")">
                <i class="bi bi-person-badge-fill"></i><span>Users</span>
            </a>
        </nav>

        <div class="admin-sidebar-user">
            <div class="admin-sidebar-avatar">@initials</div>
            <div class="admin-sidebar-user-details">
                <div class="admin-sidebar-user-email">@userEmail</div>
                <div class="admin-sidebar-user-role">@userRole.Replace("_"," ")</div>
            </div>
            <button class="admin-sidebar-iconbtn theme-toggle" id="themeToggle" title="Toggle light/dark mode">
                <i class="bi bi-moon-stars-fill icon-dark"></i>
                <i class="bi bi-sun-fill icon-light"></i>
            </button>
            <a href="/admin/account/changepassword" class="admin-sidebar-iconbtn" title="Change Password">
                <i class="bi bi-key-fill"></i>
            </a>
            <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="admin-sidebar-iconbtn" title="Sign Out">
                    <i class="bi bi-box-arrow-right"></i>
                </button>
            </form>
        </div>
    </aside>

    <!-- ══ MAIN ═══════════════════════════════════════════ -->
    <div class="admin-main">
        <header class="admin-topbar">
            <button class="admin-hamburger" id="adminSidebarToggle" aria-label="Toggle menu">
                <i class="bi bi-list"></i>
            </button>
            <span class="admin-topbar-title">@(ViewData["Title"] ?? "Dashboard")</span>
            <span></span>
        </header>

        <main class="admin-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert-banner alert-success-banner">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert-banner alert-error-banner">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                </div>
            }
            <div class="page-content">
                @RenderBody()
            </div>
        </main>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
(function () {
    // Mobile sidebar toggle
    const toggle  = document.getElementById('adminSidebarToggle');
    const sidebar = document.getElementById('adminSidebar');
    if (toggle) {
        toggle.addEventListener('click', () => sidebar.classList.toggle('open'));
        document.addEventListener('click', (e) => {
            if (sidebar.classList.contains('open') && !sidebar.contains(e.target) && e.target !== toggle && !toggle.contains(e.target)) {
                sidebar.classList.remove('open');
            }
        });
    }

    // Theme toggle
    const themeBtn = document.getElementById('themeToggle');
    const body = document.body;
    const saved = localStorage.getItem('mf-theme') || 'light';
    body.setAttribute('data-theme', saved);
    if (themeBtn) {
        themeBtn.addEventListener('click', () => {
            const next = body.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            body.setAttribute('data-theme', next);
            localStorage.setItem('mf-theme', next);
        });
    }
})();
</script>
@await RenderSectionAsync("Scripts", required: false)

<!-- ═══════════════════════════════════════════════════
     AI CHAT WIDGET
═══════════════════════════════════════════════════ -->
<style>
    #ai-fab {
        position: fixed; bottom: 28px; right: 28px; z-index: 1050;
        width: 56px; height: 56px; border-radius: 50%;
        background: #7C5CFC;
        border: none; box-shadow: 0 4px 18px rgba(124,92,252,.5);
        cursor: pointer; display: flex; align-items: center; justify-content: center;
        transition: transform .2s, box-shadow .2s;
    }
    #ai-fab:hover { transform: scale(1.08); box-shadow: 0 6px 24px rgba(124,92,252,.6); }
    #ai-fab svg { width: 26px; height: 26px; fill: #1C1C27; }
    #ai-fab .ai-fab-badge {
        position: absolute; top: -2px; right: -2px;
        width: 14px; height: 14px; border-radius: 50%;
        background: #1C1C27; border: 2px solid #fff; display: none;
    }
    #ai-fab .ai-fab-badge.has-msg { display: block; }

    #ai-panel {
        position: fixed; bottom: 96px; right: 28px; z-index: 1049;
        width: 370px; height: 520px;
        background: #fff; border-radius: 8px;
        box-shadow: 0 8px 40px rgba(0,0,0,.18);
        display: none; flex-direction: column; overflow: hidden;
        border: 1px solid #e5e7eb;
        animation: aiSlideUp .22s ease;
    }
    #ai-panel.open { display: flex; }
    @@keyframes aiSlideUp {
        from { opacity: 0; transform: translateY(18px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .ai-header {
        background: #1C1C27;
        color: #fff; padding: 14px 16px;
        display: flex; align-items: center; gap: 10px;
        border-bottom: 3px solid #7C5CFC;
    }
    .ai-header-icon {
        width: 34px; height: 34px; background: rgba(124,92,252,.2);
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        font-size: 16px; flex-shrink: 0;
    }
    .ai-header-texts { flex: 1; }
    .ai-header-title { font-size: 14px; font-weight: 700; line-height: 1.2; }
    .ai-header-sub   { font-size: 11px; opacity: .65; }
    .ai-close-btn {
        background: none; border: none; color: #fff; opacity: .7;
        font-size: 20px; line-height: 1; cursor: pointer; padding: 0;
        transition: opacity .15s;
    }
    .ai-close-btn:hover { opacity: 1; }
    .ai-messages {
        flex: 1; overflow-y: auto; padding: 14px;
        display: flex; flex-direction: column; gap: 10px; background: #F5F4FF;
    }
    .ai-messages::-webkit-scrollbar { width: 4px; }
    .ai-messages::-webkit-scrollbar-thumb { background: #ddd; border-radius: 4px; }
    .ai-bubble {
        max-width: 88%; padding: 10px 13px; border-radius: 12px;
        font-size: 13.5px; line-height: 1.55; word-break: break-word;
    }
    .ai-bubble.bot {
        background: #fff; border: 1px solid #e5e7eb;
        border-bottom-left-radius: 4px; align-self: flex-start; color: #292929;
    }
    .ai-bubble.user {
        background: #7C5CFC;
        color: #1C1C27; border-bottom-right-radius: 4px; align-self: flex-end;
        font-weight: 600;
    }
    .ai-bubble.loading { background: #fff; border: 1px solid #e5e7eb; align-self: flex-start; }
    .ai-dots span {
        display: inline-block; width: 7px; height: 7px;
        background: #bbb; border-radius: 50%; margin: 0 2px;
        animation: aiDot 1.2s infinite;
    }
    .ai-dots span:nth-child(2) { animation-delay: .2s; }
    .ai-dots span:nth-child(3) { animation-delay: .4s; }
    @@keyframes aiDot {
        0%,80%,100% { transform: scale(.7); opacity:.5; }
        40%          { transform: scale(1);  opacity:1; }
    }
    .ai-footer {
        padding: 10px 12px; border-top: 1px solid #e5e7eb;
        background: #fff; display: flex; gap: 8px; align-items: flex-end;
    }
    #ai-input {
        flex: 1; border: 1px solid #e5e7eb; border-radius: 8px;
        padding: 9px 12px; font-size: 13.5px; resize: none;
        outline: none; max-height: 90px; line-height: 1.4;
        font-family: inherit; transition: border-color .2s;
    }
    #ai-input:focus { border-color: #7C5CFC; box-shadow: 0 0 0 2px rgba(124,92,252,.2); }
    #ai-send-btn {
        width: 38px; height: 38px; border-radius: 8px; border: none; flex-shrink: 0;
        background: #7C5CFC;
        color: #1C1C27; cursor: pointer; display: flex;
        align-items: center; justify-content: center;
        transition: opacity .2s, background .15s; font-size: 15px;
    }
    #ai-send-btn:hover { background: #5B3FE0; }
    #ai-send-btn:disabled { opacity: .45; cursor: default; }
</style>

<button id="ai-fab" title="AI Assistant">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.38-1 1.73V7h2a7 7 0 0 1 7 7v1a7 7 0 0 1-7 7H9a7 7 0 0 1-7-7v-1a7 7 0 0 1 7-7h2V5.73A2 2 0 0 1 10 4a2 2 0 0 1 2-2zm-3 9a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zm6 0a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3z"/>
    </svg>
    <span class="ai-fab-badge" id="ai-badge"></span>
</button>

<div id="ai-panel">
    <div class="ai-header">
        <div class="ai-header-icon">🤖</div>
        <div class="ai-header-texts">
            <div class="ai-header-title">Manfoods AI Assistant</div>
            <div class="ai-header-sub">مساعد تحليل بيانات الموظفين</div>
        </div>
        <button class="ai-close-btn" id="ai-close-btn" title="إغلاق">×</button>
    </div>
    <div class="ai-messages" id="ai-messages">
        <div class="ai-bubble bot">
            مرحبًا! 👋 أنا مساعدك الذكي لتحليل بيانات الموظفين.<br><br>
            يمكنني مساعدتك في تحليل معدلات الـ Turnover، الـ Headcount، الاستقالات، وتقديم توصيات. اسألني ما تريد!
        </div>
    </div>
    <div class="ai-footer">
        <textarea id="ai-input" rows="1" placeholder="اكتب سؤالك هنا..."></textarea>
        <button id="ai-send-btn" title="إرسال"><i class="bi bi-send-fill"></i></button>
    </div>
</div>

<script>
(function () {
    const fab      = document.getElementById('ai-fab');
    const panel    = document.getElementById('ai-panel');
    const closeBtn = document.getElementById('ai-close-btn');
    const messages = document.getElementById('ai-messages');
    const input    = document.getElementById('ai-input');
    const sendBtn  = document.getElementById('ai-send-btn');
    const badge    = document.getElementById('ai-badge');

    let isOpen = false;

    fab.addEventListener('click', () => {
        isOpen = !isOpen;
        panel.classList.toggle('open', isOpen);
        if (isOpen) { badge.classList.remove('has-msg'); input.focus(); scrollBottom(); }
    });
    closeBtn.addEventListener('click', () => { isOpen = false; panel.classList.remove('open'); });
    input.addEventListener('keydown', e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); } });
    input.addEventListener('input', () => { input.style.height = 'auto'; input.style.height = Math.min(input.scrollHeight, 90) + 'px'; });
    sendBtn.addEventListener('click', sendMessage);

    function scrollBottom() { setTimeout(() => { messages.scrollTop = messages.scrollHeight; }, 50); }

    function addBubble(text, type) {
        const d = document.createElement('div');
        d.className = 'ai-bubble ' + type;
        if (type === 'loading') {
            d.innerHTML = '<div class="ai-dots"><span></span><span></span><span></span></div>';
        } else {
            d.innerHTML = text.replace(/\n/g, '<br>');
        }
        messages.appendChild(d);
        scrollBottom();
        return d;
    }

    function getPageContext() {
        const params = new URLSearchParams(window.location.search);
        return {
            month: params.get('month') ? parseInt(params.get('month')) : null,
            year:  params.get('year')  ? parseInt(params.get('year'))  : null,
            store: params.get('store') || null
        };
    }

    async function sendMessage() {
        const q = input.value.trim();
        if (!q || sendBtn.disabled) return;
        addBubble(q, 'user');
        input.value = ''; input.style.height = 'auto';
        sendBtn.disabled = true;
        const loading = addBubble('', 'loading');
        const ctx = getPageContext();
        try {
            const res = await fetch('/api/dashboard/ai-chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ question: q, month: ctx.month, year: ctx.year, store: ctx.store })
            });
            const data = await res.json();
            loading.remove();
            addBubble(data.answer || 'لم يتم الحصول على إجابة.', 'bot');
        } catch {
            loading.remove();
            addBubble('تعذر الاتصال بالخادم. حاول مرة أخرى.', 'bot');
        }
        sendBtn.disabled = false; input.focus();
        if (!isOpen) badge.classList.add('has-msg');
    }
})();
</script>
</body>
</html>
