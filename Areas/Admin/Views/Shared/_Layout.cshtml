@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpCtx
@inject Microsoft.Extensions.Localization.IStringLocalizer<MvcApp.Resources.SharedResource> L
@{
    var session      = HttpCtx.HttpContext?.Session;
    var userEmail    = session?.GetString("Email") ?? "";
    var userRole     = session?.GetString("Role")  ?? "";
    var currentPath  = HttpCtx.HttpContext?.Request.Path.Value ?? "";
    bool IsActive(string seg) => currentPath.Contains(seg, StringComparison.OrdinalIgnoreCase);
    var initials     = string.IsNullOrEmpty(userEmail) ? "A" : userEmail.Substring(0,1).ToUpper();
    var currentLang  = HttpCtx.HttpContext?.Request.Cookies["mf-lang"] ?? "en";
    var isRtl        = currentLang == "ar";
    var returnUrl    = HttpCtx.HttpContext?.Request.Path.Value ?? "/";
    var switchLang   = isRtl ? "en" : "ar";
}
<!DOCTYPE html>
<html lang="@currentLang" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — Manfoods" : "Manfoods McDonald's")</title>
    <link rel="icon" type="image/png" href="~/images/mclogo.png"/>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/admin-theme.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <script>document.documentElement.setAttribute('data-theme', localStorage.getItem('mf-theme') || 'light');</script>
</head>
<body class="admin-theme" data-theme="light">
<script>document.body.setAttribute('data-theme', localStorage.getItem('mf-theme') || 'light');</script>

<div class="admin-shell">
    <!-- ══ SIDEBAR ════════════════════════════════════════ -->
    <aside class="admin-sidebar" id="adminSidebar">
        <a class="admin-sidebar-brand" href="/admin/dashboard/turnover" style="text-decoration:none">
            <div class="admin-sidebar-logo"><img src="/images/mclogo.png" alt="Manfoods"/></div>
            <div>
                <div class="admin-sidebar-brand-main">Manfoods</div>
                <div class="admin-sidebar-brand-sub">@(userRole == "Admin" ? L["Layout_AdminPortal"] : L["Layout_EmployeePortal"])</div>
            </div>
        </a>

        <nav class="admin-sidebar-nav">
            <a href="/admin/dashboard/turnover" class="admin-nav-link @(IsActive("Turnover") ? "active" : "")">
                <i class="bi bi-pie-chart-fill"></i><span>@L["Nav_Turnover"]</span>
            </a>
            <a href="/admin/dashboard/workforce" class="admin-nav-link @(IsActive("Workforce") ? "active" : "")">
                <i class="bi bi-people-fill"></i><span>@L["Nav_Workforce"]</span>
            </a>
            <a href="/admin/dashboard/retention" class="admin-nav-link @(IsActive("Retention") ? "active" : "")">
                <i class="bi bi-graph-up-arrow"></i><span>@L["Nav_Retention"]</span>
            </a>
            <a href="/admin/dashboard/exitinterviews" class="admin-nav-link @(IsActive("ExitInterviews") ? "active" : "")">
                <i class="bi bi-chat-square-text-fill"></i><span>@L["Nav_ExitInterviews"]</span>
            </a>
            <a href="/admin/dashboard/ninetydayturnover" class="admin-nav-link @(IsActive("NinetyDayTurnover") ? "active" : "")">
                <i class="bi bi-hourglass-split"></i><span>@L["Nav_NinetyDay"]</span>
            </a>
            <a href="/admin/dashboard/aiassistant" class="admin-nav-link @(IsActive("AiAssistant") ? "active" : "")">
                <i class="bi bi-stars"></i><span>@L["Nav_AiAssistant"]</span>
            </a>
            @if (userRole == "Admin")
            {
                <a href="/admin/dashboard/aiusage" class="admin-nav-link @(IsActive("AiUsage") ? "active" : "")">
                    <i class="bi bi-cpu-fill"></i><span>@L["Nav_AiUsage"]</span>
                </a>
            }
            <a href="/admin/dashboard/earlywarning" class="admin-nav-link @(IsActive("EarlyWarning") ? "active" : "")">
                <i class="bi bi-exclamation-diamond-fill"></i><span>@L["Nav_EarlyWarning"]</span>
            </a>
            <a href="/admin/dashboard/scorecard" class="admin-nav-link @(IsActive("Scorecard") ? "active" : "")">
                <i class="bi bi-award-fill"></i><span>@L["Nav_Scorecard"]</span>
            </a>
            <a href="/admin/dashboard/stores" class="admin-nav-link @(IsActive("Stores") || IsActive("StoreProfile") ? "active" : "")">
                <i class="bi bi-shop"></i><span>@L["Nav_Stores"]</span>
            </a>
            @if (userRole == "Admin")
            {
                <a href="/admin/dashboard/uploads" class="admin-nav-link @(IsActive("Uploads") ? "active" : "")">
                    <i class="bi bi-cloud-upload-fill"></i><span>@L["Nav_DataManagement"]</span>
                </a>
            }
            <a href="/admin/dashboard/reports" class="admin-nav-link @(IsActive("Reports") ? "active" : "")">
                <i class="bi bi-file-earmark-bar-graph-fill"></i><span>@L["Nav_Reports"]</span>
            </a>
            @if (userRole == "Admin")
            {
                <a href="/admin/dashboard/users" class="admin-nav-link @(IsActive("Users") ? "active" : "")">
                    <i class="bi bi-person-badge-fill"></i><span>@L["Nav_Users"]</span>
                </a>
            }
            <a href="/admin/dashboard/targets" class="admin-nav-link @(IsActive("Targets") ? "active" : "")">
                <i class="bi bi-bullseye"></i><span>@L["Nav_Targets"]</span>
            </a>
        </nav>

        <div class="admin-sidebar-user">
            <div class="admin-sidebar-avatar">@initials</div>
            <div class="admin-sidebar-user-details">
                <div class="admin-sidebar-user-email">@userEmail</div>
                <div class="admin-sidebar-user-role">@userRole.Replace("_"," ")</div>
            </div>
            <button class="admin-sidebar-iconbtn theme-toggle" id="themeToggle" title="@L["Layout_DarkMode"] / @L["Layout_LightMode"]">
                <i class="bi bi-moon-stars-fill icon-dark"></i>
                <i class="bi bi-sun-fill icon-light"></i>
            </button>
            <a href="@(userRole == "Admin" ? "/admin/account/changepassword" : "/home/account/changepassword")" class="admin-sidebar-iconbtn" title="@L["Layout_ChangePassword"]">
                <i class="bi bi-key-fill"></i>
            </a>
            <form asp-area="@(userRole == "Admin" ? "Admin" : "Home")" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="admin-sidebar-iconbtn" title="@L["Layout_SignOut"]">
                    <i class="bi bi-box-arrow-right"></i>
                </button>
            </form>
            <form action="/language/set" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="lang" value="@switchLang"/>
                <input type="hidden" name="returnUrl" value="@returnUrl"/>
                <button type="submit" class="admin-sidebar-iconbtn" title="@L["Layout_SwitchLang"]" style="font-size:11px;font-weight:700;letter-spacing:.5px">
                    @L["Layout_SwitchLang"]
                </button>
            </form>
        </div>
    </aside>

    <!-- ══ MAIN ═══════════════════════════════════════════ -->
    <div class="admin-main">
        <header class="admin-topbar">
            <button class="admin-hamburger" id="adminSidebarToggle" aria-label="Toggle menu">
                <i class="bi bi-list"></i>
            </button>
            <span class="admin-topbar-title">@(ViewData["Title"] ?? "Dashboard")</span>
            <span></span>
        </header>

        <main class="admin-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert-banner alert-success-banner">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert-banner alert-error-banner">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                </div>
            }
            <div class="page-content">
                @RenderBody()
            </div>
        </main>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
(function () {
    // Mobile sidebar toggle
    const toggle  = document.getElementById('adminSidebarToggle');
    const sidebar = document.getElementById('adminSidebar');
    if (toggle) {
        toggle.addEventListener('click', () => sidebar.classList.toggle('open'));
        document.addEventListener('click', (e) => {
            if (sidebar.classList.contains('open') && !sidebar.contains(e.target) && e.target !== toggle && !toggle.contains(e.target)) {
                sidebar.classList.remove('open');
            }
        });
    }

    // Theme toggle
    const themeBtn = document.getElementById('themeToggle');
    const body = document.body;
    const saved = localStorage.getItem('mf-theme') || 'light';
    body.setAttribute('data-theme', saved);
    if (themeBtn) {
        themeBtn.addEventListener('click', () => {
            const next = body.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            body.setAttribute('data-theme', next);
            localStorage.setItem('mf-theme', next);
        });
    }
})();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
