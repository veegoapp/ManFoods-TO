@{
    ViewData["Title"] = L["Page_Turnover"].Value;
}

<style>
/* ── Turnover filter bar ─────────────────────────────────── */
.tv-filterbar { display:flex; flex-wrap:wrap; gap:14px; align-items:flex-end; }
.tv-filter-group { display:flex; flex-direction:column; gap:5px; }
.tv-filter-label { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:var(--text-3); }

.tv-select-wrap { position:relative; }
.tv-select {
    appearance:none; -webkit-appearance:none;
    background:var(--card-bg); border:1px solid var(--card-border); color:var(--text);
    border-radius:var(--radius-sm); font-size:13.5px; font-weight:600;
    height:42px; padding:0 34px 0 14px; min-width:110px;
    box-shadow:var(--shadow-sm); cursor:pointer; transition:border-color .15s, box-shadow .15s;
}
.tv-select:focus { outline:none; border-color:var(--red); box-shadow:0 0 0 3px var(--red-light); }
.tv-select-wrap i { position:absolute; top:50%; right:12px; transform:translateY(-50%); font-size:11px; color:var(--text-3); pointer-events:none; }
[dir="rtl"] .tv-select { padding:0 14px 0 34px; }
[dir="rtl"] .tv-select-wrap i { right:auto; left:12px; }

/* Months multi-select */
.tv-multiselect { position:relative; }
.tv-multiselect-trigger {
    display:flex; align-items:center; gap:10px; justify-content:space-between;
    background:var(--card-bg); border:1px solid var(--card-border); color:var(--text);
    border-radius:var(--radius-sm); font-size:13.5px; font-weight:600;
    height:42px; padding:0 12px 0 14px; min-width:190px;
    box-shadow:var(--shadow-sm); cursor:pointer; transition:border-color .15s, box-shadow .15s;
}
.tv-multiselect-trigger:hover { border-color:var(--card-border-h); }
.tv-multiselect-trigger i { font-size:11px; color:var(--text-3); flex-shrink:0; }
.tv-multiselect-chips { white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.tv-multiselect-panel {
    display:none; position:absolute; top:calc(100% + 6px); left:0; z-index:50;
    background:var(--card-bg); border:1px solid var(--card-border); border-radius:var(--radius-sm);
    box-shadow:var(--shadow-lg); min-width:230px; padding:8px; max-height:280px; overflow-y:auto;
}
.tv-multiselect-panel.open { display:block; }
[dir="rtl"] .tv-multiselect-panel { left:auto; right:0; }
.tv-multiselect-actions { display:flex; gap:6px; padding:2px 4px 8px; border-bottom:1px solid var(--card-border); margin-bottom:6px; }
.tv-ms-action {
    flex:1; background:var(--card-bg-2); border:1px solid var(--card-border); color:var(--red);
    border-radius:6px; font-size:11.5px; font-weight:700; padding:6px 8px; cursor:pointer; transition:background .15s;
}
.tv-ms-action:hover { background:var(--red-light); }
.tv-ms-option {
    display:flex; align-items:center; gap:9px; padding:7px 8px; border-radius:6px; cursor:pointer;
    font-size:13px; color:var(--text-2); transition:background .12s;
}
.tv-ms-option:hover { background:var(--card-bg-2); }
.tv-ms-option input { accent-color:var(--red); width:15px; height:15px; cursor:pointer; }

/* Searchable single-select combobox (Store / OM / OC) */
.tv-combobox { position:relative; }
.tv-combobox-input {
    background:var(--card-bg); border:1px solid var(--card-border); color:var(--text);
    border-radius:var(--radius-sm); font-size:13.5px; font-weight:500;
    height:42px; padding:0 14px; min-width:190px; width:100%;
    box-shadow:var(--shadow-sm); transition:border-color .15s, box-shadow .15s;
}
.tv-combobox-input:focus { outline:none; border-color:var(--red); box-shadow:0 0 0 3px var(--red-light); }
.tv-combobox-panel {
    display:none; position:absolute; top:calc(100% + 6px); left:0; right:0; z-index:50;
    background:var(--card-bg); border:1px solid var(--card-border); border-radius:var(--radius-sm);
    box-shadow:var(--shadow-lg); max-height:260px; overflow-y:auto; padding:6px;
}
.tv-combobox-panel.open { display:block; }
.tv-combo-option { padding:8px 10px; border-radius:6px; font-size:13px; color:var(--text-2); cursor:pointer; }
.tv-combo-option:hover { background:var(--card-bg-2); }
.tv-combo-option.active { color:var(--red); font-weight:700; background:var(--red-light); }
.tv-combo-empty { padding:10px; font-size:12.5px; color:var(--text-3); text-align:center; }

/* Mini "top driver" callout inside a chart card header */
.tv-stat-callout { font-size:12.5px; color:var(--text-2); margin-top:4px; }
.tv-stat-callout .tv-stat-highlight { color:var(--red); font-weight:700; }

/* Gender chart: doughnut + side breakdown list */
.tv-gender-body { display:flex; align-items:center; gap:18px; height:220px; }
.tv-gender-canvas-wrap { flex:0 0 44%; height:100%; position:relative; }
.tv-gender-list { flex:1; display:flex; flex-direction:column; gap:10px; }
.tv-gender-row { display:flex; align-items:center; gap:9px; font-size:13px; color:var(--text-2); }
.tv-gender-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
.tv-gender-label { flex:1; }
.tv-gender-value { font-weight:700; color:var(--text); }
.tv-gender-pct { font-weight:500; color:var(--text-3); }

@@media (max-width: 640px) {
    .tv-gender-body { flex-direction:column; height:auto; }
    .tv-gender-canvas-wrap { flex:0 0 auto; width:100%; height:180px; }
}
</style>

<div class="page-header">
    <div>
        <h1 class="page-title">@L["Page_Turnover"]</h1>
        <p class="page-subtitle">@L["Page_TurnoverSub"]</p>
    </div>
    <div class="tv-filterbar">
        <div class="tv-filter-group">
            <span class="tv-filter-label">@L["Common_Year"]</span>
            <div class="tv-select-wrap">
                <select id="tvYearSelect" class="tv-select"></select>
                <i class="bi bi-chevron-down"></i>
            </div>
        </div>

        <div class="tv-filter-group">
            <span class="tv-filter-label">@L["Common_SelectMonths"]</span>
            <div class="tv-multiselect" id="tvMonthsMultiselect" data-label-select="@L["Common_SelectMonths"]" data-label-all="@L["Common_AllMonths"]">
