@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="~/js/dashboard.js" asp-append-version="true"></script>
<script>
/* ── Turnover Analytics — filters (Year + discrete Months multi-select
   + searchable single-select combos for Store/OM/OC) ─────────────────
   dashboard.js's own #periodSelect/#fromPeriodSelect/#storeSelect/#omSelect/
   #ocSelect wiring no-ops here (those elements don't exist on this page),
   so this page owns buildQuery()/loadAll() end-to-end. storeFilter/omFilter/
   ocFilter globals are declared by dashboard.js and reused as-is. */
let tvYear = null;
let tvMonths = [];
let tvYearMonthsMap = {};

function tvMonthShortName(m) {
    return new Date(2000, m - 1, 1).toLocaleString('default', { month: 'short' });
}

/* Overrides dashboard.js's buildQuery(): discrete year+months instead of a
   continuous from/to range. "month" is also sent (= latest selected month)
   so endpoints that only understand a single period (e.g. gender-breakdown)
   still get a sensible value. */
function buildQuery() {
    const p = new URLSearchParams();
    if (tvYear) p.set('year', tvYear);
    if (tvMonths.length) {
        p.set('months', tvMonths.join(','));
        p.set('month', Math.max(...tvMonths));
    }
    if (storeFilter) p.set('store', storeFilter);
    if (omFilter)    p.set('om', omFilter);
    if (ocFilter)    p.set('oc', ocFilter);
    return p.toString();
}

function tvAnchorMonth() { return tvMonths.length ? Math.max(...tvMonths) : null; }

/* ── Generic searchable single-select combobox (Store / OM / OC) ────── */
function tvCreateCombobox({ inputId, panelId, onSelect }) {
    const input = document.getElementById(inputId);
    const panel = document.getElementById(panelId);
    const allLabel = input.placeholder;
    let options = [];
    let value = '';

    function render(filterText) {
        const ft = (filterText || '').toLowerCase();
        const filtered = options.filter(o => o.toLowerCase().includes(ft));
        let html = `<div class="tv-combo-option${value === '' ? ' active' : ''}" data-value="">${allLabel}</div>`;
        html += filtered.map(o => `<div class="tv-combo-option${o === value ? ' active' : ''}" data-value="${o.replace(/"/g, '&quot;')}">${o}</div>`).join('');
        panel.innerHTML = html;
    }

    function open() { panel.classList.add('open'); render(''); input.select(); }
    function close() { panel.classList.remove('open'); input.value = value; }

    panel.addEventListener('mousedown', (e) => {
        const opt = e.target.closest('.tv-combo-option');
        if (!opt) return;
        e.preventDefault();
        value = opt.dataset.value;
        input.value = value;
        panel.classList.remove('open');
        onSelect(value);
    });
    input.addEventListener('focus', open);
    input.addEventListener('input', () => render(input.value));
    input.addEventListener('blur', () => setTimeout(close, 150));

    return {
        setOptions(list) { options = list || []; },
        setValue(v) { value = v || ''; input.value = value; }
    };
}

const tvStoreCombo = tvCreateCombobox({ inputId: 'tvStoreInput', panelId: 'tvStorePanel', onSelect: v => { storeFilter = v; loadAll(); } });
const tvOmCombo    = tvCreateCombobox({ inputId: 'tvOmInput',    panelId: 'tvOmPanel',    onSelect: v => { omFilter    = v; loadAll(); } });
const tvOcCombo    = tvCreateCombobox({ inputId: 'tvOcInput',    panelId: 'tvOcPanel',    onSelect: v => { ocFilter    = v; loadAll(); } });

/* ── Months multi-select ─────────────────────────────────────────── */
function tvBuildMonthsOptions() {
    const container = document.getElementById('tvMonthsOptions');
    const available = (tvYearMonthsMap[tvYear] || []).slice().sort((a, b) => a - b);
    container.innerHTML = available.map(m => `
        <label class="tv-ms-option">
            <input type="checkbox" value="${m}" ${tvMonths.includes(m) ? 'checked' : ''}>
            <span>${monthName(m, tvYear)}</span>
        </label>`).join('');
    container.querySelectorAll('input[type=checkbox]').forEach(cb => {
        cb.addEventListener('change', () => {
            const m = parseInt(cb.value);
            if (cb.checked) { if (!tvMonths.includes(m)) tvMonths.push(m); }
            else { tvMonths = tvMonths.filter(x => x !== m); }
            tvMonths.sort((a, b) => a - b);
            tvRenderMonthsChips();
            tvOnMonthsChanged();
        });
    });
}

function tvRenderMonthsChips() {
    const chipsEl = document.getElementById('tvMonthsChips');
    const available = tvYearMonthsMap[tvYear] || [];
    const labels = document.getElementById('tvMonthsMultiselect').dataset;
    if (!tvMonths.length) { chipsEl.textContent = labels.labelSelect; return; }
    if (tvMonths.length === available.length) { chipsEl.textContent = labels.labelAll; return; }
    const names = tvMonths.map(tvMonthShortName);
    chipsEl.textContent = names.length <= 2 ? names.join('، ') : `${names[0]}، ${names[1]} +${names.length - 2}`;
}

let tvMonthsDebounce;
function tvOnMonthsChanged() {
    clearTimeout(tvMonthsDebounce);
    tvMonthsDebounce = setTimeout(async () => {
        if (!tvMonths.length) return;
        await tvLoadDependentLists();
        await loadAll();
    }, 250);
}

document.getElementById('tvMonthsSelectAll').addEventListener('click', () => {
    tvMonths = (tvYearMonthsMap[tvYear] || []).slice().sort((a, b) => a - b);
    tvBuildMonthsOptions(); tvRenderMonthsChips(); tvOnMonthsChanged();
});
document.getElementById('tvMonthsClearAll').addEventListener('click', () => {
    tvMonths = [];
    tvBuildMonthsOptions(); tvRenderMonthsChips(); tvOnMonthsChanged();
});
document.getElementById('tvMonthsTrigger').addEventListener('click', (e) => {
    e.stopPropagation();
    document.getElementById('tvMonthsPanel').classList.toggle('open');
});
document.addEventListener('click', (e) => {
    if (!document.getElementById('tvMonthsMultiselect').contains(e.target))
        document.getElementById('tvMonthsPanel').classList.remove('open');
});

/* ── Year select ──────────────────────────────────────────────────── */
document.getElementById('tvYearSelect').addEventListener('change', async function () {
    tvYear = parseInt(this.value);
    tvMonths = (tvYearMonthsMap[tvYear] || []).slice().sort((a, b) => a - b);
    storeFilter = ''; omFilter = ''; ocFilter = '';
    tvStoreCombo.setValue(''); tvOmCombo.setValue(''); tvOcCombo.setValue('');
    tvBuildMonthsOptions();
    tvRenderMonthsChips();
    await tvLoadDependentLists();
    await loadAll();
});

/* ── Store / OM / OC option lists (scoped to the latest selected month) ── */
async function tvLoadDependentLists() {
    const anchor = tvAnchorMonth();
    if (!anchor || !tvYear) return;
    const [stores, oms, ocs] = await Promise.all([
        fetchJson(`/api/dashboard/stores?month=${anchor}&year=${tvYear}`),
        fetchJson(`/api/dashboard/operation-managers?month=${anchor}&year=${tvYear}`),
        fetchJson(`/api/dashboard/operation-consultants?month=${anchor}&year=${tvYear}`)
    ]);
    tvStoreCombo.setOptions(stores.map(s => s.storeName));
    tvOmCombo.setOptions(oms);
    tvOcCombo.setOptions(ocs);
}

/* ── Initial load ─────────────────────────────────────────────────── */
async function tvInitFilters() {
    const periods = await fetchJson('/api/dashboard/available-periods');
    if (!periods.length) return;

    tvYearMonthsMap = {};
    periods.forEach(p => { (tvYearMonthsMap[p.year] = tvYearMonthsMap[p.year] || []).push(p.month); });

    const years = Object.keys(tvYearMonthsMap).map(Number).sort((a, b) => b - a);
    const yearSel = document.getElementById('tvYearSelect');
    yearSel.innerHTML = years.map(y => `<option value="${y}">${y}</option>`).join('');
    tvYear = years[0];
    yearSel.value = tvYear;

    tvMonths = (tvYearMonthsMap[tvYear] || []).slice().sort((a, b) => a - b);
    tvBuildMonthsOptions();
    tvRenderMonthsChips();

    await tvLoadDependentLists();
    await loadAll();
}

/* ── Extra sections (Smart Insights, Store Comparison, OC/OM, Payroll chart) ── */
let tvStoreData = [], tvSortCol = 'turnoverRate', tvSortAsc = false;

function tvRateColor(rate) {
    if (rate >= 15) return { bg: 'oklch(0.6 0.22 22)', fg: '#fff' };
    if (rate >= 8)  return { bg: 'oklch(0.68 0.18 55)', fg: '#fff' };
    if (rate >= 4)  return { bg: 'oklch(0.75 0.16 75)', fg: '#1C1C27' };
    return { bg: 'oklch(0.62 0.15 155)', fg: '#fff' };
}

/* Store Comparison ----------------------------------------- */
function tvRenderStoreTable() {
    const search = (document.getElementById('storeSearch').value || '').toLowerCase();
    let rows = tvStoreData.filter(r =>
        r.storeName.toLowerCase().includes(search) ||
        (r.operationConsultant || '').toLowerCase().includes(search) ||
        (r.operationManager    || '').toLowerCase().includes(search)
    );
    rows.sort((a, b) => {
        const va = a[tvSortCol], vb = b[tvSortCol];
        if (typeof va === 'string') return tvSortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
        return tvSortAsc ? va - vb : vb - va;
    });

    const badge = document.getElementById('storeCountBadge');
    if (badge) badge.textContent = rows.length + ' stores';

    const tbody = document.getElementById('storeTableBody');
    if (!rows.length) {
        tbody.innerHTML = '<tr><td colspan="7" class="text-center py-4 text-muted">No matching stores.</td></tr>';
        return;
    }
    tbody.innerHTML = rows.map(r => {
        const c = tvRateColor(r.turnoverRate);
        const rateBadge = `<span style="background:${c.bg};color:${c.fg};padding:3px 10px;border-radius:12px;font-size:11.5px;font-weight:700">${r.turnoverRate.toFixed(1)}%</span>`;
        return `<tr>
            <td class="px-3 py-2 fw-semibold"><a href="/admin/dashboard/storeprofile?store=${encodeURIComponent(r.storeName)}" style="color:inherit;text-decoration:none" onmouseover="this.style.color='oklch(0.5 0.18 25)'" onmouseout="this.style.color='inherit'">${r.storeName}</a></td>
            <td class="px-3 py-2" style="color:oklch(0.5 0.03 258)">${r.operationConsultant || '<span class="text-muted">—</span>'}</td>
            <td class="px-3 py-2" style="color:oklch(0.5 0.03 258)">${r.operationManager    || '<span class="text-muted">—</span>'}</td>
            <td class="px-3 py-2 text-center">${r.headcount}</td>
            <td class="px-3 py-2 text-center" style="color:oklch(0.62 0.15 155);font-weight:600">+${r.newHires}</td>
            <td class="px-3 py-2 text-center" style="color:oklch(0.6 0.22 22);font-weight:600">${r.resignations}</td>
            <td class="px-3 py-2 text-center">${rateBadge}</td>
        </tr>`;
    }).join('');
}

async function tvLoadStoreComparison() {
    if (!tvYear || !tvMonths.length) return;
    const data = await fetchJson(`/api/dashboard/store-comparison?${buildQuery()}`);
    tvStoreData = data || [];
    tvRenderStoreTable();
}

/* OC / OM Analysis ----------------------------------------- */
function tvRenderOcOmTable(tbodyId, rows) {
    const tbody = document.getElementById(tbodyId);
    if (!rows || !rows.length) {
        tbody.innerHTML = '<tr><td colspan="5" class="text-center py-3 text-muted">No data for this period.</td></tr>';
        return;
    }
    tbody.innerHTML = rows.map((r, i) => {
