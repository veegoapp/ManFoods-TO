/* ── Full Data Trend Matrix (unaffected by the Months multi-select —
   always spans from the selected Year to the latest uploaded period) ── */
let mxData = null;
let mxSortCol  = 'avg';
let mxSortAsc  = false;

function fmtPeriod(pk) {
    const [y, m] = pk.split('-');
    return new Date(+y, +m - 1, 1).toLocaleString('default', { month: 'short', year: '2-digit' });
}

function mxRateCell(rate) {
    if (rate === null || rate === undefined)
        return `<td class="px-2 py-2 text-center text-muted" style="color:#ccc">—</td>`;
    const bg = rate >= 15 ? 'oklch(0.6 0.22 22)'
             : rate >= 8  ? 'oklch(0.68 0.18 55)'
             : rate >= 4  ? 'oklch(0.75 0.16 75)'
             : 'oklch(0.62 0.15 155)';
    const fg = rate >= 4 ? (rate >= 8 ? '#fff' : '#1C1C27') : '#fff';
    return `<td class="px-2 py-2 text-center">
        <span style="background:${bg};color:${fg};padding:2px 8px;border-radius:10px;font-size:11px;font-weight:700;white-space:nowrap">${rate.toFixed(1)}%</span>
    </td>`;
}

function mxBuildHeader(periods) {
    const tr = document.querySelector('#matrixHead tr');
    const avgTh = tr.querySelector('[data-mcol="avg"]');
    tr.querySelectorAll('[data-mcol^="p-"]').forEach(el => el.remove());

    periods.forEach(pk => {
        const th = document.createElement('th');
        th.className = 'px-2 py-2 text-center';
        th.style.cssText = 'min-width:72px;cursor:pointer;white-space:nowrap';
        th.dataset.mcol = `p-${pk}`;
        th.innerHTML = `${fmtPeriod(pk)} <i id="mxi-${pk}" class="bi bi-arrow-down-up text-muted" style="font-size:10px"></i>`;
        th.onclick = () => mxSort(`p-${pk}`);
        tr.insertBefore(th, avgTh);
    });
}

function mxRender() {
    if (!mxData) return;
    const search = (document.getElementById('matrixSearch').value || '').toLowerCase();

    let rows = mxData.rows.filter(r =>
        r.storeName.toLowerCase().includes(search) ||
        (r.operationConsultant || '').toLowerCase().includes(search)
    );

    rows.sort((a, b) => {
        let va, vb;
        if (mxSortCol === 'store') { va = a.storeName; vb = b.storeName; }
        else if (mxSortCol === 'oc') { va = a.operationConsultant || ''; vb = b.operationConsultant || ''; }
        else if (mxSortCol === 'avg') { va = a.avgRate ?? -1; vb = b.avgRate ?? -1; }
        else {
            va = a.periodRates[mxSortCol.replace('p-', '')] ?? -1;
            vb = b.periodRates[mxSortCol.replace('p-', '')] ?? -1;
        }
        if (typeof va === 'string') return mxSortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
        return mxSortAsc ? va - vb : vb - va;
    });

    const colSpan = 2 + mxData.periods.length + 1;
    if (!rows.length) {
        document.getElementById('matrixBody').innerHTML =
            `<tr><td colspan="${colSpan}" class="text-center py-4 text-muted">No matching stores.</td></tr>`;
        return;
    }

    document.getElementById('matrixBody').innerHTML = rows.map(r => {
        const periodCells = mxData.periods.map(pk => mxRateCell(r.periodRates[pk])).join('');
        const avgCell = r.avgRate !== null && r.avgRate !== undefined
            ? mxRateCell(r.avgRate).replace('<td', '<td style="background:oklch(0.5 0.18 25 / .06)"')
            : `<td class="px-2 py-2 text-center text-muted" style="background:oklch(0.5 0.18 25 / .06)">—</td>`;
        return `<tr>
            <td class="px-3 py-2" style="color:oklch(0.5 0.03 258);white-space:nowrap">${r.operationConsultant || '<span class="text-muted">—</span>'}</td>
            <td class="px-3 py-2 fw-semibold" style="white-space:nowrap"><a href="/admin/dashboard/storeprofile?store=${encodeURIComponent(r.storeName)}" style="color:inherit;text-decoration:none" onmouseover="this.style.color='oklch(0.5 0.18 25)'" onmouseout="this.style.color='inherit'">${r.storeName}</a></td>
            ${periodCells}
            ${avgCell}
        </tr>`;
    }).join('');
}

function mxSort(col) {
    if (mxSortCol === col) { mxSortAsc = !mxSortAsc; }
    else { mxSortCol = col; mxSortAsc = (col === 'store' || col === 'oc'); }
    document.querySelectorAll('#matrixHead [data-mcol] i').forEach(i =>
        i.className = 'bi bi-arrow-down-up text-muted');
    const icon = document.querySelector(`#matrixHead [data-mcol="${col}"] i`);
    if (icon) icon.className = mxSortAsc ? 'bi bi-sort-up text-danger' : 'bi bi-sort-down text-danger';
    mxRender();
}

async function tvLoadTrendMatrix() {
    const body = document.getElementById('matrixBody');
    body.innerHTML = '<tr><td colspan="4" class="text-center py-4 text-muted"><div class="spinner-border spinner-border-sm me-2" style="color:oklch(0.6 0.22 22)"></div>Loading…</td></tr>';
    const q = new URLSearchParams();
    if (omFilter) q.set('om', omFilter);
    if (ocFilter) q.set('oc', ocFilter);
    if (tvYear)   q.set('sinceYear', tvYear);
    mxData = await fetchJson(`/api/dashboard/trend-matrix?${q.toString()}`);
    if (!mxData || !mxData.rows || !mxData.rows.length) {
        body.innerHTML = '<tr><td colspan="4" class="text-center py-4 text-muted">No data available.</td></tr>';
        return;
    }
    mxBuildHeader(mxData.periods);
    mxRender();
    tvRenderTrendChart();
}

document.getElementById('matrixSearch').addEventListener('input', mxRender);

/* Monthly Trend Chart — single store when filtered, top 6 when "All Stores" */
let trendChartInstance;
function tvRenderTrendChart() {
    if (!mxData || !mxData.periods || !mxData.periods.length) return;
    const colors = [
        'oklch(0.55 0.19 25)', 'oklch(0.65 0.15 190)', 'oklch(0.7 0.16 145)',
        'oklch(0.72 0.17 60)', 'oklch(0.62 0.2 15)', 'oklch(0.6 0.16 25)'
    ];
    const colorsFill = [
        'oklch(0.55 0.19 25 / .15)', 'oklch(0.65 0.15 190 / .15)', 'oklch(0.7 0.16 145 / .15)',
        'oklch(0.72 0.17 60 / .15)', 'oklch(0.62 0.2 15 / .15)', 'oklch(0.6 0.16 25 / .15)'
    ];
    const subtitle = document.getElementById('trendChartSubtitle');

    let rows;
    if (storeFilter) {
        rows = mxData.rows.filter(r => r.storeName === storeFilter);
        if (subtitle) subtitle.textContent = `Turnover rate (%) for ${storeFilter} across all available periods`;
    } else {
        rows = mxData.rows.slice(0, 6);
        if (subtitle) subtitle.textContent = 'Turnover rate (%) across all available periods';
    }

    const ctx = document.getElementById('trendChart');
    if (!ctx) return;
    if (trendChartInstance) trendChartInstance.destroy();
    trendChartInstance = new Chart(ctx, {
        type: 'line',
        data: {
            labels: mxData.periods.map(fmtPeriod),
            datasets: rows.map((row, i) => ({
                label: row.storeName,
                data: mxData.periods.map(p => row.periodRates?.[p] ?? null),
                borderColor: colors[i % colors.length],
                backgroundColor: colorsFill[i % colorsFill.length],
                tension: 0.4,
                fill: false,
                pointRadius: 4,
                spanGaps: true
            }))
        },
        options: {
            responsive: true,
            plugins: { legend: { labels: { color: 'oklch(0.5 0.03 258)', font: { size: 11 } } } },
            scales: {
