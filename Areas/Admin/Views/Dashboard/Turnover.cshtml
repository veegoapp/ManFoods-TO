/* "Top driver" mini-callout beside a chart card header ----- */
function tvRenderTopStat(elId, data) {
    const el = document.getElementById(elId);
    if (!el) return;
    if (!data || !data.length) { el.innerHTML = ''; return; }
    const total = data.reduce((s, d) => s + d.value, 0);
    const top   = data.slice().sort((a, b) => b.value - a.value)[0];
    const pct   = total > 0 ? Math.round(top.value / total * 100) : 0;
    el.innerHTML = `<span class="tv-stat-highlight">${top.label}</span> — ${top.value} (${pct}%)`;
}

async function tvLoadJobTitleStat() {
    const data = await fetchJson(`/api/dashboard/turnover-by-job-title?${buildQuery()}`);
    tvRenderTopStat('jobTitleTopStat', data);
}

