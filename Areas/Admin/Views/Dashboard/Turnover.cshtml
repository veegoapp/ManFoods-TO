/* Turnover Rate by Month — one bar per selected month, computed
   independently as resignations ÷ headcount for that single month. ------ */
let turnoverByMonthChart;
async function tvLoadTurnoverByMonthChart() {
    if (!tvYear || !tvMonths.length) return;
    const sortedMonths = tvMonths.slice().sort((a, b) => a - b);
    const results = await Promise.all(sortedMonths.map(m => {
        const q = new URLSearchParams({ year: tvYear, months: m, month: m });
        if (storeFilter) q.set('store', storeFilter);
