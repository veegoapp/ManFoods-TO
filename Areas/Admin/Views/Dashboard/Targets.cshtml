@{
    ViewData["Title"] = "Targets";
}

@Html.AntiForgeryToken()

<div class="page-header">
    <div>
        <h1 class="page-title">Targets</h1>
        <p class="page-subtitle">حدد أهداف الشركة عشان تتقارن بيها الأرقام الفعلية في كل الصفحات وفي الـ AI Assistant</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card-dark h-100">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="card-icon"><i class="bi bi-graph-up"></i></div>
                <div><h6 class="mb-0">Target Turnover Rate</h6><p class="text-muted-custom mb-0 small">النسبة المستهدفة لمعدل التيرن أوفر الشهري — تظهر كمقارنة تحت كارت "Turnover Rate" في كل الصفحات</p></div>
            </div>
            <div class="input-group mb-2">
                <input type="number" id="tgTurnoverInput" class="form-control form-control-dark" step="0.1" min="0" max="100" placeholder="مثال: 5"/>
                <span class="input-group-text">%</span>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card-dark h-100">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="card-icon"><i class="bi bi-shield-check"></i></div>
                <div><h6 class="mb-0">Target 90-Day Retention</h6><p class="text-muted-custom mb-0 small">النسبة المستهدفة للاحتفاظ بالموظفين بعد أول 90 يوم — تظهر في صفحة Retention</p></div>
            </div>
            <div class="input-group mb-2">
                <input type="number" id="tgRetentionInput" class="form-control form-control-dark" step="0.1" min="0" max="100" placeholder="مثال: 90"/>
                <span class="input-group-text">%</span>
            </div>
        </div>
    </div>
</div>

<div class="mt-4 d-flex align-items-center gap-3">
    <button id="tgSaveBtn" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>حفظ الأهداف</button>
    <span id="tgSavedMsg" class="text-success small" style="display:none"><i class="bi bi-check-circle-fill me-1"></i>اتحفظ بنجاح</span>
</div>

@section Scripts {
<script>
async function tgLoad() {
    const r = await fetch('/api/targets');
    const data = r.ok ? await r.json() : {};
    if (data.turnoverRateTarget != null) document.getElementById('tgTurnoverInput').value = data.turnoverRateTarget;
    if (data.retention90Target != null) document.getElementById('tgRetentionInput').value = data.retention90Target;
}

document.getElementById('tgSaveBtn').addEventListener('click', async () => {
    const turnoverVal = document.getElementById('tgTurnoverInput').value;
    const retentionVal = document.getElementById('tgRetentionInput').value;
    const body = {
        turnoverRateTarget: turnoverVal === '' ? null : parseFloat(turnoverVal),
        retention90Target: retentionVal === '' ? null : parseFloat(retentionVal),
    };
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    const res = await fetch('/api/targets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
        body: JSON.stringify(body)
    });
    if (res.ok) {
        const msg = document.getElementById('tgSavedMsg');
        msg.style.display = '';
        setTimeout(() => { msg.style.display = 'none'; }, 2500);
    }
});

tgLoad();
</script>
}
