@{
    ViewData["Title"] = L["Page_Comparisons"].Value;
}

<style>
.cmp-select-wrap { position:relative; }
.cmp-select {
    appearance:none; -webkit-appearance:none;
    background:var(--card-bg); border:1px solid var(--card-border); color:var(--text);
    border-radius:var(--radius-sm); font-size:13.5px; font-weight:600;
    height:42px; padding:0 34px 0 14px; width:100%;
    box-shadow:var(--shadow-sm); cursor:pointer;
}
.cmp-select:focus { outline:none; border-color:var(--red); box-shadow:0 0 0 3px var(--red-light); }
.cmp-select-wrap i { position:absolute; top:50%; right:12px; transform:translateY(-50%); font-size:11px; color:var(--text-3); pointer-events:none; }
[dir="rtl"] .cmp-select { padding:0 14px 0 34px; }
[dir="rtl"] .cmp-select-wrap i { right:auto; left:12px; }

.cmp-multiselect { position:relative; }
.cmp-multiselect-trigger {
    display:flex; align-items:center; gap:10px; justify-content:space-between; width:100%;
    background:var(--card-bg); border:1px solid var(--card-border); color:var(--text);
    border-radius:var(--radius-sm); font-size:13.5px; font-weight:600;
    height:42px; padding:0 12px 0 14px; box-shadow:var(--shadow-sm); cursor:pointer;
}
.cmp-multiselect-trigger:hover { border-color:var(--card-border-h); }
.cmp-multiselect-trigger i { font-size:11px; color:var(--text-3); flex-shrink:0; }
.cmp-multiselect-chips { white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.cmp-multiselect-panel {
    display:none; position:absolute; top:calc(100% + 6px); left:0; z-index:50;
    background:var(--card-bg); border:1px solid var(--card-border); border-radius:var(--radius-sm);
    box-shadow:var(--shadow-lg); min-width:220px; padding:8px; max-height:260px; overflow-y:auto;
}
.cmp-multiselect-panel.open { display:block; }
[dir="rtl"] .cmp-multiselect-panel { left:auto; right:0; }
.cmp-multiselect-actions { display:flex; gap:6px; padding:2px 4px 8px; border-bottom:1px solid var(--card-border); margin-bottom:6px; }
.cmp-ms-action {
    flex:1; background:var(--card-bg-2); border:1px solid var(--card-border); color:var(--red);
    border-radius:6px; font-size:11.5px; font-weight:700; padding:6px 8px; cursor:pointer;
}
.cmp-ms-action:hover { background:var(--red-light); }
.cmp-ms-option { display:flex; align-items:center; gap:9px; padding:7px 8px; border-radius:6px; cursor:pointer; font-size:13px; color:var(--text-2); }
.cmp-ms-option:hover { background:var(--card-bg-2); }
.cmp-ms-option input { accent-color:var(--red); width:15px; height:15px; cursor:pointer; }

.cmp-combobox { position:relative; }
.cmp-combobox-input {
    background:var(--card-bg); border:1px solid var(--card-border); color:var(--text);
    border-radius:var(--radius-sm); font-size:13.5px; font-weight:500;
    height:42px; padding:0 14px; width:100%; box-shadow:var(--shadow-sm);
}
.cmp-combobox-input:focus { outline:none; border-color:var(--red); box-shadow:0 0 0 3px var(--red-light); }
.cmp-combobox-panel {
    display:none; position:absolute; top:calc(100% + 6px); left:0; right:0; z-index:50;
    background:var(--card-bg); border:1px solid var(--card-border); border-radius:var(--radius-sm);
    box-shadow:var(--shadow-lg); max-height:240px; overflow-y:auto; padding:6px;
}
.cmp-combobox-panel.open { display:block; }
.cmp-combo-option { padding:8px 10px; border-radius:6px; font-size:13px; color:var(--text-2); cursor:pointer; }
.cmp-combo-option:hover { background:var(--card-bg-2); }
.cmp-combo-option.active { color:var(--red); font-weight:700; background:var(--red-light); }

/* Panels */
.cmp-panel { background:var(--card-bg); border:1px solid var(--card-border); border-radius:var(--radius); padding:20px; box-shadow:var(--shadow-sm); height:100%; }
.cmp-panel-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
.cmp-panel-title { font-size:15px; font-weight:800; color:var(--text); display:flex; align-items:center; gap:8px; }
.cmp-panel-badge { width:24px; height:24px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:800; color:#fff; }
.cmp-panel-a .cmp-panel-badge { background:oklch(0.5 0.18 25); }
.cmp-panel-b .cmp-panel-badge { background:oklch(0.65 0.15 190); }
.cmp-field { margin-bottom:12px; }
.cmp-field-label { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:var(--text-3); margin-bottom:5px; display:block; }
.cmp-copy-btn {
    background:var(--card-bg-2); border:1px solid var(--card-border); color:oklch(0.65 0.15 190);
    border-radius:7px; font-size:12px; font-weight:700; padding:7px 10px; cursor:pointer; width:100%; margin-top:2px;
}
.cmp-copy-btn:hover { background:oklch(0.65 0.15 190 / .1); }

/* KPI comparison cards */
.cmp-kpi-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:14px; }
.cmp-kpi-card { background:var(--card-bg); border:1px solid var(--card-border); border-radius:var(--radius); padding:16px 18px; box-shadow:var(--shadow-sm); }
.cmp-kpi-label { font-size:11.5px; font-weight:700; text-transform:uppercase; letter-spacing:.4px; color:var(--text-3); margin-bottom:10px; direction:ltr; unicode-bidi:isolate; text-align:left; }
.cmp-kpi-values { display:flex; align-items:baseline; gap:14px; margin-bottom:8px; direction:ltr; }
.cmp-kpi-val { display:flex; align-items:baseline; gap:5px; }
.cmp-kpi-tag { font-size:10px; font-weight:800; color:#fff; border-radius:4px; padding:1px 5px; }
.cmp-kpi-val.a .cmp-kpi-tag { background:oklch(0.5 0.18 25); }
.cmp-kpi-val.b .cmp-kpi-tag { background:oklch(0.65 0.15 190); }
.cmp-kpi-num { font-size:20px; font-weight:800; color:var(--text); }
.cmp-kpi-delta { font-size:12.5px; font-weight:700; display:inline-flex; align-items:center; gap:4px; direction:ltr; unicode-bidi:isolate; }
.cmp-kpi-delta.good { color:oklch(0.62 0.15 155); }
.cmp-kpi-delta.bad { color:oklch(0.6 0.22 22); }
.cmp-kpi-delta.neutral { color:var(--text-3); }

.cmp-insight {
    background:linear-gradient(135deg, var(--card-bg) 0%, oklch(0.5 0.18 25 / .05) 100%);
    border:1px solid oklch(0.5 0.18 25 / .2); border-radius:var(--radius); padding:16px 20px;
    display:flex; align-items:center; gap:14px; font-size:14px; color:var(--text-2);
}
.cmp-insight i { font-size:22px; color:oklch(0.5 0.18 25); flex-shrink:0; }
#cmpInsightText { direction:ltr; unicode-bidi:isolate; text-align:left; }

.cmp-table-hint { font-size:12px; color:var(--text-3); }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title">@L["Page_Comparisons"]</h1>
        <p class="page-subtitle">@L["Page_ComparisonsSub"]</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="cmp-panel cmp-panel-a">
            <div class="cmp-panel-header">
                <div class="cmp-panel-title"><span class="cmp-panel-badge">A</span>@L["Comparisons_PeriodA"]</div>
            </div>
            <div class="row g-2">
                <div class="col-6">
                    <div class="cmp-field">
                        <span class="cmp-field-label">@L["Common_Year"]</span>
                        <div class="cmp-select-wrap"><select id="cmpYearA" class="cmp-select"></select><i class="bi bi-chevron-down"></i></div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="cmp-field">
                        <span class="cmp-field-label">@L["Common_SelectMonths"]</span>
                        <div class="cmp-multiselect" id="cmpMonthsMultiselectA" data-label-select="@L["Common_SelectMonths"]" data-label-all="@L["Common_AllMonths"]">
                            <button type="button" class="cmp-multiselect-trigger" id="cmpMonthsTriggerA">
                                <span class="cmp-multiselect-chips" id="cmpMonthsChipsA">@L["Common_AllMonths"]</span>
                                <i class="bi bi-chevron-down"></i>
                            </button>
                            <div class="cmp-multiselect-panel" id="cmpMonthsPanelA">
                                <div class="cmp-multiselect-actions">
                                    <button type="button" class="cmp-ms-action" id="cmpMonthsSelectAllA">@L["Common_SelectAll"]</button>
                                    <button type="button" class="cmp-ms-action" id="cmpMonthsClearAllA">@L["Common_ClearAll"]</button>
                                </div>
                                <div id="cmpMonthsOptionsA"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="cmp-field">
                        <span class="cmp-field-label">@L["Common_StoreName"]</span>
                        <div class="cmp-combobox" id="cmpStoreComboA">
                            <input type="text" class="cmp-combobox-input" id="cmpStoreInputA" placeholder="@L["Common_AllStores"]" autocomplete="off">
                            <div class="cmp-combobox-panel" id="cmpStorePanelA"></div>
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="cmp-field">
                        <span class="cmp-field-label">@L["Common_OperationManager"]</span>
                        <div class="cmp-combobox" id="cmpOmComboA">
                            <input type="text" class="cmp-combobox-input" id="cmpOmInputA" placeholder="@L["Common_AllOperationManagers"]" autocomplete="off">
                            <div class="cmp-combobox-panel" id="cmpOmPanelA"></div>
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="cmp-field">
                        <span class="cmp-field-label">@L["Common_OperationConsultant"]</span>
                        <div class="cmp-combobox" id="cmpOcComboA">
                            <input type="text" class="cmp-combobox-input" id="cmpOcInputA" placeholder="@L["Common_AllOperationConsultants"]" autocomplete="off">
                            <div class="cmp-combobox-panel" id="cmpOcPanelA"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="cmp-panel cmp-panel-b">
            <div class="cmp-panel-header">
                <div class="cmp-panel-title"><span class="cmp-panel-badge">B</span>@L["Comparisons_PeriodB"]</div>
            </div>
            <div class="row g-2">
                <div class="col-6">
                    <div class="cmp-field">
                        <span class="cmp-field-label">@L["Common_Year"]</span>
                        <div class="cmp-select-wrap"><select id="cmpYearB" class="cmp-select"></select><i class="bi bi-chevron-down"></i></div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="cmp-field">
                        <span class="cmp-field-label">@L["Common_SelectMonths"]</span>
                        <div class="cmp-multiselect" id="cmpMonthsMultiselectB" data-label-select="@L["Common_SelectMonths"]" data-label-all="@L["Common_AllMonths"]">
                            <button type="button" class="cmp-multiselect-trigger" id="cmpMonthsTriggerB">
                                <span class="cmp-multiselect-chips" id="cmpMonthsChipsB">@L["Common_AllMonths"]</span>
                                <i class="bi bi-chevron-down"></i>
                            </button>
                            <div class="cmp-multiselect-panel" id="cmpMonthsPanelB">
                                <div class="cmp-multiselect-actions">
                                    <button type="button" class="cmp-ms-action" id="cmpMonthsSelectAllB">@L["Common_SelectAll"]</button>
                                    <button type="button" class="cmp-ms-action" id="cmpMonthsClearAllB">@L["Common_ClearAll"]</button>
