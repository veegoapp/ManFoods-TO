</div>

<div class="d-flex align-items-center gap-2 mb-3">
    <div style="width:4px;height:22px;background:linear-gradient(135deg,oklch(0.44 0.18 25),oklch(0.6 0.16 25));border-radius:2px"></div>
    <h5 class="mb-0 fw-bold">@L["Comparisons_StoreBreakdown"]</h5>
    <span class="cmp-table-hint">@L["Comparisons_StoreBreakdownHint"]</span>
</div>
<div class="chart-card mb-4 p-0" style="overflow:hidden" id="cmpTableCard">
    <div class="table-responsive" style="max-height:420px;overflow-y:auto">
        <table class="table table-hover mb-0" style="font-size:13px">
            <thead style="background:oklch(0.965 0.008 255);position:sticky;top:0;z-index:1">
                <tr>
                    <th class="px-3 py-2">@L["Common_StoreName"]</th>
                    <th class="px-3 py-2 text-center">Turnover% A</th>
                    <th class="px-3 py-2 text-center">Turnover% B</th>
                    <th class="px-3 py-2 text-center">Δ</th>
                    <th class="px-3 py-2 text-center">90-Day% A</th>
                    <th class="px-3 py-2 text-center">90-Day% B</th>
                    <th class="px-3 py-2 text-center">Δ</th>
                </tr>
            </thead>
            <tbody id="cmpTableBody">
                <tr><td colspan="7" class="text-center py-4 text-muted">@L["Common_Loading"]</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="~/js/dashboard.js" asp-append-version="true"></script>
<script>
/* ── Comparisons page — two independent filter panels (A / B) ──────────
   Reuses fetchJson/mkChart/COLORS from dashboard.js; does NOT use
   dashboard.js's period/store selects or buildQuery/loadAll (those target
   #periodSelect etc. which don't exist here, so they safely no-op). */

const panels = {
    A: { year: null, months: [], store: '', om: '', oc: '', yearMonthsMap: {} },
    B: { year: null, months: [], store: '', om: '', oc: '', yearMonthsMap: {} }
};

function cmpMonthShortName(m) { return new Date(2000, m - 1, 1).toLocaleString('default', { month: 'short' }); }

function cmpAnchor(side) { return panels[side].months.length ? Math.max(...panels[side].months) : null; }

function cmpBuildQuery(side) {
    const p = panels[side];
    const q = new URLSearchParams();
    if (p.year) q.set('year', p.year);
    if (p.months.length) { q.set('months', p.months.join(',')); q.set('month', Math.max(...p.months)); }
    if (p.store) q.set('store', p.store);
    if (p.om)    q.set('om', p.om);
    if (p.oc)    q.set('oc', p.oc);
    return q.toString();
}

function cmpLabel(side) {
    const p = panels[side];
    if (!p.months.length) return side;
    const months = p.months.slice().sort((a, b) => a - b).map(cmpMonthShortName).join('/');
    return `${side} (${months} ${p.year})`;
}

/* Generic searchable single-select combobox ---------------------------- */
function cmpCreateCombobox({ inputId, panelId, onSelect }) {
    const input = document.getElementById(inputId);
    const panel = document.getElementById(panelId);
    const allLabel = input.placeholder;
    let options = [];
    let value = '';

    function render(filterText) {
        const ft = (filterText || '').toLowerCase();
        const filtered = options.filter(o => o.toLowerCase().includes(ft));
        let html = `<div class="cmp-combo-option${value === '' ? ' active' : ''}" data-value="">${allLabel}</div>`;
        html += filtered.map(o => `<div class="cmp-combo-option${o === value ? ' active' : ''}" data-value="${o.replace(/"/g, '&quot;')}">${o}</div>`).join('');
        panel.innerHTML = html;
    }
    function open() { panel.classList.add('open'); render(''); input.select(); }
    function close() { panel.classList.remove('open'); input.value = value; }

    panel.addEventListener('mousedown', (e) => {
        const opt = e.target.closest('.cmp-combo-option');
        if (!opt) return;
        e.preventDefault();
        value = opt.dataset.value;
        input.value = value;
        panel.classList.remove('open');
        onSelect(value);
    });
    input.addEventListener('focus', open);
    input.addEventListener('input', () => render(input.value));
    input.addEventListener('blur', () => setTimeout(close, 150));

    return {
        setOptions(list) { options = list || []; },
        setValue(v) { value = v || ''; input.value = value; }
    };
}

const combos = {};
['A', 'B'].forEach(side => {
    combos[`store${side}`] = cmpCreateCombobox({ inputId: `cmpStoreInput${side}`, panelId: `cmpStorePanel${side}`, onSelect: v => { panels[side].store = v; cmpRefreshAll(); } });
    combos[`om${side}`]    = cmpCreateCombobox({ inputId: `cmpOmInput${side}`,    panelId: `cmpOmPanel${side}`,    onSelect: v => { panels[side].om    = v; cmpRefreshAll(); } });
    combos[`oc${side}`]    = cmpCreateCombobox({ inputId: `cmpOcInput${side}`,    panelId: `cmpOcPanel${side}`,    onSelect: v => { panels[side].oc    = v; cmpRefreshAll(); } });
});

/* Months multi-select ---------------------------------------------------- */
function cmpBuildMonthsOptions(side) {
    const container = document.getElementById(`cmpMonthsOptions${side}`);
    const p = panels[side];
    const available = (p.yearMonthsMap[p.year] || []).slice().sort((a, b) => a - b);
    container.innerHTML = available.map(m => `
        <label class="cmp-ms-option">
            <input type="checkbox" value="${m}" ${p.months.includes(m) ? 'checked' : ''}>
            <span>${monthName(m, p.year)}</span>
        </label>`).join('');
    container.querySelectorAll('input[type=checkbox]').forEach(cb => {
        cb.addEventListener('change', () => {
            const m = parseInt(cb.value);
            if (cb.checked) { if (!p.months.includes(m)) p.months.push(m); }
            else { p.months = p.months.filter(x => x !== m); }
            p.months.sort((a, b) => a - b);
            cmpRenderMonthsChips(side);
            cmpOnMonthsChanged(side);
        });
    });
}

function cmpRenderMonthsChips(side) {
    const p = panels[side];
    const chipsEl = document.getElementById(`cmpMonthsChips${side}`);
    const labels = document.getElementById(`cmpMonthsMultiselect${side}`).dataset;
    const available = p.yearMonthsMap[p.year] || [];
    if (!p.months.length) { chipsEl.textContent = labels.labelSelect; return; }
    if (p.months.length === available.length) { chipsEl.textContent = labels.labelAll; return; }
    const names = p.months.map(cmpMonthShortName);
    chipsEl.textContent = names.length <= 2 ? names.join('، ') : `${names[0]}، ${names[1]} +${names.length - 2}`;
}

let cmpMonthsDebounce;
function cmpOnMonthsChanged(side) {
    clearTimeout(cmpMonthsDebounce);
    cmpMonthsDebounce = setTimeout(async () => {
        if (!panels[side].months.length) return;
        await cmpLoadDependentLists(side);
        await cmpRefreshAll();
    }, 250);
}

['A', 'B'].forEach(side => {
    document.getElementById(`cmpMonthsSelectAll${side}`).addEventListener('click', () => {
        const p = panels[side];
        p.months = (p.yearMonthsMap[p.year] || []).slice().sort((a, b) => a - b);
        cmpBuildMonthsOptions(side); cmpRenderMonthsChips(side); cmpOnMonthsChanged(side);
    });
    document.getElementById(`cmpMonthsClearAll${side}`).addEventListener('click', () => {
        panels[side].months = [];
        cmpBuildMonthsOptions(side); cmpRenderMonthsChips(side); cmpOnMonthsChanged(side);
    });
    document.getElementById(`cmpMonthsTrigger${side}`).addEventListener('click', (e) => {
        e.stopPropagation();
        document.getElementById(`cmpMonthsPanel${side}`).classList.toggle('open');
    });
});
document.addEventListener('click', (e) => {
    ['A', 'B'].forEach(side => {
        if (!document.getElementById(`cmpMonthsMultiselect${side}`).contains(e.target))
            document.getElementById(`cmpMonthsPanel${side}`).classList.remove('open');
    });
});

/* Year selects ------------------------------------------------------------ */
['A', 'B'].forEach(side => {
    document.getElementById(`cmpYear${side}`).addEventListener('change', async function () {
        const p = panels[side];
        p.year = parseInt(this.value);
        p.months = (p.yearMonthsMap[p.year] || []).slice().sort((a, b) => a - b);
        p.store = ''; p.om = ''; p.oc = '';
        combos[`store${side}`].setValue(''); combos[`om${side}`].setValue(''); combos[`oc${side}`].setValue('');
        cmpBuildMonthsOptions(side); cmpRenderMonthsChips(side);
        await cmpLoadDependentLists(side);
        await cmpRefreshAll();
    });
});

/* "Copy to last year" — mirrors A into B, one year earlier -------------- */
document.getElementById('cmpCopyToLastYear').addEventListener('click', async () => {
    const a = panels.A, b = panels.B;
    const targetYear = a.year - 1;
    if (!b.yearMonthsMap[targetYear]) return;
    b.year = targetYear;
    document.getElementById('cmpYearB').value = targetYear;
    const availableB = b.yearMonthsMap[targetYear] || [];
    b.months = a.months.filter(m => availableB.includes(m));
    b.store = a.store; b.om = a.om; b.oc = a.oc;
    combos.storeB.setValue(a.store); combos.omB.setValue(a.om); combos.ocB.setValue(a.oc);
    cmpBuildMonthsOptions('B'); cmpRenderMonthsChips('B');
    await cmpLoadDependentLists('B');
    await cmpRefreshAll();
});

/* Store / OM / OC option lists (scoped to each panel's latest month) ---- */
async function cmpLoadDependentLists(side) {
    const anchor = cmpAnchor(side);
    const p = panels[side];
    if (!anchor || !p.year) return;
    const [stores, oms, ocs] = await Promise.all([
        fetchJson(`/api/dashboard/stores?month=${anchor}&year=${p.year}`),
        fetchJson(`/api/dashboard/operation-managers?month=${anchor}&year=${p.year}`),
        fetchJson(`/api/dashboard/operation-consultants?month=${anchor}&year=${p.year}`)
    ]);
    combos[`store${side}`].setOptions(stores.map(s => s.storeName));
    combos[`om${side}`].setOptions(oms);
    combos[`oc${side}`].setOptions(ocs);
}

/* Initial load ------------------------------------------------------------ */
async function cmpInit() {
    const periods = await fetchJson('/api/dashboard/available-periods');
    if (!periods.length) return;

    const yearMonthsMap = {};
    periods.forEach(pd => { (yearMonthsMap[pd.year] = yearMonthsMap[pd.year] || []).push(pd.month); });
    const years = Object.keys(yearMonthsMap).map(Number).sort((a, b) => b - a);

    for (const side of ['A', 'B']) {
        panels[side].yearMonthsMap = yearMonthsMap;
        const yearSel = document.getElementById(`cmpYear${side}`);
        yearSel.innerHTML = years.map(y => `<option value="${y}">${y}</option>`).join('');
    }

    // A defaults to the latest year/all its months; B defaults to the same
    // months one year earlier (the most common "vs last year" use case).
    panels.A.year = years[0];
    panels.A.months = (yearMonthsMap[panels.A.year] || []).slice().sort((a, b) => a - b);
    document.getElementById('cmpYearA').value = panels.A.year;

    const prevYear = panels.A.year - 1;
    if (yearMonthsMap[prevYear]) {
        panels.B.year = prevYear;
        panels.B.months = panels.A.months.filter(m => yearMonthsMap[prevYear].includes(m));
    } else {
        panels.B.year = years[years.length - 1];
        panels.B.months = (yearMonthsMap[panels.B.year] || []).slice().sort((a, b) => a - b);
    }
    document.getElementById('cmpYearB').value = panels.B.year;

    cmpBuildMonthsOptions('A'); cmpRenderMonthsChips('A');
    cmpBuildMonthsOptions('B'); cmpRenderMonthsChips('B');

    await Promise.all([cmpLoadDependentLists('A'), cmpLoadDependentLists('B')]);
    await cmpRefreshAll();
}

/* Data fetching + rendering ----------------------------------------------- */
async function cmpFetchSide(side) {
    const q = cmpBuildQuery(side);
    const [kpi, ninety] = await Promise.all([
        fetchJson(`/api/dashboard/kpis?${q}`),
        fetchJson(`/api/ninety-day-turnover/kpi?${q}`)
    ]);
    let byStore = [], ninetyByStore = [];
    if (!panels[side].store) {
        [byStore, ninetyByStore] = await Promise.all([
            fetchJson(`/api/dashboard/store-comparison?${q}`),
            fetchJson(`/api/ninety-day-turnover/by-store?${q}`)
        ]);
    }
    return { kpi, ninety, byStore, ninetyByStore };
}

function cmpDeltaBadge(a, b, lowerIsBetter) {
    const delta = a - b;
    let cls = 'neutral';
    if (lowerIsBetter === true)  cls = delta <= 0 ? 'good' : 'bad';
    if (lowerIsBetter === false) cls = delta >= 0 ? 'good' : 'bad';
    const sign = delta > 0 ? '+' : '';
    const icon = delta > 0 ? 'bi-arrow-up-short' : delta < 0 ? 'bi-arrow-down-short' : 'bi-dash';
    return `<span class="cmp-kpi-delta ${cls}"><i class="bi ${icon}"></i>${sign}${delta.toFixed(1)} (A−B)</span>`;
}

function cmpRenderKpis(dataA, dataB) {
    const metrics = [
        { label: 'Turnover %',          a: dataA.kpi.turnoverRate,        b: dataB.kpi.turnoverRate,        fmt: v => v.toFixed(1) + '%', lowerIsBetter: true },
        { label: 'Headcount',           a: dataA.kpi.totalHeadcount,      b: dataB.kpi.totalHeadcount,      fmt: v => v,                  lowerIsBetter: null },
        { label: 'New Hires',           a: dataA.kpi.newHires,            b: dataB.kpi.newHires,            fmt: v => v,                  lowerIsBetter: false },
        { label: 'Resignations',        a: dataA.kpi.totalResignations,   b: dataB.kpi.totalResignations,   fmt: v => v,                  lowerIsBetter: true },
        { label: '90-Day Early Leavers',a: dataA.ninety.earlyLeavers,     b: dataB.ninety.earlyLeavers,     fmt: v => v,                  lowerIsBetter: true },
        { label: '90-Day Turnover Rate',a: dataA.ninety.rate,             b: dataB.ninety.rate,             fmt: v => v.toFixed(1) + '%', lowerIsBetter: true }
    ];

    document.getElementById('cmpKpiGrid').innerHTML = metrics.map(m => `
        <div class="cmp-kpi-card">
            <div class="cmp-kpi-label">${m.label}</div>
            <div class="cmp-kpi-values">
                <div class="cmp-kpi-val a"><span class="cmp-kpi-tag">A</span><span class="cmp-kpi-num">${m.fmt(m.a)}</span></div>
                <div class="cmp-kpi-val b"><span class="cmp-kpi-tag">B</span><span class="cmp-kpi-num">${m.fmt(m.b)}</span></div>
            </div>
            ${cmpDeltaBadge(m.a, m.b, m.lowerIsBetter)}
        </div>
    `).join('');
}

function cmpRenderInsight(dataA, dataB) {
    const dTurnover = dataA.kpi.turnoverRate - dataB.kpi.turnoverRate;
    const d90 = dataA.ninety.rate - dataB.ninety.rate;
    const dir = v => v <= 0 ? 'improved' : 'worsened';
    const arrow = v => v <= 0 ? '↓' : '↑';
    document.getElementById('cmpInsightText').innerHTML =
        `<b>${cmpLabel('A')}</b> vs <b>${cmpLabel('B')}</b> — ` +
        `Turnover ${dir(dTurnover)} ${arrow(dTurnover)} ${Math.abs(dTurnover).toFixed(1)}pt, ` +
        `90-day rate ${dir(d90)} ${arrow(d90)} ${Math.abs(d90).toFixed(1)}pt.`;
}

let cmpTurnoverChart, cmpNinetyChart;
function cmpBuildSeries(dataA, dataB, storeKey, overallA, overallB) {
    const allA = !panels.A.store, allB = !panels.B.store;
    if (allA && allB) {
        const mapA = {}, mapB = {};
        (dataA[storeKey] || []).forEach(r => mapA[r.label ?? r.storeName] = r.value ?? r.turnoverRate);
        (dataB[storeKey] || []).forEach(r => mapB[r.label ?? r.storeName] = r.value ?? r.turnoverRate);
        const stores = Array.from(new Set([...Object.keys(mapA), ...Object.keys(mapB)]))
            .sort((s1, s2) => ((mapA[s2] || 0) + (mapB[s2] || 0)) - ((mapA[s1] || 0) + (mapB[s1] || 0)))
            .slice(0, 8);
        return { labels: stores, seriesA: stores.map(s => mapA[s] || 0), seriesB: stores.map(s => mapB[s] || 0) };
    }
    return { labels: ['Overall'], seriesA: [overallA], seriesB: [overallB] };
}

function cmpRenderCharts(dataA, dataB) {
    const t = cmpBuildSeries(dataA, dataB, 'byStore', dataA.kpi.turnoverRate, dataB.kpi.turnoverRate);
    cmpTurnoverChart = mkChart(cmpTurnoverChart, 'cmpTurnoverChart', {
        type: 'bar',
        data: { labels: t.labels, datasets: [
            { label: cmpLabel('A'), data: t.seriesA, backgroundColor: 'oklch(0.5 0.18 25)', borderRadius: 4 },
            { label: cmpLabel('B'), data: t.seriesB, backgroundColor: 'oklch(0.65 0.15 190)', borderRadius: 4 }
        ] },
        options: { plugins: { legend: { position: 'bottom' } }, scales: { y: { ticks: { callback: v => v + '%' } } } }
    });

    const n = cmpBuildSeries(dataA, dataB, 'ninetyByStore', dataA.ninety.rate, dataB.ninety.rate);
    cmpNinetyChart = mkChart(cmpNinetyChart, 'cmpNinetyChart', {
        type: 'bar',
        data: { labels: n.labels, datasets: [
            { label: cmpLabel('A'), data: n.seriesA, backgroundColor: 'oklch(0.5 0.18 25)', borderRadius: 4 },
            { label: cmpLabel('B'), data: n.seriesB, backgroundColor: 'oklch(0.65 0.15 190)', borderRadius: 4 }
        ] },
        options: { plugins: { legend: { position: 'bottom' } }, scales: { y: { ticks: { callback: v => v + '%' } } } }
    });
}

function cmpRenderTable(dataA, dataB) {
    const card = document.getElementById('cmpTableCard');
    if (panels.A.store || panels.B.store) { card.style.display = 'none'; return; }
    card.style.display = '';

    const turnoverA = {}, turnoverB = {}, ninetyA = {}, ninetyB = {};
    dataA.byStore.forEach(r => turnoverA[r.storeName] = r.turnoverRate);
    dataB.byStore.forEach(r => turnoverB[r.storeName] = r.turnoverRate);
    dataA.ninetyByStore.forEach(r => ninetyA[r.label] = r.value);
    dataB.ninetyByStore.forEach(r => ninetyB[r.label] = r.value);

    const stores = Array.from(new Set([...Object.keys(turnoverA), ...Object.keys(turnoverB)])).sort();
    if (!stores.length) {
        document.getElementById('cmpTableBody').innerHTML = `<tr><td colspan="7" class="text-center py-4 text-muted">No data.</td></tr>`;
        return;
    }

    document.getElementById('cmpTableBody').innerHTML = stores.map(s => {
        const ta = turnoverA[s], tb = turnoverB[s], na = ninetyA[s], nb = ninetyB[s];
        const fmt = v => v === undefined ? '<span class="text-muted">—</span>' : v.toFixed(1) + '%';
        const ltr = v => `<span style="direction:ltr;unicode-bidi:isolate">${v}</span>`;
        const dt = (ta !== undefined && tb !== undefined) ? ltr((ta - tb).toFixed(1)) : '—';
        const dn = (na !== undefined && nb !== undefined) ? ltr((na - nb).toFixed(1)) : '—';
        return `<tr>
            <td class="px-3 py-2 fw-semibold">${s}</td>
            <td class="px-3 py-2 text-center">${fmt(ta)}</td>
            <td class="px-3 py-2 text-center">${fmt(tb)}</td>
            <td class="px-3 py-2 text-center">${dt}</td>
            <td class="px-3 py-2 text-center">${fmt(na)}</td>
            <td class="px-3 py-2 text-center">${fmt(nb)}</td>
            <td class="px-3 py-2 text-center">${dn}</td>
        </tr>`;
    }).join('');
}

async function cmpRefreshAll() {
    if (!panels.A.months.length || !panels.B.months.length) return;
    const [dataA, dataB] = await Promise.all([cmpFetchSide('A'), cmpFetchSide('B')]);
    cmpRenderKpis(dataA, dataB);
    cmpRenderInsight(dataA, dataB);
    cmpRenderCharts(dataA, dataB);
    cmpRenderTable(dataA, dataB);
}

cmpInit();
</script>
}
