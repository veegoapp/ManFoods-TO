                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="cmp-field">
                        <span class="cmp-field-label">@L["Common_StoreName"]</span>
                        <div class="cmp-combobox" id="cmpStoreComboB">
                            <input type="text" class="cmp-combobox-input" id="cmpStoreInputB" placeholder="@L["Common_AllStores"]" autocomplete="off">
                            <div class="cmp-combobox-panel" id="cmpStorePanelB"></div>
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="cmp-field">
                        <span class="cmp-field-label">@L["Common_OperationManager"]</span>
                        <div class="cmp-combobox" id="cmpOmComboB">
                            <input type="text" class="cmp-combobox-input" id="cmpOmInputB" placeholder="@L["Common_AllOperationManagers"]" autocomplete="off">
                            <div class="cmp-combobox-panel" id="cmpOmPanelB"></div>
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="cmp-field">
                        <span class="cmp-field-label">@L["Common_OperationConsultant"]</span>
                        <div class="cmp-combobox" id="cmpOcComboB">
                            <input type="text" class="cmp-combobox-input" id="cmpOcInputB" placeholder="@L["Common_AllOperationConsultants"]" autocomplete="off">
