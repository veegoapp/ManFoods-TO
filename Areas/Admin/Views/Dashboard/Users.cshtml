@model List<MvcApp.Models.ViewModels.UserViewModel>
@{
    ViewData["Title"] = L["Page_Users"].Value;
}

<div class="page-header">
    <div><h1 class="page-title">@L["Page_Users"]</h1><p class="page-subtitle">@L["Page_UsersSub"]</p></div>
    <div class="d-flex flex-wrap gap-2">
        <a href="/admin/dashboard/download-template?type=bulk_users" class="btn btn-outline-template btn-sm">
            <i class="bi bi-file-earmark-arrow-down me-1"></i>@L["Users_TemplateBulk"]
        </a>
        <a href="/admin/dashboard/createuser" class="btn btn-primary btn-sm"><i class="bi bi-person-plus me-2"></i>@L["Users_NewUser"]</a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="card-dark h-100">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="card-icon"><i class="bi bi-people-fill"></i></div>
                <div><h6 class="mb-0">@L["Users_BulkUpload"]</h6><p class="text-muted-custom mb-0 small">@L["Users_BulkUploadSub"]</p></div>
            </div>
            <form asp-area="Admin" asp-controller="Dashboard" asp-action="UploadBulkUsers" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="mb-2"><input type="file" name="File" accept=".xlsx,.xls" class="form-control form-control-dark form-control-sm" required/></div>
                <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-cloud-upload me-1"></i>@L["Users_UploadUsers"]</button>
            </form>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card-dark h-100">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="card-icon"><i class="bi bi-key-fill"></i></div>
                <div><h6 class="mb-0">@L["Users_BulkOtp"]</h6><p class="text-muted-custom mb-0 small">@L["Users_BulkOtpSub"]</p></div>
            </div>
            <a href="/admin/dashboard/generatebulkotps" class="btn btn-primary btn-sm w-100"><i class="bi bi-file-earmark-arrow-down me-1"></i>@L["Users_GenerateOtps"]</a>
        </div>
    </div>
</div>

<div class="card-dark">
    @if (!Model.Any())
    {
        <div class="empty-state"><i class="bi bi-people"></i><p>No users yet</p></div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark-custom">
                <thead><tr><th>@L["Common_Email"]</th><th>@L["Common_Phone"]</th><th>@L["Common_Role"]</th><th>@L["Common_Status"]</th><th>@L["Common_Created"]</th><th class="text-end">@L["Common_Actions"]</th></tr></thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="fw-medium">@user.Email</td>
                            <td class="text-muted-custom">@user.Phone</td>
                            <td><span class="role-badge role-@user.Role.ToLower()">@user.Role</span></td>
                            <td>
                                @if (user.HasPassword)
                                {
                                    <span class="role-badge" style="background:var(--success-bg);color:var(--success)">Active</span>
                                }
                                else
                                {
                                    <span class="role-badge role-pending">Pending Activation</span>
                                }
                            </td>
                            <td class="text-muted-custom small">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-end">
                                @if (user.Role == "User")
                                {
                                    <button type="button" class="btn btn-sm btn-outline-secondary me-1 js-generate-otp" data-id="@user.Id" data-email="@user.Email" title="Generate OTP"><i class="bi bi-key"></i></button>
                                }
                                @if (user.Role == "Admin")
                                {
                                    <button type="button" class="btn btn-sm btn-outline-secondary me-1 js-regenerate-recovery-key" title="Generate a new admin recovery key"><i class="bi bi-shield-lock"></i></button>
                                }
                                <a href="/admin/dashboard/edituser/@user.Id" class="btn btn-sm btn-outline-secondary me-1"><i class="bi bi-pencil"></i></a>
                                <form asp-area="Admin" asp-controller="Dashboard" asp-action="DeleteUser" method="post" class="d-inline" onsubmit="return confirm('Delete user @user.Email?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id"/>
                                    <button type="submit" class="btn btn-sm btn-danger-outline"><i class="bi bi-trash3"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div id="otpResultModal" style="display:none;position:fixed;inset:0;z-index:1100;background:rgba(0,0,0,.5);align-items:center;justify-content:center">
    <div class="card-dark" style="max-width:380px;width:90%">
        <h6 class="mb-2"><i class="bi bi-key-fill me-1"></i>OTP Generated</h6>
        <p class="text-muted-custom small mb-2" id="otpResultEmail"></p>
        <div class="d-flex align-items-center gap-2 mb-3">
            <input type="text" id="otpResultCode" class="form-control form-control-dark" readonly style="font-size:20px;letter-spacing:4px;text-align:center;font-weight:700"/>
            <button type="button" class="btn btn-outline-secondary btn-sm" id="otpCopyBtn" title="Copy"><i class="bi bi-clipboard"></i></button>
        </div>
        <p class="text-muted-custom small mb-3">Valid for 4 hours, single use. Send this to the user yourself.</p>
        <button type="button" class="btn btn-primary w-100" id="otpCloseBtn">Close</button>
    </div>
</div>

<div id="recoveryPasswordModal" style="display:none;position:fixed;inset:0;z-index:1100;background:rgba(0,0,0,.5);align-items:center;justify-content:center">
    <div class="card-dark" style="max-width:380px;width:90%">
        <h6 class="mb-2"><i class="bi bi-shield-lock me-1"></i>Confirm Your Password</h6>
        <p class="text-muted-custom small mb-3">Enter <strong>your own</strong> admin password to generate a new recovery key. This replaces the current key everywhere — the old one stops working immediately.</p>
        <input type="password" id="recoveryPasswordInput" class="form-control form-control-dark mb-2" placeholder="Your password"/>
        <p class="text-danger small mb-2" id="recoveryPasswordError" style="display:none"></p>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary w-100" id="recoveryPasswordCancelBtn">Cancel</button>
            <button type="button" class="btn btn-primary w-100" id="recoveryPasswordSubmitBtn">Generate New Key</button>
        </div>
    </div>
</div>

<div id="recoveryResultModal" style="display:none;position:fixed;inset:0;z-index:1100;background:rgba(0,0,0,.5);align-items:center;justify-content:center">
    <div class="card-dark" style="max-width:420px;width:90%">
        <h6 class="mb-2"><i class="bi bi-shield-check me-1"></i>New Recovery Key</h6>
        <div class="d-flex align-items-center gap-2 mb-3">
            <input type="text" id="recoveryResultKey" class="form-control form-control-dark" readonly style="font-size:14px;font-weight:700"/>
            <button type="button" class="btn btn-outline-secondary btn-sm" id="recoveryCopyBtn" title="Copy"><i class="bi bi-clipboard"></i></button>
        </div>
        <p class="text-danger small mb-3"><i class="bi bi-exclamation-triangle-fill me-1"></i>Save this now — it will not be shown again, and the old key no longer works.</p>
        <button type="button" class="btn btn-primary w-100" id="recoveryResultCloseBtn">I've Saved It — Close</button>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const modal = document.getElementById('otpResultModal');
    const emailEl = document.getElementById('otpResultEmail');
    const codeEl = document.getElementById('otpResultCode');
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    document.querySelectorAll('.js-generate-otp').forEach(btn => {
        btn.addEventListener('click', async () => {
            btn.disabled = true;
            try {
                const res = await fetch(`/admin/dashboard/generateotp/${btn.dataset.id}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                });
                if (!res.ok) { alert('Failed to generate OTP.'); return; }
                const data = await res.json();
                emailEl.textContent = btn.dataset.email;
                codeEl.value = data.otp;
                modal.style.display = 'flex';
            } finally {
                btn.disabled = false;
            }
        });
    });

    document.getElementById('otpCopyBtn').addEventListener('click', () => {
        codeEl.select();
        navigator.clipboard.writeText(codeEl.value);
    });
    document.getElementById('otpCloseBtn').addEventListener('click', () => { modal.style.display = 'none'; });

    // ── Regenerate admin recovery key ──────────────────────
    const pwModal = document.getElementById('recoveryPasswordModal');
    const pwInput = document.getElementById('recoveryPasswordInput');
    const pwError = document.getElementById('recoveryPasswordError');
    const resultModal = document.getElementById('recoveryResultModal');
    const resultKeyEl = document.getElementById('recoveryResultKey');

    document.querySelectorAll('.js-regenerate-recovery-key').forEach(btn => {
        btn.addEventListener('click', () => {
            pwInput.value = '';
            pwError.style.display = 'none';
            pwModal.style.display = 'flex';
            pwInput.focus();
        });
    });

    document.getElementById('recoveryPasswordCancelBtn').addEventListener('click', () => { pwModal.style.display = 'none'; });

    async function submitRecoveryPassword() {
        const submitBtn = document.getElementById('recoveryPasswordSubmitBtn');
        pwError.style.display = 'none';
        submitBtn.disabled = true;
        try {
            const body = new URLSearchParams({ password: pwInput.value });
            const res = await fetch('/admin/dashboard/regeneraterecoverykey', {
                method: 'POST',
                headers: { 'RequestVerificationToken': token, 'Content-Type': 'application/x-www-form-urlencoded' },
                body
            });
            const data = await res.json();
            if (!res.ok || data.error) {
                pwError.textContent = data.error || 'Something went wrong.';
                pwError.style.display = '';
                return;
            }
            pwModal.style.display = 'none';
            resultKeyEl.value = data.key;
            resultModal.style.display = 'flex';
        } finally {
            submitBtn.disabled = false;
        }
    }

    document.getElementById('recoveryPasswordSubmitBtn').addEventListener('click', submitRecoveryPassword);
    pwInput.addEventListener('keydown', e => { if (e.key === 'Enter') submitRecoveryPassword(); });

    document.getElementById('recoveryCopyBtn').addEventListener('click', () => {
        resultKeyEl.select();
        navigator.clipboard.writeText(resultKeyEl.value);
    });
    document.getElementById('recoveryResultCloseBtn').addEventListener('click', () => { resultModal.style.display = 'none'; });
})();
</script>
}
