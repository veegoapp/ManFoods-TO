@model List<MvcApp.Models.ViewModels.UserViewModel>
@{
    ViewData["Title"] = "Users";
}

<div class="page-header">
    <div><h1 class="page-title">Users</h1><p class="page-subtitle">Manage system access and roles</p></div>
    <div class="d-flex flex-wrap gap-2">
        <a href="/admin/dashboard/download-template?type=bulk_users" class="btn btn-outline-template btn-sm">
            <i class="bi bi-file-earmark-arrow-down me-1"></i>Template: Bulk Users
        </a>
        <a href="/admin/dashboard/createuser" class="btn btn-primary btn-sm"><i class="bi bi-person-plus me-2"></i>New User</a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="card-dark h-100">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="card-icon"><i class="bi bi-people-fill"></i></div>
                <div><h6 class="mb-0">Bulk Upload Users</h6><p class="text-muted-custom mb-0 small">Excel with Email + Phone — created as pending "User" accounts, no password yet.</p></div>
            </div>
            <form asp-area="Admin" asp-controller="Dashboard" asp-action="UploadBulkUsers" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="mb-2"><input type="file" name="File" accept=".xlsx,.xls" class="form-control form-control-dark form-control-sm" required/></div>
                <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-cloud-upload me-1"></i>Upload Users</button>
            </form>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card-dark h-100">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="card-icon"><i class="bi bi-key-fill"></i></div>
                <div><h6 class="mb-0">Generate Bulk OTPs</h6><p class="text-muted-custom mb-0 small">Downloads Email + Phone + OTP for every pending user — send it yourself via bulk SMS. Already-activated users are skipped.</p></div>
            </div>
            <a href="/admin/dashboard/generatebulkotps" class="btn btn-primary btn-sm w-100"><i class="bi bi-file-earmark-arrow-down me-1"></i>Generate &amp; Download OTPs</a>
        </div>
    </div>
</div>

<div class="card-dark">
    @if (!Model.Any())
    {
        <div class="empty-state"><i class="bi bi-people"></i><p>No users yet</p></div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark-custom">
                <thead><tr><th>Email</th><th>Phone</th><th>Role</th><th>Status</th><th>Created</th><th class="text-end">Actions</th></tr></thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="fw-medium">@user.Email</td>
                            <td class="text-muted-custom">@user.Phone</td>
                            <td><span class="role-badge role-@user.Role.ToLower()">@user.Role</span></td>
                            <td>
                                @if (user.HasPassword)
                                {
                                    <span class="role-badge" style="background:var(--success-bg);color:var(--success)">Active</span>
                                }
                                else
                                {
                                    <span class="role-badge role-pending">Pending Activation</span>
                                }
                            </td>
                            <td class="text-muted-custom small">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-end">
                                @if (user.Role == "User")
                                {
                                    <button type="button" class="btn btn-sm btn-outline-secondary me-1 js-generate-otp" data-id="@user.Id" data-email="@user.Email" title="Generate OTP"><i class="bi bi-key"></i></button>
                                }
                                <a href="/admin/dashboard/edituser/@user.Id" class="btn btn-sm btn-outline-secondary me-1"><i class="bi bi-pencil"></i></a>
                                <form asp-area="Admin" asp-controller="Dashboard" asp-action="DeleteUser" method="post" class="d-inline" onsubmit="return confirm('Delete user @user.Email?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id"/>
                                    <button type="submit" class="btn btn-sm btn-danger-outline"><i class="bi bi-trash3"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div id="otpResultModal" style="display:none;position:fixed;inset:0;z-index:1100;background:rgba(0,0,0,.5);align-items:center;justify-content:center">
    <div class="card-dark" style="max-width:380px;width:90%">
        <h6 class="mb-2"><i class="bi bi-key-fill me-1"></i>OTP Generated</h6>
        <p class="text-muted-custom small mb-2" id="otpResultEmail"></p>
        <div class="d-flex align-items-center gap-2 mb-3">
            <input type="text" id="otpResultCode" class="form-control form-control-dark" readonly style="font-size:20px;letter-spacing:4px;text-align:center;font-weight:700"/>
            <button type="button" class="btn btn-outline-secondary btn-sm" id="otpCopyBtn" title="Copy"><i class="bi bi-clipboard"></i></button>
        </div>
        <p class="text-muted-custom small mb-3">Valid for 4 hours, single use. Send this to the user yourself.</p>
        <button type="button" class="btn btn-primary w-100" id="otpCloseBtn">Close</button>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const modal = document.getElementById('otpResultModal');
    const emailEl = document.getElementById('otpResultEmail');
    const codeEl = document.getElementById('otpResultCode');
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    document.querySelectorAll('.js-generate-otp').forEach(btn => {
        btn.addEventListener('click', async () => {
            btn.disabled = true;
            try {
                const res = await fetch(`/admin/dashboard/generateotp/${btn.dataset.id}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                });
                if (!res.ok) { alert('Failed to generate OTP.'); return; }
                const data = await res.json();
                emailEl.textContent = btn.dataset.email;
                codeEl.value = data.otp;
                modal.style.display = 'flex';
            } finally {
                btn.disabled = false;
            }
        });
    });

    document.getElementById('otpCopyBtn').addEventListener('click', () => {
        codeEl.select();
        navigator.clipboard.writeText(codeEl.value);
    });
    document.getElementById('otpCloseBtn').addEventListener('click', () => { modal.style.display = 'none'; });
})();
</script>
}
