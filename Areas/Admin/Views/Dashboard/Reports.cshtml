@model List<MvcApp.Models.ViewModels.PeriodItem>
@{
    ViewData["Title"] = L["Page_Reports"].Value;
    var months = new[] { "January","February","March","April","May","June","July","August","September","October","November","December" };
    var hasPeriods = Model != null && Model.Count > 0;
    var stores = (ViewBag.Stores as List<string>) ?? new List<string>();
    var operationManagers = (ViewBag.OperationManagers as List<string>) ?? new List<string>();
    var operationConsultants = (ViewBag.OperationConsultants as List<string>) ?? new List<string>();
}

<div class="page-header">
    <div>
        <h1 class="page-title">@L["Page_Reports"]</h1>
        <p class="page-subtitle">@L["Page_ReportsSub"]</p>
    </div>
</div>

@if (hasPeriods)
{
    <div class="card-dark mb-4" style="border-left:4px solid oklch(0.5 0.18 25)">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <div class="card-icon" style="background:oklch(0.5 0.18 25 / .12)"><i class="bi bi-file-earmark-zip-fill" style="color:oklch(0.5 0.18 25)"></i></div>
            <div class="flex-grow-1" style="min-width:220px">
                <h6 class="mb-0">@L["Rep_FullCompany"]</h6>
                <p class="text-muted-custom mb-0 small">@L["Rep_FullCompanyDesc"]</p>
            </div>
            <form method="get" action="/admin/dashboard/export" class="d-flex gap-2 align-items-center flex-wrap">
                <input type="hidden" name="reportType" value="full" />
                <select name="month" class="form-select form-select-dark form-select-sm" style="width:130px">
                    @for (int m = 1; m <= 12; m++)
                    {
                        var isSelected = Model!.LastOrDefault()?.Month == m;
                        <option value="@m" selected="@isSelected">@months[m-1]</option>
                    }
                </select>
                <select name="year" class="form-select form-select-dark form-select-sm" style="width:100px">
                    @foreach (var y in Model!.Select(p => p.Year).Distinct().OrderByDescending(y => y))
                    {
                        <option value="@y">@y</option>
                    }
                </select>
                <select name="store" class="form-select form-select-dark form-select-sm" style="width:170px">
                    <option value="">@L["Common_AllStores"]</option>
                    @foreach (var s in stores)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
                <button type="submit" class="btn btn-primary btn-sm text-nowrap"><i class="bi bi-download me-1"></i>@L["Common_Download"]</button>
            </form>
        </div>
    </div>
}

<h5 class="fw-bold mb-3 mt-2">@L["Rep_TurnoverWorkforce"]</h5>
@if (!hasPeriods)
{
    <div class="card-dark text-center py-4 mb-4">
        <i class="bi bi-file-earmark-bar-graph-fill" style="font-size:2.5rem;color:oklch(0.5 0.18 25);display:block;margin-bottom:.75rem"></i>
        <p class="text-muted-custom mb-0">@L["Rep_UploadFirst"]</p>
    </div>
}
else
{
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card-dark h-100">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="card-icon" style="background:rgba(39,174,96,.15)"><i class="bi bi-file-earmark-spreadsheet-fill" style="color:#27ae60"></i></div>
                    <div>
                        <h6 class="mb-0">@L["Rep_Summary"]</h6>
                        <p class="text-muted-custom mb-0 small">@L["Rep_SummaryDesc"]</p>
                    </div>
                </div>
                <form method="get" action="/admin/dashboard/export">
                    <input type="hidden" name="reportType" value="summary" />
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label small text-muted-custom">@L["Common_Month"]</label>
                            <select name="month" class="form-select form-select-dark form-select-sm">
                                @for (int m = 1; m <= 12; m++)
                                {
                                    var isSelected = Model!.LastOrDefault()?.Month == m;
                                    <option value="@m" selected="@isSelected">@months[m-1]</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small text-muted-custom">@L["Common_Year"]</label>
                            <select name="year" class="form-select form-select-dark form-select-sm">
                                @foreach (var y in Model!.Select(p => p.Year).Distinct().OrderByDescending(y => y))
                                {
                                    <option value="@y">@y</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label small text-muted-custom">@L["Common_StoreName"]</label>
                            <select name="store" class="form-select form-select-dark form-select-sm">
                                <option value="">@L["Common_AllStores"]</option>
                                @foreach (var s in stores)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success w-100 btn-sm">
                        <i class="bi bi-download me-2"></i>@L["Rep_DownloadSummaryExcel"]
                    </button>
                </form>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card-dark h-100">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="card-icon" style="background:oklch(0.5 0.18 25 / .12)"><i class="bi bi-shop-window" style="color:oklch(0.5 0.18 25)"></i></div>
                    <div>
                        <h6 class="mb-0">@L["Rep_StoreComparison"]</h6>
                        <p class="text-muted-custom mb-0 small">@L["Rep_StoreComparisonDesc"]</p>
                    </div>
                </div>
                <form method="get" action="/admin/dashboard/export">
                    <input type="hidden" name="reportType" value="stores" />
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label small text-muted-custom">@L["Common_Month"]</label>
                            <select name="month" class="form-select form-select-dark form-select-sm">
                                @for (int m = 1; m <= 12; m++)
                                {
                                    var isSelected = Model!.LastOrDefault()?.Month == m;
                                    <option value="@m" selected="@isSelected">@months[m-1]</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small text-muted-custom">@L["Common_Year"]</label>
                            <select name="year" class="form-select form-select-dark form-select-sm">
                                @foreach (var y in Model!.Select(p => p.Year).Distinct().OrderByDescending(y => y))
                                {
                                    <option value="@y">@y</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small text-muted-custom">@L["Common_OperationManager"]</label>
                            <select name="om" class="form-select form-select-dark form-select-sm">
                                <option value="">@L["Common_All"]</option>
                                @foreach (var name in operationManagers)
                                {
                                    <option value="@name">@name</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small text-muted-custom">@L["Common_OperationConsultant"]</label>
                            <select name="oc" class="form-select form-select-dark form-select-sm">
                                <option value="">@L["Common_All"]</option>
                                @foreach (var name in operationConsultants)
                                {
                                    <option value="@name">@name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-danger w-100 btn-sm">
                        <i class="bi bi-download me-2"></i>@L["Rep_DownloadStoreExcel"]
                    </button>
                </form>
            </div>
        </div>
    </div>
}

<h5 class="fw-bold mb-3">@L["Rep_DeepAnalytics"]</h5>
<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="card-dark h-100 d-flex flex-column">
            <div class="card-icon mb-2" style="background:oklch(0.5 0.18 25 / .12)"><i class="bi bi-hourglass-split" style="color:oklch(0.5 0.18 25)"></i></div>
            <h6 class="mb-1">@L["Rep_NinetyDay"]</h6>
            <p class="text-muted-custom mb-2 small flex-grow-1">@L["Rep_NinetyDayDesc"]</p>
            <form method="get" action="/admin/dashboard/export">
                <input type="hidden" name="reportType" value="ninety-day" />
                <select name="store" class="form-select form-select-dark form-select-sm mb-2">
                    <option value="">@L["Common_AllStores"]</option>
                    @foreach (var s in stores)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
                <button type="submit" class="btn btn-outline-secondary btn-sm w-100"><i class="bi bi-download me-2"></i>@L["Common_Download"]</button>
            </form>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card-dark h-100 d-flex flex-column">
            <div class="card-icon mb-2" style="background:oklch(0.75 0.15 85 / .15)"><i class="bi bi-graph-up-arrow" style="color:oklch(0.6 0.13 82)"></i></div>
            <h6 class="mb-1">@L["Rep_Retention"]</h6>
            <p class="text-muted-custom mb-2 small flex-grow-1">@L["Rep_RetentionDesc"]</p>
            <form method="get" action="/admin/dashboard/export">
                <input type="hidden" name="reportType" value="retention" />
                <select name="store" class="form-select form-select-dark form-select-sm mb-2">
                    <option value="">@L["Common_AllStores"]</option>
                    @foreach (var s in stores)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
                <button type="submit" class="btn btn-outline-secondary btn-sm w-100"><i class="bi bi-download me-2"></i>@L["Common_Download"]</button>
            </form>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card-dark h-100 d-flex flex-column">
            <div class="card-icon mb-2" style="background:oklch(0.5 0.18 25 / .12)"><i class="bi bi-award-fill" style="color:oklch(0.5 0.18 25)"></i></div>
            <h6 class="mb-1">@L["Rep_Scorecard"]</h6>
            <p class="text-muted-custom mb-2 small flex-grow-1">@L["Rep_ScorecardDesc"]</p>
            <form method="get" action="/admin/dashboard/export">
                <input type="hidden" name="reportType" value="scorecard" />
                <select name="om" class="form-select form-select-dark form-select-sm mb-2">
                    <option value="">@L["Common_AllOperationManagers"]</option>
                    @foreach (var name in operationManagers)
                    {
                        <option value="@name">@name</option>
                    }
                </select>
                <select name="oc" class="form-select form-select-dark form-select-sm mb-2">
                    <option value="">@L["Common_AllOperationConsultants"]</option>
                    @foreach (var name in operationConsultants)
                    {
                        <option value="@name">@name</option>
                    }
                </select>
                <button type="submit" class="btn btn-outline-secondary btn-sm w-100"><i class="bi bi-download me-2"></i>@L["Common_Download"]</button>
            </form>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card-dark h-100 d-flex flex-column">
            <div class="card-icon mb-2" style="background:oklch(0.6 0.22 22 / .12)"><i class="bi bi-exclamation-diamond-fill" style="color:oklch(0.6 0.22 22)"></i></div>
            <h6 class="mb-1">@L["Rep_EarlyWarning"]</h6>
            <p class="text-muted-custom mb-2 small flex-grow-1">@L["Rep_EarlyWarningDesc"]</p>
            <form method="get" action="/admin/dashboard/export">
                <input type="hidden" name="reportType" value="early-warning" />
                <select name="store" class="form-select form-select-dark form-select-sm mb-2">
                    <option value="">@L["Common_AllStores"]</option>
                    @foreach (var s in stores)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
                <button type="submit" class="btn btn-outline-secondary btn-sm w-100"><i class="bi bi-download me-2"></i>@L["Common_Download"]</button>
            </form>
        </div>
    </div>
</div>

<h5 class="fw-bold mb-3">@L["Rep_ExitInterviewsSection"]</h5>
<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-4">
        <div class="card-dark h-100 d-flex flex-column">
            <div class="card-icon mb-2" style="background:oklch(0.65 0.15 190 / .12)"><i class="bi bi-chat-square-text-fill" style="color:oklch(0.55 0.15 190)"></i></div>
            <h6 class="mb-1">@L["Rep_ExitInterview"]</h6>
            <p class="text-muted-custom mb-2 small flex-grow-1">@L["Rep_ExitInterviewDesc"]</p>
            <form method="get" action="/admin/dashboard/export">
                <input type="hidden" name="reportType" value="exit-interviews" />
                <div class="row g-2 mb-2">
                    <div class="col-12">
                        <select name="store" class="form-select form-select-dark form-select-sm">
                            <option value="">@L["Common_AllStores"]</option>
                            @foreach (var s in stores)
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                    <div class="col-6">
                        <select name="om" class="form-select form-select-dark form-select-sm">
                            <option value="">@L["Common_AllOperationManagers"]</option>
                            @foreach (var name in operationManagers)
                            {
                                <option value="@name">@name</option>
                            }
                        </select>
                    </div>
                    <div class="col-6">
                        <select name="oc" class="form-select form-select-dark form-select-sm">
                            <option value="">@L["Common_AllOperationConsultants"]</option>
                            @foreach (var name in operationConsultants)
                            {
                                <option value="@name">@name</option>
                            }
                        </select>
                    </div>
                </div>
                <button type="submit" class="btn btn-outline-secondary btn-sm w-100"><i class="bi bi-download me-2"></i>@L["Common_Download"]</button>
            </form>
        </div>
    </div>
</div>

@if (hasPeriods)
{
    <div class="card-dark">
        <h6 class="mb-3"><i class="bi bi-calendar3 me-2" style="color:oklch(0.5 0.18 25)"></i>@L["Rep_AvailablePeriods"]</h6>
        <div class="d-flex flex-wrap gap-2">
            @foreach (var p in Model!.OrderByDescending(x => x.Year).ThenByDescending(x => x.Month))
            {
                <span class="badge" style="background:oklch(0.5 0.18 25 / .12);color:oklch(0.5 0.18 25);border:1px solid oklch(0.5 0.18 25 / .3);padding:6px 12px;border-radius:6px;font-size:12px">
                    @months[p.Month - 1] @p.Year
                </span>
            }
        </div>
    </div>
}
