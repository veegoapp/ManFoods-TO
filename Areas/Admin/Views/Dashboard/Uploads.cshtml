@model List<MvcApp.Models.ViewModels.UploadHistoryItem>
@{
    ViewData["Title"] = L["Page_DataManagement"].Value;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var totalCount = (int)(ViewBag.TotalCount ?? 0);
}

<style>
.dm-select-wrap { position:relative; }
.dm-select {
    appearance:none; -webkit-appearance:none;
    background:var(--card-bg); border:1px solid var(--card-border); color:var(--text);
    border-radius:var(--radius-sm); font-size:13.5px; font-weight:600;
    height:42px; padding:0 34px 0 14px; min-width:130px;
    box-shadow:var(--shadow-sm); cursor:pointer;
}
.dm-select:focus { outline:none; border-color:var(--red); box-shadow:0 0 0 3px var(--red-light); }
.dm-select-wrap i { position:absolute; top:50%; right:12px; transform:translateY(-50%); font-size:11px; color:var(--text-3); pointer-events:none; }
[dir="rtl"] .dm-select { padding:0 14px 0 34px; }
[dir="rtl"] .dm-select-wrap i { right:auto; left:12px; }

.dm-template-btn {
    background:transparent; border:1px solid oklch(0.62 0.15 155 / .4); color:oklch(0.62 0.15 155);
    font-size:12px; font-weight:600; border-radius:8px; padding:7px 13px;
    text-decoration:none; display:inline-flex; align-items:center; gap:6px; transition:background .15s,color .15s;
}
.dm-template-btn:hover { background:oklch(0.62 0.15 155); color:#fff; }

.dm-requirement-banner {
    display:flex; align-items:flex-start; gap:10px;
    background:oklch(0.75 0.16 75 / .1); border:1px solid oklch(0.75 0.16 75 / .35);
    border-radius:var(--radius-sm); padding:12px 14px; font-size:13px; color:var(--text-2); margin-bottom:18px;
}
.dm-requirement-banner i { color:oklch(0.6 0.14 75); font-size:16px; margin-top:1px; flex-shrink:0; }

.dm-dropzone-grid { display:grid; grid-template-columns:repeat(3, 1fr); gap:16px; margin-bottom:16px; }
@@media (max-width: 900px) { .dm-dropzone-grid { grid-template-columns:1fr; } }

.dm-dropzone {
    position:relative; border:2px dashed var(--card-border); border-radius:var(--radius-sm);
    padding:20px 14px; text-align:center; cursor:pointer; transition:border-color .15s, background .15s;
    background:var(--bg-2);
}
.dm-dropzone:hover, .dm-dropzone.dragover { border-color:oklch(0.55 0.19 25); background:var(--red-light); }
.dm-dropzone.has-file { border-style:solid; border-color:oklch(0.62 0.15 155); background:oklch(0.62 0.15 155 / .06); }
.dm-dropzone input[type="file"] { position:absolute; inset:0; opacity:0; cursor:pointer; }
.dm-dropzone-icon { font-size:26px; color:var(--text-3); margin-bottom:8px; display:block; }
.dm-dropzone.has-file .dm-dropzone-icon { color:oklch(0.62 0.15 155); }
.dm-dropzone-title { font-weight:700; font-size:13.5px; color:var(--text); margin-bottom:2px; }
.dm-dropzone-sub { font-size:11.5px; color:var(--text-3); margin-bottom:10px; }
.dm-dropzone-hint { font-size:12px; color:var(--text-3); }
.dm-dropzone-filename { font-size:12.5px; font-weight:600; color:oklch(0.55 0.15 155); word-break:break-all; }
.dm-dropzone-change { font-size:11px; color:var(--text-3); margin-top:2px; }

.dm-form-error {
    display:none; background:oklch(0.6 0.22 22 / .08); border:1px solid oklch(0.6 0.22 22 / .35); color:oklch(0.55 0.2 22);
    border-radius:var(--radius-sm); padding:10px 14px; font-size:13px; margin-bottom:14px;
}

.dm-btn-submit {
    background:oklch(0.5 0.18 25); color:#fff; border:none; border-radius:var(--radius-sm);
    font-weight:700; font-size:13.5px; padding:11px 20px; cursor:pointer; transition:background .15s;
}
.dm-btn-submit:hover { background:oklch(0.45 0.18 25); }

.dm-history-badge { font-size:11px; font-weight:700; padding:3px 10px; border-radius:12px; }
.dm-history-badge.period { background:oklch(0.55 0.19 25 / .12); color:oklch(0.5 0.18 25); }
.dm-history-badge.exit { background:oklch(0.65 0.15 190 / .12); color:oklch(0.5 0.15 190); }

.dm-file-chip {
    display:inline-flex; align-items:center; gap:5px; font-size:11.5px; padding:3px 9px; border-radius:10px;
    background:var(--bg-2); color:var(--text-2); text-decoration:none; margin:2px 3px 2px 0;
}
.dm-file-chip:hover { background:oklch(0.62 0.15 155 / .12); color:oklch(0.55 0.15 155); }
.dm-file-chip i { font-size:11px; }
.dm-file-chip.disabled { opacity:.5; pointer-events:none; }

.dm-action-btn {
    display:inline-flex; align-items:center; gap:5px; font-size:12px; font-weight:600; border-radius:7px;
    padding:6px 12px; cursor:pointer; border:1px solid var(--card-border); background:var(--card-bg); color:var(--text-2);
}
.dm-action-btn.download:hover { border-color:oklch(0.62 0.15 155); color:oklch(0.55 0.15 155); background:oklch(0.62 0.15 155 / .08); }
.dm-action-btn.delete:hover { border-color:oklch(0.6 0.22 22); color:oklch(0.55 0.2 22); background:oklch(0.6 0.22 22 / .08); }

.page-link-dm { background:var(--card-bg); border-color:var(--card-border); color:var(--text-2); border-radius:6px !important; }
.page-link-dm:hover { background:var(--bg-2); color:var(--text); }
.page-item.active .page-link-dm { background:oklch(0.5 0.18 25); border-color:oklch(0.5 0.18 25); color:#fff; }
</style>

<div class="page-header d-flex align-items-center justify-content-between flex-wrap gap-3">
    <div>
        <h1 class="page-title">@L["Page_DataManagement"]</h1>
        <p class="page-subtitle">@L["Page_DataManagementSub"]</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a href="/admin/dashboard/download-template?type=active_employees" class="dm-template-btn"><i class="bi bi-file-earmark-arrow-down"></i>@L["UL_TemplateActiveEmployees"]</a>
        <a href="/admin/dashboard/download-template?type=resignations" class="dm-template-btn"><i class="bi bi-file-earmark-arrow-down"></i>@L["UL_TemplateResignations"]</a>
        <a href="/admin/dashboard/download-template?type=store_reference" class="dm-template-btn"><i class="bi bi-file-earmark-arrow-down"></i>@L["UL_TemplateStoreRef"]</a>
        <a href="/admin/dashboard/download-template?type=exit_interviews" class="dm-template-btn"><i class="bi bi-file-earmark-arrow-down"></i>@L["UL_SampleExitInterviews"]</a>
    </div>
</div>

<div class="chart-card mb-4">
    <div class="chart-header">
        <h6>@L["DM_MonthlyData"]</h6>
        <p>@L["DM_MonthlyDataSub"]</p>
    </div>

    <div class="dm-requirement-banner">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>@L["DM_MonthlyDataRequirement"]</span>
    </div>

    <form id="dmPeriodForm" asp-area="Admin" asp-controller="Dashboard" asp-action="UploadPeriodData" method="post" enctype="multipart/form-data"
          data-change-label="@L["DM_ChangeFile"]" data-requirement-text="@L["DM_MonthlyDataRequirement"]">
        @Html.AntiForgeryToken()
        <div class="d-flex gap-2 mb-3">
            <div class="dm-select-wrap">
                <select name="Month" class="dm-select" required>
                    <option value="">@L["Common_Month"]</option>
                    @for (int m = 1; m <= 12; m++) { <option value="@m">@(new DateTime(2000, m, 1).ToString("MMMM"))</option> }
                </select>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div class="dm-select-wrap">
                <select name="Year" class="dm-select" required>
                    <option value="">@L["Common_Year"]</option>
                    @for (int y = DateTime.Now.Year + 1; y >= 2022; y--) { <option value="@y">@y</option> }
                </select>
                <i class="bi bi-chevron-down"></i>
            </div>
        </div>

        <div id="dmFormError" class="dm-form-error"></div>

        <div class="dm-dropzone-grid">
            <div class="dm-dropzone" id="dmZone1" data-title="@L["UL_ActiveEmployees"]" data-sub="@L["UL_ActiveEmployeesSub"]">
                <i class="bi bi-people-fill dm-dropzone-icon"></i>
                <div class="dm-dropzone-title">@L["UL_ActiveEmployees"]</div>
                <div class="dm-dropzone-sub">@L["UL_ActiveEmployeesSub"]</div>
                <div class="dm-dropzone-hint" data-role="hint">@L["DM_DropzoneHint"]</div>
                <input type="file" name="ActiveEmployeesFile" accept=".xlsx,.xls">
            </div>
            <div class="dm-dropzone" id="dmZone2" data-title="@L["UL_Resignations"]" data-sub="@L["UL_ResignationsSub"]">
                <i class="bi bi-person-dash-fill dm-dropzone-icon"></i>
                <div class="dm-dropzone-title">@L["UL_Resignations"]</div>
                <div class="dm-dropzone-sub">@L["UL_ResignationsSub"]</div>
                <div class="dm-dropzone-hint" data-role="hint">@L["DM_DropzoneHint"]</div>
                <input type="file" name="ResignationsFile" accept=".xlsx,.xls">
            </div>
            <div class="dm-dropzone" id="dmZone3" data-title="@L["UL_StoreReference"]" data-sub="@L["UL_StoreReferenceSub"]">
                <i class="bi bi-shop dm-dropzone-icon"></i>
                <div class="dm-dropzone-title">@L["UL_StoreReference"]</div>
                <div class="dm-dropzone-sub">@L["UL_StoreReferenceSub"]</div>
                <div class="dm-dropzone-hint" data-role="hint">@L["DM_DropzoneHint"]</div>
                <input type="file" name="StoreReferenceFile" accept=".xlsx,.xls">
            </div>
        </div>

        <button type="submit" class="dm-btn-submit"><i class="bi bi-cloud-upload me-1"></i>@L["DM_UploadMonthlyButton"]</button>
    </form>
</div>

<div class="chart-card mb-4">
    <div class="chart-header">
        <h6>@L["UL_ExitInterviews"]</h6>
        <p>@L["UL_ExitInterviewsSub"]</p>
    </div>
    <div class="dm-requirement-banner">
        <i class="bi bi-info-circle-fill"></i>
        <span>@L["UL_ExitInterviewsNote"]</span>
    </div>
    <form asp-area="Admin" asp-controller="Dashboard" asp-action="UploadExitInterviews" method="post" enctype="multipart/form-data" data-change-label="@L["DM_ChangeFile"]">
        @Html.AntiForgeryToken()
        <div class="dm-dropzone-grid" style="grid-template-columns:1fr;max-width:360px">
            <div class="dm-dropzone" id="dmZoneExit" data-title="@L["UL_ExitInterviews"]">
                <i class="bi bi-chat-square-text-fill dm-dropzone-icon"></i>
                <div class="dm-dropzone-title">@L["UL_ExitInterviews"]</div>
                <div class="dm-dropzone-hint" data-role="hint">@L["DM_DropzoneHint"]</div>
                <input type="file" name="File" accept=".xlsx,.xls" required>
            </div>
        </div>
        <button type="submit" class="dm-btn-submit"><i class="bi bi-cloud-upload me-1"></i>@L["DM_UploadExitInterviewsButton"]</button>
    </form>
</div>

<div class="chart-card p-0" style="overflow:hidden">
    <div class="chart-header px-4 pt-4 d-flex align-items-center justify-content-between">
        <h6 class="mb-0">@L["DM_History"]</h6>
        <a href="/admin/dashboard/download-upload-history" class="dm-action-btn download">
            <i class="bi bi-file-earmark-arrow-down"></i>@L["DM_DownloadHistory"]
        </a>
    </div>
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px;color:var(--text-3)"></i>
            @L["DM_NoUploads"]
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0" style="font-size:13px">
                <thead style="background:var(--bg-2)">
                    <tr>
                        <th class="px-3 py-2">@L["Upload_FileType"]</th>
                        <th class="px-3 py-2">@L["Upload_FileName"]</th>
                        <th class="px-3 py-2">@L["Upload_Period"]</th>
                        <th class="px-3 py-2">@L["Upload_UploadedBy"]</th>
                        <th class="px-3 py-2">@L["Upload_Date"]</th>
                        <th class="px-3 py-2"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var isPeriod = item.Kind == "period";
                        <tr>
                            <td class="px-3 py-2">
                                <span class="dm-history-badge @(isPeriod ? "period" : "exit")">@(isPeriod ? L["DM_MonthlyDataBadge"] : L["DM_ExitInterviewsBadge"])</span>
                            </td>
                            <td class="px-3 py-2">
                                @foreach (var f in item.Files)
                                {
                                    if (f.HasFile)
                                    {
                                        <a class="dm-file-chip" asp-area="Admin" asp-controller="Dashboard" asp-action="DownloadUploadFile" asp-route-id="@f.LogId" title="@f.FileName">
                                            <i class="bi bi-download"></i>@f.FileName
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="dm-file-chip disabled" title="@f.FileName"><i class="bi bi-file-earmark"></i>@f.FileName</span>
                                    }
                                }
                            </td>
                            <td class="px-3 py-2 text-muted-custom">
                                @(isPeriod ? new DateTime(item.Year!.Value, item.Month!.Value, 1).ToString("MMMM yyyy") : "—")
                            </td>
                            <td class="px-3 py-2 text-muted-custom">@item.UploadedBy</td>
                            <td class="px-3 py-2 text-muted-custom small">@item.UploadDate.ToString("MMM dd, yyyy HH:mm")</td>
                            <td class="px-3 py-2">
                                <div class="d-flex gap-2">
                                    <form asp-area="Admin" asp-controller="Dashboard" asp-action="DeleteUploadLog" method="post"
                                          onsubmit="return confirm('@(isPeriod ? L["DM_DeleteConfirmPeriod"].Value : L["DM_DeleteConfirmExit"].Value)')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.PrimaryLogId"/>
                                        <button type="submit" class="dm-action-btn delete"><i class="bi bi-trash3"></i>@L["DM_Delete"]</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        if (totalPages > 1)
        {
            <div class="d-flex align-items-center justify-content-between px-4 py-3" style="border-top:1px solid var(--card-border)">
                <span class="text-muted-custom small">@string.Format(L["DM_PageSummary"].Value, currentPage, totalPages, totalCount)</span>
                <nav>
                    <ul class="pagination pagination-sm mb-0" style="gap:4px">
                        @if (currentPage > 1)
                        {
                            <li class="page-item"><a class="page-link page-link-dm" href="?page=@(currentPage - 1)"><i class="bi bi-chevron-left"></i></a></li>
                        }
                        @for (int p = Math.Max(1, currentPage - 2); p <= Math.Min(totalPages, currentPage + 2); p++)
                        {
                            <li class="page-item @(p == currentPage ? "active" : "")"><a class="page-link page-link-dm" href="?page=@p">@p</a></li>
                        }
                        @if (currentPage < totalPages)
                        {
                            <li class="page-item"><a class="page-link page-link-dm" href="?page=@(currentPage + 1)"><i class="bi bi-chevron-right"></i></a></li>
                        }
                    </ul>
                </nav>
            </div>
        }
    }
</div>

@section Scripts {
<script>
/* Custom dropzone: click-to-browse + drag-and-drop, shows the chosen filename
   in-place instead of the browser's plain "No file chosen" text. */
function dmSetupDropzone(zoneId) {
    const zone = document.getElementById(zoneId);
    if (!zone) return;
    const input = zone.querySelector('input[type="file"]');
    const hint = zone.querySelector('[data-role="hint"]');
    const defaultHint = hint.textContent;
    const changeLabel = zone.closest('form').dataset.changeLabel;

    function render() {
        if (input.files && input.files.length > 0) {
            zone.classList.add('has-file');
            hint.innerHTML = `<div class="dm-dropzone-filename">${input.files[0].name}</div><div class="dm-dropzone-change">${changeLabel}</div>`;
        } else {
            zone.classList.remove('has-file');
            hint.textContent = defaultHint;
        }
    }

    input.addEventListener('change', render);
    zone.addEventListener('dragover', (e) => { e.preventDefault(); zone.classList.add('dragover'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('dragover'));
    zone.addEventListener('drop', (e) => {
        e.preventDefault();
        zone.classList.remove('dragover');
        if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
            input.files = e.dataTransfer.files;
            render();
        }
    });
}

['dmZone1', 'dmZone2', 'dmZone3', 'dmZoneExit'].forEach(dmSetupDropzone);

document.getElementById('dmPeriodForm').addEventListener('submit', function (e) {
    const inputs = this.querySelectorAll('input[type="file"]');
    const missing = Array.from(inputs).some(i => !i.files || i.files.length === 0);
    const errorEl = document.getElementById('dmFormError');
    if (missing) {
        e.preventDefault();
        errorEl.textContent = this.dataset.requirementText;
        errorEl.style.display = 'block';
    } else {
        errorEl.style.display = 'none';
    }
});
</script>
}
