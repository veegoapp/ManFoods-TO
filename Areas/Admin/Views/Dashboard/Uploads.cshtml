@model List<MvcApp.Models.UploadLog>
@{
    ViewData["Title"] = "Data Management";
}

<div class="page-header d-flex align-items-center justify-content-between flex-wrap gap-3">
    <div>
        <h1 class="page-title">Data Management</h1>
        <p class="page-subtitle">Upload monthly Excel files to import workforce data</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a href="/admin/dashboard/download-template?type=active_employees" class="btn btn-outline-template btn-sm">
            <i class="bi bi-file-earmark-arrow-down me-1"></i>Template: Active Employees
        </a>
        <a href="/admin/dashboard/download-template?type=resignations" class="btn btn-outline-template btn-sm">
            <i class="bi bi-file-earmark-arrow-down me-1"></i>Template: Resignations
        </a>
        <a href="/admin/dashboard/download-template?type=store_reference" class="btn btn-outline-template btn-sm">
            <i class="bi bi-file-earmark-arrow-down me-1"></i>Template: Store Reference
        </a>
        <a href="/admin/dashboard/download-template?type=exit_interviews" class="btn btn-outline-template btn-sm">
            <i class="bi bi-file-earmark-arrow-down me-1"></i>Sample: Exit Interviews
        </a>
    </div>
</div>

<style>
    .btn-outline-template {
        background: transparent;
        border: 1px solid oklch(0.62 0.15 155);
        color: oklch(0.62 0.15 155);
        font-size: 12px;
        border-radius: 7px;
        padding: 6px 12px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: background .15s, color .15s;
    }
    .btn-outline-template:hover {
        background: oklch(0.62 0.15 155);
        color: #fff;
    }
    .btn-download-outline {
        background: transparent; border: 1px solid oklch(0.5 0.18 25 / .3); color: oklch(0.62 0.15 155);
        border-radius: 8px; padding: 6px 12px;
        cursor: pointer; transition: all .2s;
        font-weight: 600; font-size: 13px; min-height: 34px;
        display: inline-flex; align-items: center; gap: 4px;
        text-decoration: none;
    }
    .btn-download-outline:hover { background: rgba(39,174,96,.15); border-color: oklch(0.62 0.15 155); color: oklch(0.62 0.15 155); }
</style>

<div class="row g-4 mb-4">
    <div class="col-xl-3 col-lg-6">
        <div class="card-dark">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="card-icon"><i class="bi bi-people-fill"></i></div>
                <div><h6 class="mb-0">Active Employees</h6><p class="text-muted-custom mb-0 small">Upload active employees for a given month.</p></div>
            </div>
            <form asp-area="Admin" asp-controller="Dashboard" asp-action="UploadActiveEmployees" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="row g-2 mb-2">
                    <div class="col-6"><select name="Month" class="form-select form-select-dark form-select-sm" required><option value="">Month</option>@for(int m=1;m<=12;m++){<option value="@m">@(new DateTime(2000,m,1).ToString("MMMM"))</option>}</select></div>
                    <div class="col-6"><select name="Year" class="form-select form-select-dark form-select-sm" required><option value="">Year</option>@for(int y=DateTime.Now.Year;y>=2022;y--){<option value="@y">@y</option>}</select></div>
                </div>
                <div class="mb-2"><input type="file" name="File" accept=".xlsx,.xls" class="form-control form-control-dark form-control-sm" required/></div>
                <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-cloud-upload me-1"></i>Upload Active Employees</button>
            </form>
        </div>
    </div>
    <div class="col-xl-3 col-lg-6">
        <div class="card-dark">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="card-icon"><i class="bi bi-person-dash-fill"></i></div>
                <div><h6 class="mb-0">Resignations</h6><p class="text-muted-custom mb-0 small">Upload resignation records for a given month.</p></div>
            </div>
            <form asp-area="Admin" asp-controller="Dashboard" asp-action="UploadResignations" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="row g-2 mb-2">
                    <div class="col-6"><select name="Month" class="form-select form-select-dark form-select-sm" required><option value="">Month</option>@for(int m=1;m<=12;m++){<option value="@m">@(new DateTime(2000,m,1).ToString("MMMM"))</option>}</select></div>
                    <div class="col-6"><select name="Year" class="form-select form-select-dark form-select-sm" required><option value="">Year</option>@for(int y=DateTime.Now.Year;y>=2022;y--){<option value="@y">@y</option>}</select></div>
                </div>
                <div class="mb-2"><input type="file" name="File" accept=".xlsx,.xls" class="form-control form-control-dark form-control-sm" required/></div>
                <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-cloud-upload me-1"></i>Upload Resignations</button>
            </form>
        </div>
    </div>
    <div class="col-xl-3 col-lg-6">
        <div class="card-dark">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="card-icon"><i class="bi bi-shop"></i></div>
                <div><h6 class="mb-0">Store Reference</h6><p class="text-muted-custom mb-0 small">Upload store reference with assignments.</p></div>
            </div>
            <form asp-area="Admin" asp-controller="Dashboard" asp-action="UploadStoreReference" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="row g-2 mb-2">
                    <div class="col-6"><select name="Month" class="form-select form-select-dark form-select-sm" required><option value="">Month</option>@for(int m=1;m<=12;m++){<option value="@m">@(new DateTime(2000,m,1).ToString("MMMM"))</option>}</select></div>
                    <div class="col-6"><select name="Year" class="form-select form-select-dark form-select-sm" required><option value="">Year</option>@for(int y=DateTime.Now.Year;y>=2022;y--){<option value="@y">@y</option>}</select></div>
                </div>
                <div class="mb-2"><input type="file" name="File" accept=".xlsx,.xls" class="form-control form-control-dark form-control-sm" required/></div>
                <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-cloud-upload me-1"></i>Upload Store Reference</button>
            </form>
        </div>
    </div>
    <div class="col-xl-3 col-lg-6">
        <div class="card-dark">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="card-icon"><i class="bi bi-chat-square-text-fill"></i></div>
                <div><h6 class="mb-0">Exit Interviews</h6><p class="text-muted-custom mb-0 small">Export responses from Microsoft Forms and upload as-is — no reformatting needed.</p></div>
            </div>
            <form asp-area="Admin" asp-controller="Dashboard" asp-action="UploadExitInterviews" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="mb-2"><input type="file" name="File" accept=".xlsx,.xls" class="form-control form-control-dark form-control-sm" required/></div>
                <div class="mb-2" style="font-size:11px;color:var(--text-3)">Re-uploading the full export is safe — existing responses are matched and updated, never duplicated.</div>
                <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-cloud-upload me-1"></i>Upload Exit Interviews</button>
            </form>
        </div>
    </div>
</div>

<div class="card-dark">
    <h6 class="mb-3"><i class="bi bi-clock-history me-2"></i>Upload History</h6>
    @{
        var currentPage = (int)(ViewBag.CurrentPage ?? 1);
        var totalPages = (int)(ViewBag.TotalPages ?? 1);
        var totalCount = (int)(ViewBag.TotalCount ?? 0);
    }
    @if (!Model.Any())
    {
        <div class="empty-state"><i class="bi bi-inbox"></i><p>No uploads yet</p></div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark-custom">
                <thead><tr><th>File Type</th><th>File Name</th><th>Period</th><th>Uploaded By</th><th>Date</th><th></th></tr></thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td><span class="badge-type">@log.FileType.Replace("_"," ")</span></td>
                            <td class="text-muted-custom small">@log.FileName</td>
                            <td>@(new DateTime(log.Year,log.Month,1).ToString("MMMM yyyy"))</td>
                            <td class="text-muted-custom">@log.UploadedBy</td>
                            <td class="text-muted-custom small">@log.UploadDate.ToString("MMM dd, yyyy HH:mm")</td>
                            <td class="d-flex gap-2">
                                @if (log.HasFile)
                                {
                                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="DownloadUploadFile" asp-route-id="@log.Id" class="btn-download-outline" title="Download original file"><i class="bi bi-download"></i></a>
                                }
                                <form asp-area="Admin" asp-controller="Dashboard" asp-action="DeleteUploadLog" method="post" onsubmit="return confirm('Delete this upload and all associated data?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@log.Id"/>
                                    <button type="submit" class="btn-danger-outline"><i class="bi bi-trash3"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <div class="d-flex align-items-center justify-content-between mt-3">
                <span class="text-muted-custom small">Showing page @currentPage of @totalPages (@totalCount total)</span>
                <nav>
                    <ul class="pagination pagination-sm mb-0" style="gap:4px">
                        @if (currentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link page-link-dark" href="?page=@(currentPage-1)"><i class="bi bi-chevron-left"></i></a>
                            </li>
                        }
                        @for (int p = Math.Max(1, currentPage - 2); p <= Math.Min(totalPages, currentPage + 2); p++)
                        {
                            <li class="page-item @(p == currentPage ? "active" : "")">
                                <a class="page-link page-link-dark" href="?page=@p">@p</a>
                            </li>
                        }
                        @if (currentPage < totalPages)
                        {
                            <li class="page-item">
                                <a class="page-link page-link-dark" href="?page=@(currentPage+1)"><i class="bi bi-chevron-right"></i></a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    }
</div>

<style>
    .page-link-dark { background: var(--card-bg); border-color: var(--card-border); color: var(--text-2); border-radius: 6px !important; }
    .page-link-dark:hover { background: var(--bg-2); color: var(--text); }
    .page-item.active .page-link-dark { background: oklch(0.5 0.18 25); border-color: oklch(0.5 0.18 25); color: #fff; }
</style>
