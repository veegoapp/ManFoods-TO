@{
    ViewData["Title"] = L["Page_Retention"].Value;
}

<div class="page-header">
    <div>
        <h1 class="page-title">@L["Page_Retention"]</h1>
        <p class="page-subtitle">@L["Page_RetentionSub"]</p>
    </div>
    <div class="d-flex gap-2 flex-wrap align-items-center">
        <span class="text-muted" style="font-size:12px">@L["Common_From"]</span>
        <select id="rtFromPeriodSelect" class="form-select form-select-dark form-select-sm" style="width:150px">
            <option value="">@L["Common_HireMonth"]</option>
        </select>
        <span class="text-muted" style="font-size:12px">@L["Common_To"]</span>
        <select id="rtToPeriodSelect" class="form-select form-select-dark form-select-sm" style="width:150px">
            <option value="">@L["Common_HireMonth"]</option>
        </select>
        <select id="rtStoreSelect" class="form-select form-select-dark form-select-sm" style="width:180px">
            <option value="">@L["Common_AllStores"]</option>
        </select>
        <select id="rtOmSelect" class="form-select form-select-dark form-select-sm" style="width:190px">
            <option value="">@L["Common_AllOperationManagers"]</option>
        </select>
        <select id="rtOcSelect" class="form-select form-select-dark form-select-sm" style="width:190px">
            <option value="">@L["Common_AllOperationConsultants"]</option>
        </select>
    </div>
</div>

<div id="rtEmptyState" class="card-dark text-center py-5" style="display:none">
    <i class="bi bi-shield-check" style="font-size:3rem;color:oklch(0.5 0.18 25);display:block;margin-bottom:1rem"></i>
    <h5 class="mb-2">No Retention Data Yet</h5>
    <p class="text-muted-custom">Upload workforce and resignation data with hire dates to see retention analysis here.</p>
</div>

<div id="rtContent">
    <div class="d-flex align-items-center gap-2 mb-3">
        <i class="bi bi-lightbulb-fill" style="color:oklch(0.75 0.16 75)"></i>
        <h5 class="mb-0 fw-bold">@L["Common_SmartInsights"]</h5>
        <span class="badge ms-1" style="background:var(--bg-2);color:var(--text-2);font-size:11px">@L["Common_AutoGenerated"]</span>
    </div>
    <div class="chart-card mb-4" id="rtInsightsCard">
        <div id="rtInsights">
            <div class="text-center py-3 text-muted">
                <div class="spinner-border spinner-border-sm me-2" style="color:oklch(0.5 0.18 25)"></div>Loading...
            </div>
        </div>
    </div>

    <div id="rtMilestoneCards" class="kpi-grid mb-4">
        <div class="kpi-spinner text-center py-3 w-100">
            <div class="spinner-border spinner-border-sm" style="color:oklch(0.5 0.18 25)"></div>
        </div>
    </div>

    <div class="chart-card mb-4">
        <div class="chart-header">
            <h6>@L["Chart_SurvivalCurve"]</h6>
            <p>@L["Chart_SurvivalCurveSub"]</p>
        </div>
        <div class="chart-body"><canvas id="rtSurvivalChart" style="max-height:280px"></canvas></div>
    </div>

    <div class="chart-card mb-4">
        <div class="chart-header">
            <h6>@L["Chart_RetentionTrend"]</h6>
            <p>@L["Chart_RetentionTrendSub"]</p>
        </div>
        <div class="chart-body"><canvas id="rtTrendChart" style="max-height:280px"></canvas></div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-6">
            <div class="chart-card h-100">
                <div class="chart-header"><h6>Store Leaderboard</h6><p>180-day retention rate, best first</p></div>
                <div class="chart-body"><canvas id="rtLeaderboardChart"></canvas></div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="chart-card h-100">
                <div class="chart-header"><h6>Workforce Tenure Distribution</h6><p>How long today's active employees have been here</p></div>
                <div class="chart-body"><canvas id="rtTenureChart"></canvas></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
const _L = {
    allStores: '@L["Common_AllStores"]',
    hireMonth: '@L["Common_HireMonth"]',
    allOperationManagers: '@L["Common_AllOperationManagers"]',
    allOperationConsultants: '@L["Common_AllOperationConsultants"]'
};
function rtMonthName(m, y) {
    return new Date(y, m - 1).toLocaleString('default', { month: 'long', year: 'numeric' });
}

async function rtFetch(path) {
    const p = new URLSearchParams();
    const store = document.getElementById('rtStoreSelect').value;
    if (store) p.set('store', store);
    const fromVal = document.getElementById('rtFromPeriodSelect').value;
    const toVal   = document.getElementById('rtToPeriodSelect').value;
    if (fromVal && toVal) {
        const [fm, fy] = fromVal.split('-'); p.set('fromMonth', fm); p.set('fromYear', fy);
        const [tm, ty] = toVal.split('-');   p.set('toMonth', tm);   p.set('toYear', ty);
    }
    const om = document.getElementById('rtOmSelect').value;
    if (om) p.set('om', om);
    const oc = document.getElementById('rtOcSelect').value;
    if (oc) p.set('oc', oc);
    const r = await fetch(`/api/retention/${path}?${p.toString()}`);
    return r.ok ? r.json() : null;
}

async function rtLoadFilters() {
    const [stores, periods, managers, consultants] = await Promise.all([
        rtFetch('stores'),
        fetch('/api/dashboard/available-periods').then(r => r.ok ? r.json() : []),
        fetch('/api/retention/operation-managers').then(r => r.ok ? r.json() : []),
        fetch('/api/retention/operation-consultants').then(r => r.ok ? r.json() : []),
    ]);

    const sel = document.getElementById('rtStoreSelect');
    const cur = sel.value;
    sel.innerHTML = `<option value="">${_L.allStores}</option>`;
    (stores || []).forEach(s => {
        const opt = document.createElement('option');
        opt.value = s; opt.textContent = s;
        sel.appendChild(opt);
    });
    if (cur) sel.value = cur;

    const fromSel = document.getElementById('rtFromPeriodSelect');
    const toSel   = document.getElementById('rtToPeriodSelect');
    const sortedPeriods = (periods || []).slice().sort((a, b) => (a.year - b.year) || (a.month - b.month));
    [fromSel, toSel].forEach(s => { s.innerHTML = `<option value="">${_L.hireMonth}</option>`; });
    sortedPeriods.forEach(p => {
        [fromSel, toSel].forEach(s => {
            const opt = document.createElement('option');
            opt.value = `${p.month}-${p.year}`;
            opt.textContent = rtMonthName(p.month, p.year);
            s.appendChild(opt);
        });
    });
    if (sortedPeriods.length) {
        fromSel.value = `${sortedPeriods[0].month}-${sortedPeriods[0].year}`;
        const last = sortedPeriods[sortedPeriods.length - 1];
        toSel.value = `${last.month}-${last.year}`;
    }

    const omSel = document.getElementById('rtOmSelect');
    omSel.innerHTML = `<option value="">${_L.allOperationManagers}</option>`;
    (managers || []).forEach(name => {
        const opt = document.createElement('option');
        opt.value = name; opt.textContent = name;
        omSel.appendChild(opt);
    });

    const ocSel = document.getElementById('rtOcSelect');
    ocSel.innerHTML = `<option value="">${_L.allOperationConsultants}</option>`;
    (consultants || []).forEach(name => {
        const opt = document.createElement('option');
        opt.value = name; opt.textContent = name;
        ocSel.appendChild(opt);
    });

    const hasData = (stores || []).length > 0;
    document.getElementById('rtEmptyState').style.display = hasData ? 'none' : '';
    document.getElementById('rtContent').style.display = hasData ? '' : 'none';
    return hasData;
}

function rtRenderMilestones(items, targets) {
    const el = document.getElementById('rtMilestoneCards');
    if (!items || !items.length) { el.innerHTML = ''; return; }
    el.innerHTML = items.map(m => {
        if (!m.totalHires) {
            return `<div class="kpi-card"><div class="kpi-icon"><i class="bi bi-hourglass"></i></div><div class="kpi-value text-muted" style="font-size:16px">Not yet</div><div class="kpi-label">${m.days}-Day Retention</div></div>`;
        }
        let targetLine = '';
        if (m.days === 90 && targets && targets.retention90Target != null) {
            const diff = m.retentionRate - targets.retention90Target;
            const color = diff >= 0 ? '#198754' : '#dc3545';
            const sign = diff > 0 ? '+' : '';
            targetLine = `<div style="font-size:11px;color:${color}">${sign}${diff.toFixed(1)}pt vs target ${targets.retention90Target.toFixed(1)}%</div>`;
        }
        return `<div class="kpi-card">
            <div class="kpi-icon"><i class="bi bi-calendar-check"></i></div>
            <div class="kpi-value">${m.retentionRate.toFixed(1)}%</div>
            <div class="kpi-label">${m.days}-Day Retention</div>
            <div style="font-size:11px;color:var(--text-3);margin-top:2px">${m.retained}/${m.totalHires} hires · through ${m.throughCohortLabel}</div>
            ${targetLine}
        </div>`;
    }).join('');
}

async function rtLoadMilestones() {
    const [items, targets] = await Promise.all([rtFetch('milestones'), fetch('/api/targets').then(r => r.ok ? r.json() : null)]);
    rtRenderMilestones(items, targets);
}

let rtSurvivalInstance;
async function rtLoadSurvivalCurve() {
    const data = await rtFetch('survival-curve') || [];
    const ctx = document.getElementById('rtSurvivalChart');
    if (!ctx) return;
    if (rtSurvivalInstance) rtSurvivalInstance.destroy();
    rtSurvivalInstance = new Chart(ctx, {
        type: 'line',
        data: {
            labels: data.map(d => `Day ${d.day}`),
            datasets: [{
                label: 'Retained',
                data: data.map(d => d.retentionRate),
                borderColor: 'oklch(0.55 0.19 25)',
                backgroundColor: 'oklch(0.55 0.19 25 / .15)',
                tension: 0.3, fill: true, pointRadius: 4, spanGaps: true
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false },
                tooltip: { callbacks: { afterLabel: c => `Sample: ${data[c.dataIndex]?.sampleSize ?? 0} hires` } }
            },
            scales: {
                x: { ticks: { color: 'oklch(0.5 0.03 258)', font: { size: 11 } }, grid: { display: false } },
                y: { min: 0, max: 100, ticks: { color: 'oklch(0.5 0.03 258)', font: { size: 11 }, callback: v => v + '%' }, grid: { color: 'oklch(0.92 0.008 255)' } }
            }
        }
    });
}

let rtTrendInstance;
async function rtLoadTrend() {
    const data = await rtFetch('trend') || [];
    const ctx = document.getElementById('rtTrendChart');
    if (!ctx) return;
    if (rtTrendInstance) rtTrendInstance.destroy();
    const series = [
        { key: 'retention90', prov: 'provisional90', label: '90-Day', color: 'oklch(0.55 0.19 25)' },
        { key: 'retention180', prov: 'provisional180', label: '180-Day', color: 'oklch(0.7 0.16 145)' },
        { key: 'retention365', prov: 'provisional365', label: '365-Day', color: 'oklch(0.72 0.17 60)' },
    ];
    rtTrendInstance = new Chart(ctx, {
        type: 'line',
        data: {
            labels: data.map(d => d.label),
            datasets: series.map(s => ({
                label: s.label,
                data: data.map(d => d[s.key]),
                borderColor: s.color,
                backgroundColor: 'transparent',
                segment: { borderDash: c => data[c.p1DataIndex]?.[s.prov] ? [6, 4] : undefined },
                tension: 0.3, fill: false, pointRadius: 3, spanGaps: true
            }))
        },
        options: {
            responsive: true,
            plugins: { legend: { labels: { color: 'oklch(0.5 0.03 258)', font: { size: 11 } } } },
            scales: {
                x: { ticks: { color: 'oklch(0.5 0.03 258)', font: { size: 11 } }, grid: { display: false } },
                y: { min: 0, max: 100, ticks: { color: 'oklch(0.5 0.03 258)', font: { size: 11 }, callback: v => v + '%' }, grid: { color: 'oklch(0.92 0.008 255)' } }
            }
        }
    });
}

let rtLeaderboardInstance;
async function rtLoadLeaderboard() {
    const data = await rtFetch('store-leaderboard') || [];
    const ctx = document.getElementById('rtLeaderboardChart');
    if (!ctx) return;
    if (rtLeaderboardInstance) rtLeaderboardInstance.destroy();
    rtLeaderboardInstance = new Chart(ctx.getContext('2d'), {
        type: 'bar',
        data: { labels: data.map(d => d.label), datasets: [{ data: data.map(d => d.value), backgroundColor: 'oklch(0.7 0.16 145)', borderRadius: 4, maxBarThickness: 26 }] },
        options: {
            indexAxis: 'y',
            plugins: { legend: { display: false } },
            scales: {
                x: { min: 0, max: 100, grid: { color: 'oklch(0.92 0.008 255)' }, ticks: { color: 'oklch(0.5 0.03 258)', callback: v => v + '%' } },
                y: { grid: { display: false }, ticks: { color: 'oklch(0.5 0.03 258)' } }
            }
        }
    });
}

const RT_TENURE_COLORS = ['oklch(0.55 0.19 25)', 'oklch(0.65 0.15 190)', 'oklch(0.7 0.16 145)', 'oklch(0.72 0.17 60)', 'oklch(0.62 0.2 15)'];
let rtTenureInstance;
async function rtLoadTenureDistribution() {
    const data = await rtFetch('tenure-distribution') || [];
    const ctx = document.getElementById('rtTenureChart');
    if (!ctx) return;
    if (rtTenureInstance) rtTenureInstance.destroy();
    if (!data.length) return;
    rtTenureInstance = new Chart(ctx.getContext('2d'), {
        type: 'doughnut',
        data: { labels: data.map(d => d.label), datasets: [{ data: data.map(d => d.value), backgroundColor: RT_TENURE_COLORS, borderWidth: 2, borderColor: 'oklch(1 0 0)' }] },
        options: { cutout: '60%', plugins: { legend: { position: 'bottom', labels: { color: 'oklch(0.5 0.03 258)', boxWidth: 10, boxHeight: 10, padding: 12, font: { size: 11 } } } } }
    });
}

function rtRenderInsights(items) {
    const el = document.getElementById('rtInsights');
    if (!items || !items.length) { el.innerHTML = '<div class="text-muted" style="font-size:13px">No insights available yet — upload more periods of data to enable trend analysis.</div>'; return; }
    const colorMap = {
        danger:    { bg: 'oklch(0.6 0.22 22 / .08)', border: 'oklch(0.6 0.22 22)', text: 'oklch(0.6 0.22 22)' },
        success:   { bg: 'oklch(0.62 0.15 155 / .1)', border: 'oklch(0.62 0.15 155)', text: 'oklch(0.62 0.15 155)' },
        warning:   { bg: 'oklch(0.75 0.16 75 / .12)', border: 'oklch(0.75 0.16 75)', text: 'oklch(0.6 0.14 75)' },
        secondary: { bg: 'var(--bg-2)', border: 'var(--text-3)', text: 'var(--text-2)' }
    };
    el.innerHTML = items.map(item => {
        const c = colorMap[item.color] || colorMap.secondary;
        return `<div style="background:${c.bg};border-left:3px solid ${c.border};border-radius:8px;padding:12px 14px;margin-bottom:10px">
            <div class="d-flex align-items-start gap-2">
                <i class="bi ${item.icon} mt-1 flex-shrink-0" style="color:${c.text};font-size:15px"></i>
                <div>
                    <div style="font-size:12.5px;font-weight:700;color:${c.text};margin-bottom:2px">${item.title}</div>
                    <div style="font-size:12px;color:var(--text-2);line-height:1.5">${item.description}</div>
                </div>
            </div>
        </div>`;
    }).join('');
}

async function rtLoadInsights() {
    rtRenderInsights(await rtFetch('insights'));
}

async function rtLoadAll() {
    await Promise.all([rtLoadMilestones(), rtLoadSurvivalCurve(), rtLoadTrend(), rtLoadLeaderboard(), rtLoadTenureDistribution(), rtLoadInsights()]);
}

document.getElementById('rtStoreSelect').addEventListener('change', rtLoadAll);
document.getElementById('rtFromPeriodSelect').addEventListener('change', rtLoadAll);
document.getElementById('rtToPeriodSelect').addEventListener('change', rtLoadAll);
document.getElementById('rtOmSelect').addEventListener('change', rtLoadAll);
document.getElementById('rtOcSelect').addEventListener('change', rtLoadAll);

(async function init() {
    const hasData = await rtLoadFilters();
    if (hasData) await rtLoadAll();
})();
</script>
}
