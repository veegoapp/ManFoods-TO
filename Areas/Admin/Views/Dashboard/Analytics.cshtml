@{
    ViewData["Title"] = "Global Analytics";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Global Analytics</h1>
        <p class="page-subtitle">Workforce intelligence and turnover metrics</p>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <select id="periodSelect" class="form-select form-select-dark" style="width:180px">
            <option value="">Select Period</option>
        </select>
        <select id="storeSelect" class="form-select form-select-dark" style="width:200px">
            <option value="">All Stores</option>
        </select>
    </div>
</div>

<div id="kpiCards" class="kpi-grid mb-4">
    <div class="kpi-card"><div class="kpi-spinner"><div class="spinner-border spinner-border-sm"></div></div></div>
</div>

<div class="insight-card mb-4">
    <div class="insight-icon"><i class="bi bi-stars"></i></div>
    <div>
        <div class="insight-title">AI Insights</div>
        <div class="insight-text">Connect your AI key to enable smart workforce recommendations.</div>
    </div>
</div>

<div class="charts-grid">
    <div class="chart-card">
        <div class="chart-header"><h6>Turnover by Job Title</h6><p>Resignations grouped by role</p></div>
        <div class="chart-body"><canvas id="jobTitleChart"></canvas></div>
    </div>
    <div class="chart-card">
        <div class="chart-header"><h6>Turnover by Tenure</h6><p>Duration before resignation</p></div>
        <div class="chart-body"><canvas id="tenureChart"></canvas></div>
    </div>
    <div class="chart-card chart-full">
        <div class="chart-header"><h6>Gender Breakdown</h6><p>Active workforce distribution</p></div>
        <div class="chart-body chart-body-sm"><canvas id="genderChart"></canvas></div>
    </div>
</div>

<!-- Multi-Month Trend Chart -->
<div class="chart-card mt-4" style="border-radius:14px">
    <div class="chart-header d-flex align-items-center justify-content-between">
        <div>
            <h6>Monthly Turnover Trend</h6>
            <p>Turnover rate (%) across all available periods</p>
        </div>
        <a href="/admin/dashboard/reports" class="btn btn-sm" style="background:rgba(109,93,251,.15);color:#6D5DFB;border:1px solid rgba(109,93,251,.3);font-size:12px;border-radius:7px">
            <i class="bi bi-download me-1"></i>Export
        </a>
    </div>
    <div class="chart-body"><canvas id="trendChart" style="max-height:260px"></canvas></div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
    <script>
    (async function loadTrendChart() {
        try {
            const res = await fetch('/api/dashboard/trendmatrix');
            if (!res.ok) return;
            const data = await res.json();
            if (!data || !data.periods || data.periods.length === 0) return;

            const colors = ['#6D5DFB','#A78BFA','#27ae60','#3498db','#9b59b6','#e67e22'];
            const storeMap = {};
            data.rows.forEach(row => {
                storeMap[row.storeName] = data.periods.map(p => row.periodRates?.[p] ?? null);
            });
            const storeNames = Object.keys(storeMap).slice(0, 6);

            const ctx = document.getElementById('trendChart');
            if (!ctx) return;
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: data.periods,
                    datasets: storeNames.map((name, i) => ({
                        label: name,
                        data: storeMap[name],
                        borderColor: colors[i % colors.length],
                        backgroundColor: colors[i % colors.length] + '22',
                        tension: 0.4,
                        fill: false,
                        pointRadius: 4,
                        spanGaps: true
                    }))
                },
                options: {
                    responsive: true,
                    plugins: { legend: { labels: { color: '#ccc', font: { size: 11 } } } },
                    scales: {
                        x: { ticks: { color: '#888', font: { size: 11 } }, grid: { color: '#2a2a2a' } },
                        y: { ticks: { color: '#888', font: { size: 11 }, callback: v => v + '%' }, grid: { color: '#2a2a2a' } }
                    }
                }
            });
        } catch(e) { console.warn('Trend chart error:', e); }
    })();
    </script>
}
