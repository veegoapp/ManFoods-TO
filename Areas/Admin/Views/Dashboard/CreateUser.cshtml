@model MvcApp.Models.ViewModels.CreateUserViewModel
@{
    ViewData["Title"] = L["Page_CreateUser"].Value;
}

<div class="page-header">
    <div><h1 class="page-title">@L["Page_CreateUser"]</h1><p class="page-subtitle">@L["Page_CreateUserSub"]</p></div>
    <a href="/admin/dashboard/users" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>@L["Common_Back"]</a>
</div>

<div class="card-dark" style="max-width:520px">
    <form asp-area="Admin" asp-controller="Dashboard" asp-action="CreateUser" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert-banner alert-error-banner mb-3"></div>
        <div class="mb-3">
            <label asp-for="Email" class="form-label-dark">@L["Common_Email"]</label>
            <input asp-for="Email" class="form-control form-control-dark" placeholder="user@manfoods.com"/>
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Phone" class="form-label-dark">@L["Common_Phone"]</label>
            <input asp-for="Phone" class="form-control form-control-dark" placeholder="+20 1xx xxx xxxx"/>
            <span asp-validation-for="Phone" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Password" class="form-label-dark">@L["Login_Password"]</label>
            <input asp-for="Password" type="password" class="form-control form-control-dark" placeholder="Min. 6 characters"/>
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>
        <div class="mb-4">
            <label asp-for="Role" class="form-label-dark">@L["Common_Role"]</label>
            <select asp-for="Role" class="form-select form-select-dark">
                <option value="">@L["CU_SelectRole"]</option>
                <option value="Admin">Admin</option>
                <option value="User">User</option>
            </select>
            <span asp-validation-for="Role" class="text-danger small"></span>
        </div>
        <button type="submit" class="btn btn-primary w-100">@L["CU_CreateUser"]</button>
    </form>
</div>
