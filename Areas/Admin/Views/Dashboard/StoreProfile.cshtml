@{
    ViewData["Title"] = "Store Profile";
    var storeName = ViewBag.StoreName as string ?? "";
    var storeLeader = ViewBag.StoreLeader as string ?? "";
    var oc = ViewBag.OperationConsultant as string ?? "";
    var om = ViewBag.OperationManager as string ?? "";
}

<div class="page-header">
    <div>
        <a href="/admin/dashboard/turnover" class="btn btn-sm mb-2" style="background:oklch(0.5 0.18 25 / .15);color:oklch(0.5 0.18 25);border:1px solid oklch(0.5 0.18 25 / .3);font-size:12px;border-radius:7px">
            <i class="bi bi-arrow-left me-1"></i>Back to Turnover Analysis
        </a>
        <h1 class="page-title">@storeName</h1>
        <p class="page-subtitle">
            Leader: @(string.IsNullOrEmpty(storeLeader) ? "—" : storeLeader)
            &nbsp;·&nbsp; OC: @(string.IsNullOrEmpty(oc) ? "—" : oc)
            &nbsp;·&nbsp; OM: @(string.IsNullOrEmpty(om) ? "—" : om)
        </p>
    </div>
    <div class="d-flex gap-2">
        <select id="periodSelect" class="form-select form-select-dark" style="width:180px">
            <option value="">Select Period</option>
        </select>
    </div>
</div>

<div id="kpiCards" class="kpi-grid mb-4">
    <div class="kpi-card"><div class="kpi-spinner"><div class="spinner-border spinner-border-sm"></div></div></div>
</div>

<div id="networkCompareCard" class="insight-card mb-4">
    <div class="insight-icon"><i class="bi bi-bar-chart-steps"></i></div>
    <div>
        <div class="insight-title">Vs. Network Average</div>
        <div class="insight-text" id="networkCompareText">Loading comparison…</div>
    </div>
</div>

<div class="charts-grid mb-4">
    <div class="chart-card">
        <div class="chart-header"><h6>Turnover by Job Title</h6><p>Resignations grouped by role</p></div>
        <div class="chart-body"><canvas id="jobTitleChart"></canvas></div>
    </div>
    <div class="chart-card">
        <div class="chart-header"><h6>Turnover by Tenure</h6><p>Duration before resignation</p></div>
        <div class="chart-body"><canvas id="tenureChart"></canvas></div>
    </div>
    <div class="chart-card chart-full">
        <div class="chart-header"><h6>Gender Breakdown</h6><p>Active workforce distribution</p></div>
        <div class="chart-body chart-body-sm"><canvas id="genderChart"></canvas></div>
    </div>
</div>

<!-- ── Monthly Trend Chart ─────────────────────────────────── -->
<div class="chart-card mb-4" style="border-radius:14px">
    <div class="chart-header">
        <h6>Turnover Trend</h6>
        <p>This store's turnover rate (%) across all available periods</p>
    </div>
    <div class="chart-body"><canvas id="trendChart" style="max-height:260px"></canvas></div>
</div>

<!-- ── Active Employees ───────────────────────────────────── -->
<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-2">
        <div style="width:4px;height:22px;background:linear-gradient(135deg,oklch(0.44 0.18 25),oklch(0.6 0.16 25));border-radius:2px"></div>
        <h5 class="mb-0 fw-bold">Active Employees</h5>
        <span id="employeeCountBadge" class="badge" style="background:oklch(0.965 0.008 255);color:oklch(0.5 0.03 258);font-size:11px"></span>
    </div>
</div>
<div class="chart-card mb-4 p-0" style="overflow:hidden">
    <div class="table-responsive" style="max-height:400px;overflow-y:auto">
        <table class="table table-hover mb-0" style="font-size:13px">
            <thead style="background:oklch(0.965 0.008 255);border-bottom:2px solid oklch(0.92 0.008 255);position:sticky;top:0;z-index:1">
                <tr>
                    <th class="px-3 py-2">Name</th>
                    <th class="px-3 py-2">Job Title</th>
                    <th class="px-3 py-2">Grade</th>
                    <th class="px-3 py-2">Gender</th>
                    <th class="px-3 py-2">Hire Date</th>
                </tr>
            </thead>
            <tbody id="employeesTableBody">
                <tr><td colspan="5" class="text-center py-4 text-muted">
                    <div class="spinner-border spinner-border-sm me-2" style="color:oklch(0.6 0.22 22)"></div>Loading...
                </td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- ── Resignation History ────────────────────────────────── -->
<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-2">
        <div style="width:4px;height:22px;background:linear-gradient(135deg,oklch(0.44 0.18 25),oklch(0.6 0.16 25));border-radius:2px"></div>
        <h5 class="mb-0 fw-bold">Resignation History</h5>
        <span class="badge ms-1" style="background:oklch(0.965 0.008 255);color:oklch(0.5 0.03 258);font-size:11px">All Periods</span>
    </div>
</div>
<div class="chart-card mb-4 p-0" style="overflow:hidden">
    <div class="table-responsive" style="max-height:400px;overflow-y:auto">
        <table class="table table-hover mb-0" style="font-size:13px">
            <thead style="background:oklch(0.965 0.008 255);border-bottom:2px solid oklch(0.92 0.008 255);position:sticky;top:0;z-index:1">
                <tr>
                    <th class="px-3 py-2">Name</th>
                    <th class="px-3 py-2">Job Title</th>
                    <th class="px-3 py-2">Hire Date</th>
                    <th class="px-3 py-2">Resignation Date</th>
                    <th class="px-3 py-2 text-center">Tenure</th>
                </tr>
            </thead>
            <tbody id="resignationsTableBody">
                <tr><td colspan="5" class="text-center py-4 text-muted">
                    <div class="spinner-border spinner-border-sm me-2" style="color:oklch(0.6 0.22 22)"></div>Loading...
                </td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="~/js/dashboard.js" asp-append-version="true"></script>
<script>
storeFilter = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(storeName));

function fmtDate(d) {
    if (!d) return '—';
    const dt = new Date(d);
    return dt.toLocaleDateString('default', { day: '2-digit', month: 'short', year: 'numeric' });
}

function tenureLabel(hire, end) {
    if (!hire) return '—';
    const h = new Date(hire);
    const e = end ? new Date(end) : new Date();
    let months = (e.getFullYear() - h.getFullYear()) * 12 + (e.getMonth() - h.getMonth());
    if (months < 0) months = 0;
    if (months < 12) return `${months} mo`;
    return `${(months / 12).toFixed(1)} yr`;
}

/* Network comparison ----------------------------------------- */
async function loadNetworkCompare() {
    if (!periodMonth || !periodYear) return;
    const [storeKpi, networkKpi] = await Promise.all([
        fetchJson(`/api/dashboard/kpis?month=${periodMonth}&year=${periodYear}&store=${encodeURIComponent(storeFilter)}`),
        fetchJson(`/api/dashboard/kpis?month=${periodMonth}&year=${periodYear}`)
    ]);
    const el = document.getElementById('networkCompareText');
    if (!el || !storeKpi || !networkKpi) return;
    const diff = (storeKpi.turnoverRate || 0) - (networkKpi.turnoverRate || 0);
    const arrow = diff > 0 ? '▲' : diff < 0 ? '▼' : '—';
    const color = diff > 0 ? 'oklch(0.6 0.22 22)' : diff < 0 ? 'oklch(0.62 0.15 155)' : 'oklch(0.5 0.03 258)';
    el.innerHTML = `This store: <strong>${(storeKpi.turnoverRate || 0).toFixed(1)}%</strong> &nbsp;|&nbsp; Network average: <strong>${(networkKpi.turnoverRate || 0).toFixed(1)}%</strong> &nbsp;|&nbsp; <span style="color:${color};font-weight:700">${arrow} ${Math.abs(diff).toFixed(1)}%</span>`;
}

/* Active employees --------------------------------------------- */
async function loadEmployees() {
    if (!periodMonth || !periodYear) return;
    const rows = await fetchJson(`/api/dashboard/store-employees?store=${encodeURIComponent(storeFilter)}&month=${periodMonth}&year=${periodYear}`);
    const badge = document.getElementById('employeeCountBadge');
    if (badge) badge.textContent = (rows ? rows.length : 0) + ' employees';

    const tbody = document.getElementById('employeesTableBody');
    if (!rows || !rows.length) {
        tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4 text-muted">No employees for this period.</td></tr>';
        return;
    }
    tbody.innerHTML = rows.map(r => `<tr>
        <td class="px-3 py-2 fw-semibold">${r.name}</td>
        <td class="px-3 py-2">${r.jobTitle || '—'}</td>
        <td class="px-3 py-2">${r.grade || '—'}</td>
        <td class="px-3 py-2">${r.gender || '—'}</td>
        <td class="px-3 py-2">${fmtDate(r.hireDate)}</td>
    </tr>`).join('');
}

/* Resignation history -------------------------------------------- */
async function loadResignations() {
    const rows = await fetchJson(`/api/dashboard/store-resignations?store=${encodeURIComponent(storeFilter)}`);
    const tbody = document.getElementById('resignationsTableBody');
    if (!rows || !rows.length) {
        tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4 text-muted">No resignation history for this store.</td></tr>';
        return;
    }
    tbody.innerHTML = rows.map(r => `<tr>
        <td class="px-3 py-2 fw-semibold">${r.name}</td>
        <td class="px-3 py-2">${r.jobTitle || '—'}</td>
        <td class="px-3 py-2">${fmtDate(r.hireDate)}</td>
        <td class="px-3 py-2">${fmtDate(r.resignationDate)}</td>
        <td class="px-3 py-2 text-center">${tenureLabel(r.hireDate, r.resignationDate)}</td>
    </tr>`).join('');
}

/* Trend chart (single store) ------------------------------------- */
function fmtPeriod(pk) {
    const [y, m] = pk.split('-');
    return new Date(+y, +m - 1, 1).toLocaleString('default', { month: 'short', year: '2-digit' });
}

async function loadTrendChart() {
    const data = await fetchJson('/api/dashboard/trend-matrix');
    if (!data || !data.periods || !data.periods.length) return;
    const row = data.rows.find(r => r.storeName === storeFilter);
    if (!row) return;

    const ctx = document.getElementById('trendChart');
    if (!ctx) return;
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: data.periods.map(fmtPeriod),
            datasets: [{
                label: storeFilter,
                data: data.periods.map(p => row.periodRates?.[p] ?? null),
                borderColor: 'oklch(0.5 0.18 25)',
                backgroundColor: 'oklch(0.5 0.18 25 / .15)',
                tension: 0.4,
                fill: true,
                pointRadius: 4,
                spanGaps: true
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                x: { ticks: { color: 'oklch(0.5 0.03 258)', font: { size: 11 } }, grid: { color: 'oklch(0.92 0.008 255)' } },
                y: { ticks: { color: 'oklch(0.5 0.03 258)', font: { size: 11 }, callback: v => v + '%' }, grid: { color: 'oklch(0.92 0.008 255)' } }
            }
        }
    });
}

/* Hook into dashboard.js loadAll so extras refresh on period change */
const _spOrigLoadAll = loadAll;
loadAll = async function () {
    await _spOrigLoadAll();
    await loadNetworkCompare();
    await loadEmployees();
};

loadResignations();
loadTrendChart();
</script>
}
