@model MvcApp.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Change Password</h1>
        <p class="page-subtitle">Update your account password</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card-dark p-4">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="card-icon"><i class="bi bi-key-fill"></i></div>
                <div>
                    <h5 class="mb-0">Update Password</h5>
                    <p class="text-muted-custom mb-0 small">Minimum 8 characters required</p>
                </div>
            </div>

            <form asp-area="Admin" asp-controller="Account" asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="alert alert-danger small mb-3" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <div class="mb-3">
                    <label class="form-label small text-muted-custom">Current Password</label>
                    <input asp-for="CurrentPassword" type="password" class="form-control form-control-dark" placeholder="Enter current password" />
                    <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label small text-muted-custom">New Password</label>
                    <input asp-for="NewPassword" type="password" class="form-control form-control-dark" placeholder="Minimum 8 characters" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label small text-muted-custom">Confirm New Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control form-control-dark" placeholder="Repeat new password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-shield-lock-fill me-2"></i>Update Password
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
