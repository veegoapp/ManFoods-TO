@model MvcApp.Models.ViewModels.LoginViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<MvcApp.Resources.SharedResource> L
@{
    Layout = null;
    var _lang = Context.Request.Cookies["mf-lang"] ?? "en";
    var _isRtl = _lang == "ar";
    var _switchLang = _isRtl ? "en" : "ar";
}
<!DOCTYPE html>
<html lang="@_lang" dir="@(_isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Admin Sign In — Workforce Intelligence</title>
    <link rel="icon" type="image/png" href="~/images/mclogo.png"/>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <script>document.documentElement.setAttribute('data-theme', localStorage.getItem('mf-theme') || 'light');</script>
    <style>
        /* ── Brand colors ── */
        :root {
            --red:        #DA291C;
            --red-dark:   #B01E11;
            --red-light:  rgba(218,41,28,.12);
            --red-glow:   rgba(218,41,28,.25);
            --shadow-red: 0 4px 20px rgba(218,41,28,.35);
            --gold:       #FFC72C;
            --gold-dark:  #E5A800;
            --gold-light: rgba(255,199,44,.15);
            --gold-glow:  rgba(255,199,44,.3);
        }
        [data-theme="light"] { --shadow-red: 0 4px 20px rgba(218,41,28,.2); }

        @@keyframes cardEntrance { 0%{opacity:0;transform:translateY(28px) scale(.97)} 100%{opacity:1;transform:translateY(0) scale(1)} }
        @@keyframes logoFloat { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }
        @@keyframes floatUp { 0%{transform:translateY(0) rotate(0deg);opacity:.25} 100%{transform:translateY(-100vh) rotate(360deg);opacity:0} }

        .login-body {
            background: var(--bg);
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            position: relative; overflow: hidden;
        }
        .login-body::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
            background: linear-gradient(90deg, var(--red), var(--gold));
        }
        [data-theme="light"] .login-body { background: #ffffff; }

        .bubble { position: absolute; border-radius: 50%; background: rgba(255,199,44,.06); animation: floatUp linear infinite; }
        [data-theme="light"] .bubble { background: rgba(218,41,28,.05); }

        .login-theme-toggle {
            position: fixed; top: 16px; right: 16px; z-index: 100;
            width: 38px; height: 38px; border-radius: 10px;
            border: 1px solid var(--card-border);
            background: var(--card-bg); color: var(--text-2);
            display: flex; align-items: center; justify-content: center;
            font-size: 16px; cursor: pointer; transition: all .2s;
        }
        .login-theme-toggle:hover { border-color: var(--gold); color: var(--gold); }
        .login-theme-toggle .icon-dark  { display: block; }
        .login-theme-toggle .icon-light { display: none; }
        [data-theme="light"] .login-theme-toggle .icon-dark  { display: none; }
        [data-theme="light"] .login-theme-toggle .icon-light { display: block; }

        .lang-toggle {
            position: fixed; top: 16px; left: 16px; z-index: 100;
            width: 38px; height: 38px; border-radius: 10px;
            border: 1px solid var(--card-border);
            background: var(--card-bg); color: var(--text-2);
            display: flex; align-items: center; justify-content: center;
            font-size: 11px; font-weight: 700; cursor: pointer; transition: all .2s;
            text-decoration: none; letter-spacing: .5px;
        }
        .lang-toggle:hover { border-color: var(--gold); color: var(--gold); }

        .login-container { width: 100%; max-width: 420px; padding: 16px; position: relative; z-index: 10; }

        .login-card {
            background: var(--card-bg); border: 1px solid var(--card-border);
            border-radius: 14px; padding: 44px 40px 36px;
            box-shadow: var(--shadow-lg);
            animation: cardEntrance .55s cubic-bezier(.22,1,.36,1) both;
            position: relative; overflow: hidden;
        }
        .login-card::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
            background: linear-gradient(90deg, var(--red), var(--gold));
        }

        .admin-badge {
            display: inline-flex; align-items: center; gap: 5px;
            background: var(--red-light); border: 1px solid rgba(218,41,28,.25); color: var(--red);
            font-size: 10px; font-weight: 700; letter-spacing: .8px; text-transform: uppercase;
            padding: 3px 10px; border-radius: 20px; margin-bottom: 14px;
        }

        .logo-wrap { display: inline-block; animation: logoFloat 3.5s ease-in-out infinite; filter: drop-shadow(0 4px 10px rgba(255,199,44,.4)); }
        .logo-wrap img { width: 70px; height: auto; }

        .login-title { font-size: 28px; font-weight: 800; color: var(--text); margin: 10px 0 0; line-height: 32px; letter-spacing: -.3px; }
        .login-title span { color: var(--gold); }
        [data-theme="light"] .login-title span { color: var(--red); }
        .login-subtitle { font-size: 11px; color: var(--text-3); margin: 6px 0 0; letter-spacing: 1.2px; text-transform: uppercase; font-weight: 400; }

        .divider { display: flex; align-items: center; gap: 10px; margin: 22px 0 18px; }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--card-border); }
        .divider span { font-size: 11px; color: var(--text-3); font-weight: 400; white-space: nowrap; }

        .field-wrap { position: relative; margin-bottom: 16px; }
        .field-wrap .fi { position: absolute; left: 14px; top: calc(50% + 13px); transform: translateY(-50%); color: var(--text-3); font-size: 15px; pointer-events: none; transition: color .2s; }
        .field-wrap:focus-within .fi { color: var(--gold); }
        [data-theme="light"] .field-wrap:focus-within .fi { color: var(--red); }
        .field-wrap label { font-size: 11px; font-weight: 700; color: var(--text-2); text-transform: uppercase; letter-spacing: .8px; margin-bottom: 6px; display: block; }
        .field-wrap input {
            padding-left: 40px; height: 48px; font-size: 15px;
            border-radius: 8px; border: 1.5px solid var(--card-border);
            background: var(--card-bg-2); color: var(--text); width: 100%;
            transition: all .2s; outline: none; font-family: inherit;
        }
        .field-wrap input:focus { background: var(--card-bg); border-color: var(--gold); box-shadow: 0 0 0 3px rgba(255,199,44,.12); }
        [data-theme="light"] .field-wrap input:focus { border-color: var(--red); box-shadow: 0 0 0 3px rgba(218,41,28,.1); }
        .field-wrap input::placeholder { color: var(--text-3); }

        .btn-signin {
            width: 100%; min-height: 50px;
            background: linear-gradient(135deg, var(--red) 0%, var(--red-dark) 100%);
            border: 1px solid var(--red-dark); border-radius: 48px; color: #fff;
            font-size: 16px; font-weight: 700; cursor: pointer;
            transition: all .2s; margin-top: 8px; font-family: inherit;
            box-shadow: var(--shadow-red);
        }
        .btn-signin:hover { box-shadow: 0 6px 24px rgba(218,41,28,.45); transform: translateY(-1px); }

        .user-portal-link { display: block; text-align: center; margin-top: 16px; font-size: 12px; color: var(--text-3); }
        .user-portal-link a { color: var(--gold); font-weight: 700; text-decoration: none; }
        [data-theme="light"] .user-portal-link a { color: var(--red); }
        .user-portal-link a:hover { text-decoration: underline; }
        .login-footer { text-align: center; margin-top: 18px; font-size: 11px; color: var(--text-3); }

        .alert-error-banner { background: var(--danger-bg); border-left: 4px solid var(--red); color: #fca5a5; padding: 11px 16px; border-radius: 8px; font-size: 14px; margin-bottom: 16px; }
        [data-theme="light"] .alert-error-banner { color: var(--red); }
        .alert-success-banner { background: var(--success-bg); border-left: 4px solid var(--success); color: var(--success); padding: 11px 16px; border-radius: 8px; font-size: 14px; margin-bottom: 16px; }

        /* ── RTL overrides ── */
        [dir="rtl"] .lang-toggle    { left: auto; right: 16px; }
        [dir="rtl"] .login-theme-toggle { right: auto; left: 16px; }
        [dir="rtl"] .field-wrap .fi { left: auto; right: 14px; }
        [dir="rtl"] .field-wrap input { padding-left: 16px; padding-right: 40px; }
        [dir="rtl"] .alert-error-banner   { border-left: none; border-right: 4px solid var(--red); }
        [dir="rtl"] .alert-success-banner { border-left: none; border-right: 4px solid var(--success); }
        [dir="rtl"] .user-portal-link { direction: rtl; }
        [dir="rtl"] .login-footer { direction: rtl; }
        [dir="rtl"] .btn-signin i { margin-right: 0; margin-left: .5rem; }
        [dir="rtl"] .divider { direction: rtl; }
        [dir="rtl"] .admin-badge i { margin-right: 0; margin-left: 5px; }
    </style>
</head>
<body class="login-body">

    <button class="login-theme-toggle" id="themeToggle" title="Toggle theme">
        <i class="bi bi-moon-stars-fill icon-dark"></i>
        <i class="bi bi-sun-fill icon-light"></i>
    </button>

    <form action="/language/set" method="post" style="position:fixed;top:16px;left:16px;z-index:100;margin:0">
        @Html.AntiForgeryToken()
        <input type="hidden" name="lang" value="@_switchLang"/>
        <input type="hidden" name="returnUrl" value="/adminlogin"/>
        <button type="submit" class="lang-toggle">@L["Layout_SwitchLang"]</button>
    </form>

    <div class="bubble" style="width:70px;height:70px;left:5%;animation-duration:14s;bottom:-70px;"></div>
    <div class="bubble" style="width:30px;height:30px;left:18%;animation-duration:9s;animation-delay:2s;bottom:-30px;"></div>
    <div class="bubble" style="width:90px;height:90px;left:75%;animation-duration:16s;animation-delay:1s;bottom:-90px;"></div>
    <div class="bubble" style="width:20px;height:20px;left:88%;animation-duration:8s;animation-delay:3s;bottom:-20px;"></div>

    <div class="login-container">
        <div class="login-card">
            <div class="text-center">
                <div class="admin-badge"><i class="bi bi-shield-lock-fill"></i> @L["Login_AdminPortal"]</div>
                <div class="logo-wrap">
                    <img src="/images/mclogo.png" alt="Logo"/>
                </div>
                <h1 class="login-title">Workforce Intelligence <span>Crew Level</span></h1>
                <p class="login-subtitle">@L["Login_AdminDashboard"]</p>
            </div>

            <div class="divider"><span>@L["Login_SignInToContinue"]</span></div>

            @if (TempData["Success"] != null)
            {
                <div class="alert-success-banner"><i class="bi bi-check-circle-fill me-1"></i>@TempData["Success"]</div>
            }

            <form asp-area="Admin" asp-controller="Account" asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-error-banner">
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div><i class="bi bi-exclamation-triangle-fill me-1"></i>@err.ErrorMessage</div>
                        }
                    </div>
                }

                <div class="field-wrap">
                    <label>@L["Login_EmailAddress"]</label>
                    <i class="bi bi-envelope-fill fi"></i>
                    <input asp-for="Email" type="email" placeholder="admin@mcd.com" autocomplete="email"/>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="field-wrap">
                    <label>@L["Login_Password"]</label>
                    <i class="bi bi-lock-fill fi"></i>
                    <input asp-for="Password" type="password" placeholder="••••••••" autocomplete="current-password"/>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn-signin">
                    <i class="bi bi-shield-lock me-2"></i>@L["Login_SignInAdmin"]
                </button>
            </form>

            <div class="user-portal-link">
                <a href="/admin/account/recover">@L["Login_ForgotPasswordAdmin"]</a>
            </div>
            <div class="login-footer">&copy; @DateTime.Now.Year Workforce Intelligence – Crew Level</div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script>
    (function () {
        const btn = document.getElementById('themeToggle');
        const root = document.documentElement;
        if (btn) {
            btn.addEventListener('click', () => {
                const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
                root.setAttribute('data-theme', next);
                localStorage.setItem('mf-theme', next);
            });
        }
    })();
    </script>
</body>
</html>
